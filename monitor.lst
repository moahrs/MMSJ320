                    2700   ; *
                    2701   ; * Mapa de Memoria
                    2702   ; * ---------------
                    2703   ; *
                    2704   ; *     SLOT 0                          SLOT 1
                    2705   ; * +-------------+ 000000h
                    2706   ; * |   EEPROM    |
                    2707   ; * |   512KB     |
                    2708   ; * |   (BIOS)    | 07FFFFh
                    2709   ; * +-------------+ 080000h
                    2710   ; * |    LIVRE    | 1FFFFFh
                    2711   ; * +-------------+ 200000h
                    2712   ; * |             |
                    2713   ; * |  EXPANSAO   |
                    2714   ; * |             | 3FFFFFh
                    2715   ; * +-------------+ 400000h
                    2716   ; * |             |
                    2717   ; * | PERIFERICOS |
                    2718   ; * |             | 5FFFFFh
                    2719   ; * +-------------+ 600000h
                    2720   ; * |  RAM 256KB  |
                    2721   ; * |  BUFFER E   |
                    2722   ; * |  SISTEMA    | 63FFFFh
                    2723   ; * +-------------+ 640000h
                    2724   ; * |    LIVRE    | 7FFFFFh
                    2725   ; * +-------------+ 800000h
                    2726   ; * |             |
                    2727   ; * |   ATUAL     |
                    2728   ; * |    RAM      |
                    2729   ; * |  USUARIO    |
                    2730   ; * |    1MB      | 8FFFFFh
                    2731   ; * +-------------+ 900000h
                    2732   ; * |             |
                    2733   ; * |             |
                    2734   ; * |    RAM      |
                    2735   ; * |  USUARIO    |
                    2736   ; * |    7MB      |
                    2737   ; * |             |
                    2738   ; * |             |
                    2739   ; * |             |
                    2740   ; * |             |
                    2741   ; * |             |
                    2742   ; * |             |
                    2743   ; * |             |
                    2744   ; * |             |
                    2745   ; * +-------------+ FFFFFFh
                    2746   ; *--------------------------------------------------------------------------------
                    2747   ; *
                    2748   ; * Enderecos de Perifericos
                    2749   ; *
                    2750   ; * 00200001h e 00200003 - DISK Arduino UNO (Temp)
                    2751   ; *                        - A1 = 0: r/w 4 bits LSB
                    2752   ; *                        - A1 = 1: r/w 4 bits MSB
                    2753   ; * 00400020h a 0040003F - MFP MC68901p - Cristal de 2.4576MHz
                    2754   ; *                        - SERIAL 9600, 8, 1, n
                    2755   ; *                        - TECLADO (PC-AT - PS/2)
                    2756   ; *                        - Controle de Interrupcoes e PS/2
                    2757   ; * 00400040h a 00400043 - VIDEO TMS9118 (16KB VRAM):
                    2758   ; *             00400041 - Data Mode
                    2759   ; *             00400043 - Register / Adress Mode
                    2760   ; ********************************************************************************/
