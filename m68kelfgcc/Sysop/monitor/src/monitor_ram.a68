* Executar SO pre-carregado no endere�o de memoria 0x00800000
*
_runSO:
       movem.l   D0-D7/A0-A6,-(A7)
       jsr       $00800000       ; Jump to position ram memory
       movem.l   (A7)+,D0-D7/A0-A6
       rts

_runCmd:
       xref _runMemory
       movem.l   D0-D7/A0-A6,-(A7)
       move.l    _runMemory,A0
       jsr       (A0)       ; Jump to position ram memory
       movem.l   (A7)+,D0-D7/A0-A6
       rts

_runBas:
       movem.l   D0-D7/A0-A6,-(A7)
       jsr       $00020000       ; Jump to position Basic ram memory
       movem.l   (A7)+,D0-D7/A0-A6
       rts

_runBasAp2:
       movem.l   D0-D7/A0-A6,-(A7)
       jsr       $00008000       ; Jump to position Basic Apple 2 ram memory
       movem.l   (A7)+,D0-D7/A0-A6
       rts

_runOSCmd:
       movem.l   D0-D7/A0-A6,-(A7)
       jsr       $00800170                          ; lembrar de ajustar esse endere�o se ele mudar
       movem.l   (A7)+,D0-D7/A0-A6
       rts

_probeDiskDrive:
       clr.l     ($0060F958)
       move.l    #PROBE_DISK_BERR,($0060F954)
       move.b    ($00200001),D0
       clr.l     ($0060F954)
       moveq     #1,D0
       rts

PROBE_DISK_BERR:
       clr.l     ($0060F954)
       moveq     #0,D0
       rts

* Executar Funcoes Traps
