FILES_RELOC_TBL_OFFSET  equ $00000022   ; FICTICIO: offset do cabecalho de relocacao (qtd de funcoes)

            xdef _runFromOsCmd

_runFromOsCmd:
       movem.l   D0/D1/D2/D3/D4/D5/D6/D7/A0/A1/A2/A3/A4/A5/A6,-(A7)
       move.l    64(A7),A0
       jsr       (A0)       ; Jump to position ram memory
       movem.l   (A7)+,D0/D1/D2/D3/D4/D5/D6/D7/A0/A1/A2/A3/A4/A5/A6
       rts