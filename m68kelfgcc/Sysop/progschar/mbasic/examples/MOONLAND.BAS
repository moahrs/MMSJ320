PROC MAIN
  SCREEN 2
  COLOR 15,1
  FOR N=1 TO 50
    PLOT RND(1)*255,RND (1) *140,15
  NEXT N
  
  DRAW "C6BM0,188M+18,-30M+18,+15M+18,+8M+18,-8M+16,-20M+16,-5M+13,+20M+14,+8M+18,+4M+10,0M+10,-10M+20,-25M+10,+20M+10,+10M+20,+5M+18,-20M255,191"
  ' PAINT 10,191,6
  
  DRAW "C1BM145,188M+2,-4M+14,0M+2,+4"
  DRAW "BM93,157C1D31R1U31"
  
  S=-1
  LX=INT(RND(-1)*240)+10
  LY=INT(RND(-1)*10)+15
  XV=INT(RND(-1)*10)
  YU=0
  F=256
  
  AX=LX
  AY=LY
  
  CALL G4000

  LBL120:
  CALL G1000
  CALL G2000
  CALL G3000
  
  IF LY<173 THEN GOTO LBL120
  
  FOR TT=0 TO 200
  NEXT TT
  
  SCREEN 0
  COLOR 15,1

  IF LX<147 OR LX>161 THEN GOTO LBL190
  IF ABS(YV)>4 THEN GOTO LBL200

  LOCATE 5,10
  PRINT "Congratulations, successful landing."
  GOTO LBL210

  LBL190:
  LOCATE 7,10
  PRINT "!! off-platform !!"
  GOTO LBL210
  
  LBL200:
  LOCATE 0,10
  PRINT "damaged spacecraft, inappropriate speed"

  LBL210:
  END
ENDPROC

PROC G1000
  IF LY>1 THEN CALL G4000
  LX=LX+XV
  LY=LY+YV
  IF LX<5 THEN LX=LX+245
  IF LX>250 THEN LX=LX-242
  IF LY<1 THEN RETURN
  IF LY>150 THEN RETURN
  
  CALL G4000
ENDPROC

PROC G2000
  YV=YV+0.5

  IF F<l THEN RETURN
  
  GET I$
  
  IF I$="Q" THEN
    SCREEN 0
    PRINT "BYE"
    END
  ENDIF

  IF I$="S" AND F>3 THEN 
    YV=YV-1
    F=F-3
    RETURN
  ENDIF

  IF I$="A" THEN 
    XV=XV-0.5
    F=F-1 
    RETURN
  ENDIF

  IF I$="D" THEN 
    XV=XV+0.5 
    F=F-1 
    RETURN
  ENDIF
ENDPROC

PROC G3000
  G$=STR$(INT ((256-F)/8))
  DRAW "C6BM93,157D"+G$+"R1U"+G$
  DRAW "C6BM105,155D35"
  DC$="C15BM105,173M+0,"+STR$(INT(YV))
  DRAW DC$
ENDPROC

PROC G4000
  DA$="C1BM"+STR$(INT(AX))+","+STR$(INT(AY))+"M-5,+10M+5,-2M+5,+2M-4,-10"
  DRAW DA$
  DB$="C15BM"+STR$(INT(LX))+","+STR$(INT(LY))+"M-5,+10M+5,-2M+5,+2M-4,-10"
  DRAW DB$
  AX=INT(LX)
  AY=INT(LY)
ENDPROC
