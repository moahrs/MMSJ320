PROC MAIN
  LBL100:
  SCREEN 0
  CLS
  COLOR 15,1,1
  PRINT "       Quantas polias? (2,4 ou 6)?";

  LBL110:
  GET A$
  IF ASC(A$)=27 THEN END
  IF A$<>"2" AND A$<>"4" AND A$ <>"6" THEN GOTO LBL110

  PRINT A$
  NP=VAL(A$)
  L=25*NP-50

  PRINT
  PRINT "       Forca necessaria = "; INT(1000/NP) ;"Kg"
  PRINT "       para levantar 1 tonelada"
  
  FOR G=l TO 1500
  NEXT G
  
  CLS
  SCREEN 2
  COLOR 15,1

  FILL 0,0,255,10,5

  BUFDRAW 1

  CLS
  
  FOR K=1 TO NP STEP 2
    CIRCLE (232-K*26),33,13,2
    PAINT (232-K*26),33,2
    LINE (232-K*26),33 TO (232-K*26),10
  NEXT K

  KA = K
  
  FILL 208,32,(256-NP*26),34

  FOR V=0 TO -30 STEP -5
    CALL POLIAS
    
    ' COPIA PESO PRIMEIRO
    BUFCOPY 1,0,((232-KA*26)-20),11,((232-KA*26)+13),190 

    ' COPIA AS POLIAS DEPOIS
    BUFCOPY 1,0,((232-KA*26)-20),11,254,190 
  NEXT V

  FOR I=1 TO 2000
  NEXT I

  GOTO LBL100
ENDPROC

PROC POLIAS
  FILL (194-L-NP-12/NP),(75-3*(V+5)),(196-L-NP+12/NP),(75+30/NP-3*(V+5)),1
  LINE (195-L-NP), 33 TO (195-L-NP),(75-3*V) COLOR 2
  FILL (194-L-NP-12/NP),(75-3*V),(196-L-NP+12/NP), (75+30/NP-3*V),10
  FILL (215-L),(107+V),249,(175+V),1

  FOR K=1 TO NP STEP 2
    CIRCLE (258-K*26),(121+V),13,2
    PAINT (258-K*26),(121+V) ,2
  NEXT K
  
  LINE 245,10 TO 245,(121+V) COLOR 2

  FOR K=1 TO NP-1
    LINE (246-K*26), 35 TO (246-K*26),(121+V) COLOR 2
  NEXT K

  FILL 234,(120+V),(282-NP*26),(122+V),8
  LINE (232-L*2/3),(121+V) TO (232-L*2/3),(141+V) COLOR 8
  LINE (232-L/3),(121+V) TO (232-L/3),(141+V) TO (232-L*2/3),(141+V) COLOR 8
  LINE (232-L/2),(141+V) TO (232-L/2),(151+V) COLOR 8
  DRAW "C8L9D19R19U19L9"
ENDPROC
