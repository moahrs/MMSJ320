PROC MAIN
  SCREEN 2

  COLOR 5,1

  FOR I = 1 TO 80
    LINE 139,79 TO RND (1) * 255, RND (1) * 79
  NEXT I

  COLOR 6,1

  FOR I = 79 TO 191 STEP 10
    LINE 139,79 TO 0,I
    LINE 139,79 TO 255, I
  NEXT I

  FOR I=0 TO 255 STEP 20
    LINE 139,79 TO I, 191
  NEXT I

  FOR I = 1 TO 5000
  NEXT I
ENDPROC
