; #endif
; #if OS_ARG_CHK_EN > 0u
; if (pevent == (OS_EVENT *)0) {                         /* Validate 'pevent'                        */
; *perr = OS_ERR_PEVENT_NULL;
; return (pevent);
; }
; #endif
; if (pevent->OSEventType != OS_EVENT_TYPE_MBOX) {       /* Validate event block type                */
       move.l    D2,A0
       move.b    (A0),D0
       cmp.b     #1,D0
       beq.s     OSMboxDel_1
; *perr = OS_ERR_EVENT_TYPE;
       move.l    D3,A0
       move.b    #1,(A0)
; return (pevent);
       move.l    D2,D0
       bra       OSMboxDel_3
OSMboxDel_1:
; }
; if (OSIntNesting > 0u) {                               /* See if called from ISR ...               */
       move.b    _OSIntNesting.L,D0
       cmp.b     #0,D0
       bls.s     OSMboxDel_4
; *perr = OS_ERR_DEL_ISR;                            /* ... can't DELETE from an ISR             */
       move.l    D3,A0
       move.b    #15,(A0)
; return (pevent);
       move.l    D2,D0
       bra       OSMboxDel_3
OSMboxDel_4:
; }
; OS_ENTER_CRITICAL();
       dc.w      16615
       dc.w      124
       dc.w      1792
; if (pevent->OSEventGrp != 0u) {                        /* See if any tasks waiting on mailbox      */
       move.l    D2,A0
       move.b    8(A0),D0
       beq.s     OSMboxDel_6
; tasks_waiting = OS_TRUE;                           /* Yes                                      */
       moveq     #1,D5
       bra.s     OSMboxDel_7
OSMboxDel_6:
; } else {
; tasks_waiting = OS_FALSE;                          /* No                                       */
       clr.b     D5
OSMboxDel_7:
; }
; switch (opt) {
       move.b    15(A6),D0
       and.l     #255,D0
       cmp.l     #1,D0
       beq       OSMboxDel_11
       bhi       OSMboxDel_8
       tst.l     D0
