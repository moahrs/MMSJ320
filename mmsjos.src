       move.b    _OSLockNesting.L,D0
       cmp.b     #0,D0
       bls.s     OSSemPend_6
; *perr = OS_ERR_PEND_LOCKED;                   /* ... can't PEND when locked                    */
       move.l    D2,A0
       move.b    #13,(A0)
