       dc.w      16615
       dc.w      124
       dc.w      1792
; if (prio == OS_PRIO_SELF) {                  /* See if need to get register from current task      */
       move.b    11(A6),D0
       cmp.b     #255,D0
       bne.s     OSTaskRegGet_1
; ptcb = OSTCBCur;
       move.l    _OSTCBCur.L,D2
       bra.s     OSTaskRegGet_2
OSTaskRegGet_1:
