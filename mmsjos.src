       move.l    _OSTmrSemSignal.L,-(A7)
       jsr       _OSSemPost
       addq.w    #4,A7
       move.b    D0,-1(A6)
; return (err);
       move.b    -1(A6),D0
       unlk      A6
       rts
; }
