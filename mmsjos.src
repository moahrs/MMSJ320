       lea       _OSTCBCur.L,A2
       move.l    8(A6),D3
; INT8U  y;
; OSTCBCur->OSTCBEventPtr               = pevent;                 /* Store ptr to ECB in TCB         */
       move.l    (A2),A0
       move.l    D3,28(A0)
; pevent->OSEventTbl[OSTCBCur->OSTCBY] |= OSTCBCur->OSTCBBitX;    /* Put task in waiting list        */
       move.l    D3,A0
       move.l    (A2),A1
       move.b    54(A1),D0
       and.l     #255,D0
       add.l     D0,A0
       move.l    (A2),A1
       move.b    55(A1),D0
       or.b      D0,10(A0)
; pevent->OSEventGrp                   |= OSTCBCur->OSTCBBitY;
       move.l    D3,A0
       move.l    (A2),A1
       move.b    56(A1),D0
       or.b      D0,8(A0)
; y             =  OSTCBCur->OSTCBY;            /* Task no longer ready                              */
       move.l    (A2),A0
       move.b    54(A0),D2
; OSRdyTbl[y]  &= (OS_PRIO)~OSTCBCur->OSTCBBitX;
       and.l     #255,D2
       lea       _OSRdyTbl.L,A0
       move.l    (A2),A1
       move.b    55(A1),D0
       not.b     D0
       and.b     D0,0(A0,D2.L)
; if (OSRdyTbl[y] == 0u) {                      /* Clear event grp bit if this was only task pending */
       and.l     #255,D2
       lea       _OSRdyTbl.L,A0
       move.b    0(A0,D2.L),D0
       bne.s     OS_EventTaskWait_1
; OSRdyGrp &= (OS_PRIO)~OSTCBCur->OSTCBBitY;
       move.l    (A2),A0
       move.b    56(A0),D0
