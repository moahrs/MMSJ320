_spritePointer:
	    ;  Dados para Sprite Ponteiro Mouse 8x8
		dc.b $80,$C0,$E0,$F0,$F8,$FC,$30,$18 ; Seta ponteiro mouse

_spriteHourGlass:
	    ;  Dados para Sprite Ampulheta Mouse 8x8
		dc.b $7F,$32,$1C,$1C,$1C,$1C,$2E,$7F ; Ampulheta

