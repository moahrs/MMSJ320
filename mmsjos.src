       move.l    D3,A0
       move.b    8(A0),D0
       beq.s     OSQPostFront_4
; /* Ready highest priority task waiting on event  */
; (void)OS_EventTaskRdy(pevent, pmsg, OS_STAT_Q, OS_STAT_PEND_OK);
       clr.l     -(A7)
       pea       4
