OS_MemCopy_1:
       move.w    18(A6),D0
       cmp.w     #0,D0
       bls.s     OS_MemCopy_3
; *pdest++ = *psrc++;
       move.l    12(A6),A0
       addq.l    #1,12(A6)
       move.l    8(A6),A1
       addq.l    #1,8(A6)
       move.b    (A0),(A1)
; size--;
       subq.w    #1,18(A6)
       bra       OS_MemCopy_1
OS_MemCopy_3:
       unlk      A6
       rts
; }
; }
