       move.l    2(A0),-4(A6)
; pevent->OSEventPtr = (void *)0;                       /* Clear the mailbox                         */
       move.l    D2,A0
       clr.l     2(A0)
; OS_EXIT_CRITICAL();
       dc.w      18143
; return (pmsg);                                        /* Return the message received (or NULL)     */
       move.l    -4(A6),D0
OSMboxAccept_3:
       move.l    (A7)+,D2
       unlk      A6
       rts
