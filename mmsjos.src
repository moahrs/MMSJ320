; /*
; *********************************************************************************************************
; *                              MAKE TASK READY-TO-RUN, EVENT(s) OCCURRED
; *
; * Description: This function is internal to uC/OS-II and is used to make a task ready-to-run because the
; *              desired event flag bits have been set.
; *
