OS_TaskStat_3:
; }
; OSIdleCtrMax /= 100uL;
       move.l    (A2),-(A7)
       pea       100
       jsr       ULDIV
       move.l    (A7),(A2)
       addq.w    #8,A7
; if (OSIdleCtrMax == 0uL) {
       move.l    (A2),D0
       bne.s     OS_TaskStat_4
; OSCPUUsage = 0u;
       clr.b     _OSCPUUsage.L
; #if OS_TASK_SUSPEND_EN > 0u
; (void)OSTaskSuspend(OS_PRIO_SELF);
       pea       255
       jsr       _OSTaskSuspend
       addq.w    #4,A7
       and.l     #255,D0
