       link      A6,#-8
       movem.l   D2/D3/A2,-(A7)
       lea       _OSQTbl.L,A2
; #if OS_MAX_QS == 1u
; OSQFreeList         = &OSQTbl[0];                /* Only ONE queue!                                */
; OSQFreeList->OSQPtr = (OS_Q *)0;
; #endif
