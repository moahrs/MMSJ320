; OS_CPU_SR     cpu_sr = 0u;
; #endif
; #ifdef OS_SAFETY_CRITICAL
; if (perr == (INT8U *)0) {
; OS_SAFETY_CRITICAL_EXCEPTION();
; return ((OS_FLAGS)0);
; }
; #endif
; #if OS_ARG_CHK_EN > 0u
