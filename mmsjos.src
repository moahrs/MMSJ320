; ptcb                = (OS_TCB *)pnode->OSFlagNodeTCB;
       move.l    D3,A0
       move.l    8(A0),-8(A6)
; ptcb->OSTCBFlagNode = (OS_FLAG_NODE *)0;
       move.l    -8(A6),A0
       clr.l     40(A0)
       movem.l   (A7)+,D2/D3/D4
       unlk      A6
       rts
