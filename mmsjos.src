       link      A6,#0
       movem.l   D2/D3,-(A7)
       move.l    8(A6),D2
; void      *pblk;
; #if OS_CRITICAL_METHOD == 3u                          /* Allocate storage for CPU status register      */
; OS_CPU_SR  cpu_sr = 0u;
; #endif
