; /*
; *********************************************************************************************************
; *                                           SUSPEND A TASK
; *
; * Description: This function is called to suspend a task.  The task can be the calling task if the
; *              priority passed to OSTaskSuspend() is the priority of the calling task or OS_PRIO_SELF.
; *
