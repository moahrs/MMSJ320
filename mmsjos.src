       cmp.w     #0,D0
       bls.s     OSSemPend_8
; pevent->OSEventCnt--;                         /* ... decrement semaphore only if positive.     */
       move.l    D3,D0
       addq.l    #6,D0
       move.l    D0,A0
       subq.w    #1,(A0)
; OS_EXIT_CRITICAL();
       dc.w      18143
; *perr = OS_ERR_NONE;
       move.l    D2,A0
       clr.b     (A0)
; return;
       bra       OSSemPend_3
