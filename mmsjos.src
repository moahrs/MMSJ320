; break;
       bra       OSMboxDel_9
OSMboxDel_11:
; case OS_DEL_ALWAYS:                                /* Always delete the mailbox                */
; while (pevent->OSEventGrp != 0u) {            /* Ready ALL tasks waiting for mailbox      */
OSMboxDel_15:
       move.l    D2,A0
       move.b    8(A0),D0
       beq.s     OSMboxDel_17
; (void)OS_EventTaskRdy(pevent, (void *)0, OS_STAT_MBOX, OS_STAT_PEND_ABORT);
       pea       2
       pea       2
       clr.l     -(A7)
