; (void)OS_EventTaskRdy(pevent, (void *)0, OS_STAT_SEM, OS_STAT_PEND_ABORT);
       pea       2
       pea       1
       clr.l     -(A7)
       move.l    D2,-(A7)
       jsr       _OS_EventTaskRdy
       add.w     #16,A7
       and.l     #255,D0
; nbr_tasks++;
       addq.b    #1,D3
; break;
OSSemPendAbort_7:
