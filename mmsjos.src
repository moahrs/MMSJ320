            dc.l _fsCloseFile
            dc.l _fsInfoFile
            dc.l _fsFree
            dc.l _fsReadFile
            dc.l _fsWriteFile
            dc.l _fsDelFile
            dc.l _fsRenameFile
            dc.l _loadFile
            dc.l _fsMakeDir
            dc.l _fsChangeDir
            dc.l _fsRemoveDir
            dc.l _OSTimeDlyHMSM
            dc.l _fsFindInDir
            dc.l _fsMalloc
            dc.l _fsFindNextCluster
            dc.l _fsFindClusterFree

__exit:                                ; exit() functions
_exit:
           lea         __stack,A7      ; reset stack
           trap        #15
           dc.w        0               ; IDE68K system call 0 -> EXIT (no return)
           jsr         _main           ; when re-started after exit() call

_uCOSII_TICK:
           dc.l _OSTickISR

