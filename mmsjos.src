; for (;;) {
OS_TaskIdle_1:
; OS_ENTER_CRITICAL();
       dc.w      16615
       dc.w      124
       dc.w      1792
; OSIdleCtr++;
       addq.l    #1,_OSIdleCtr.L
; OS_EXIT_CRITICAL();
       dc.w      18143
