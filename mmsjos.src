; OS_EXIT_CRITICAL();
       dc.w      18143
; return (OS_ERR_NONE);
       clr.b     D0
OSQPostOpt_3:
       movem.l   (A7)+,D2/D3/D4/D5
       unlk      A6
       rts
; }
