00803936  10BC 0001 11432          move.b    #1,(A0)
                    11433   ; return (pevent);
0080393A  2002      11434          move.l    D2,D0
0080393C  6000 00EE 11435          bra       OSSemDel_3
                    11436   OSSemDel_1:
                    11437   ; }
                    11438   ; if (OSIntNesting > 0u) {                               /* See if called from ISR ...               */
00803940  1039 0060 11439          move.b    _OSIntNesting.L,D0
00803944  2636      
