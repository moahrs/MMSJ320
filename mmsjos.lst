00804938  00FF      
0080493A  41F9 0060 14559          lea       _OSRdyTbl.L,A0
0080493E  2640      
00804940  2252      14560          move.l    (A2),A1
00804942  1029 0037 14561          move.b    55(A1),D0
00804946  4600      14562          not.b     D0
00804948  C130 2800 14563          and.b     D0,0(A0,D2.L)
                    14564   ; if (OSRdyTbl[y] == 0u) {
0080494C  C4BC 0000 14565          and.l     #255,D2
00804950  00FF      
00804952  41F9 0060 14566          lea       _OSRdyTbl.L,A0
00804956  2640      
00804958  1030 2800 14567          move.b    0(A0,D2.L),D0
0080495C  660E      14568          bne.s     OSTimeDly_8
                    14569   ; OSRdyGrp &= (OS_PRIO)~OSTCBCur->OSTCBBitY;
