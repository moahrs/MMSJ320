00804966  C139 0060 14573          and.b     D0,_OSRdyGrp.L
0080496A  263E      
                    14574   OSTimeDly_8:
                    14575   ; }
                    14576   ; OSTCBCur->OSTCBDly = ticks;              /* Load ticks in TCB                                  */
