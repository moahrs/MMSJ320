                    1103   ; /*
                    1104   ; *********************************************************************************************************
                    1105   ; *                                       PEND ON MULTIPLE EVENTS
                    1106   ; *
                    1107   ; * Description: This function waits for multiple events.  If multiple events are ready at the start of the
                    1108   ; *              pend call, then all available events are returned as ready.  If the task must pend on the
                    1109   ; *              multiple events, then only the first posted or aborted event is returned as ready.
                    1110   ; *
                    1111   ; * Arguments  : pevents_pend  is a pointer to a NULL-terminated array of event control blocks to wait for.
                    1112   ; *
                    1113   ; *              pevents_rdy   is a pointer to an array to return which event control blocks are available
                    1114   ; *                            or ready.  The size of the array MUST be greater than or equal to the size
                    1115   ; *                            of the 'pevents_pend' array, including terminating NULL.
                    1116   ; *
                    1117   ; *              pmsgs_rdy     is a pointer to an array to return messages from any available message-type
                    1118   ; *                            events.  The size of the array MUST be greater than or equal to the size of
                    1119   ; *                            the 'pevents_pend' array, excluding the terminating NULL.  Since NULL
                    1120   ; *                            messages are valid messages, this array cannot be NULL-terminated.  Instead,
                    1121   ; *                            every available message-type event returns its messages in the 'pmsgs_rdy'
                    1122   ; *                            array at the same index as the event is returned in the 'pevents_rdy' array.
                    1123   ; *                            All other 'pmsgs_rdy' array indices are filled with NULL messages.
                    1124   ; *
                    1125   ; *              timeout       is an optional timeout period (in clock ticks).  If non-zero, your task will
                    1126   ; *                            wait for the resources up to the amount of time specified by this argument.
                    1127   ; *                            If you specify 0, however, your task will wait forever for the specified
                    1128   ; *                            events or, until the resources becomes available (or the events occur).
                    1129   ; *
                    1130   ; *              perr          is a pointer to where an error message will be deposited.  Possible error
                    1131   ; *                            messages are:
                    1132   ; *
                    1133   ; *                            OS_ERR_NONE         The call was successful and your task owns the resources
                    1134   ; *                                                or, the events you are waiting for occurred; check the
                    1135   ; *                                                'pevents_rdy' array for which events are available.
                    1136   ; *                            OS_ERR_PEND_ABORT   The wait on the events was aborted; check the
                    1137   ; *                                                'pevents_rdy' array for which events were aborted.
                    1138   ; *                            OS_ERR_TIMEOUT      The events were not received within the specified
                    1139   ; *                                                'timeout'.
                    1140   ; *                            OS_ERR_PEVENT_NULL  If 'pevents_pend', 'pevents_rdy', or 'pmsgs_rdy' is a
                    1141   ; *                                                NULL pointer.
                    1142   ; *                            OS_ERR_EVENT_TYPE   If you didn't pass a pointer to an array of semaphores,
                    1143   ; *                                                mailboxes, and/or queues.
                    1144   ; *                            OS_ERR_PEND_ISR     If you called this function from an ISR and the result
                    1145   ; *                                                would lead to a suspension.
                    1146   ; *                            OS_ERR_PEND_LOCKED  If you called this function when the scheduler is locked.
                    1147   ; *
                    1148   ; * Returns    : >  0          the number of events returned as ready or aborted.
                    1149   ; *              == 0          if no events are returned as ready because of timeout or upon error.
                    1150   ; *
                    1151   ; * Notes      : 1) a. Validate 'pevents_pend' array as valid OS_EVENTs :
                    1152   ; *
                    1153   ; *                        semaphores, mailboxes, queues
                    1154   ; *
                    1155   ; *                 b. Return ALL available events and messages, if any
                    1156   ; *
                    1157   ; *                 c. Add    current task priority as pending to   each events's wait list
                    1158   ; *                      Performed in OS_EventTaskWaitMulti()
                    1159   ; *
                    1160   ; *                 d. Wait on any of multiple events
                    1161   ; *
                    1162   ; *                 e. Remove current task priority as pending from each events's wait list
                    1163   ; *                      Performed in OS_EventTaskRdy(), if events posted or aborted
                    1164   ; *
                    1165   ; *                 f. Return any event posted or aborted, if any
                    1166   ; *                      else
                    1167   ; *                    Return timeout
                    1168   ; *
                    1169   ; *              2) 'pevents_rdy' initialized to NULL PRIOR to all other validation or function handling in
                    1170   ; *                 case of any error(s).
                    1171   ; *********************************************************************************************************
                    1172   ; */
                    1173   ; /*$PAGE*/
                    1174   ; #if ((OS_EVENT_EN) && (OS_EVENT_MULTI_EN > 0u))
                    1175   ; INT16U  OSEventPendMulti (OS_EVENT  **pevents_pend,
                    1176   ; OS_EVENT  **pevents_rdy,
                    1177   ; void      **pmsgs_rdy,
                    1178   ; INT32U      timeout,
                    1179   ; INT8U      *perr)
                    1180   ; {
                    1181   _OSEventPendMulti:
00800472  4E56 FFFC 1182          link      A6,#-4
