00804900  0C00 0000 14532          cmp.b     #0,D0
00804904  6304      14533          bls.s     OSTimeDly_1
                    14534   ; return;
00804906  6000 0074 14535          bra       OSTimeDly_6
                    14536   OSTimeDly_1:
                    14537   ; }
                    14538   ; if (OSLockNesting > 0u) {                    /* See if called with scheduler locked                */
0080490A  1039 0060 14539          move.b    _OSLockNesting.L,D0
0080490E  2638      
00804910  0C00 0000 14540          cmp.b     #0,D0
00804914  6304      14541          bls.s     OSTimeDly_4
                    14542   ; return;
00804916  6000 0064 14543          bra       OSTimeDly_6
                    14544   OSTimeDly_4:
                    14545   ; }
                    14546   ; if (ticks > 0u) {                            /* 0 means no delay!                                  */
0080491A  202E 0008 14547          move.l    8(A6),D0
0080491E  0C80 0000 14548          cmp.l     #0,D0
00804922  0000      
00804924  6300 0056 14549          bls       OSTimeDly_6
                    14550   ; OS_ENTER_CRITICAL();
