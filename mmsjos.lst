                    12728   ; /*
                    12729   ; *********************************************************************************************************
                    12730   ; *                                  CREATE A TASK (Extended Version)
                    12731   ; *
                    12732   ; * Description: This function is used to have uC/OS-II manage the execution of a task.  Tasks can either
                    12733   ; *              be created prior to the start of multitasking or by a running task.  A task cannot be
                    12734   ; *              created by an ISR.  This function is similar to OSTaskCreate() except that it allows
                    12735   ; *              additional information about a task to be specified.
                    12736   ; *
                    12737   ; * Arguments  : task      is a pointer to the task's code
                    12738   ; *
                    12739   ; *              p_arg     is a pointer to an optional data area which can be used to pass parameters to
                    12740   ; *                        the task when the task first executes.  Where the task is concerned it thinks
                    12741   ; *                        it was invoked and passed the argument 'p_arg' as follows:
                    12742   ; *
                    12743   ; *                            void Task (void *p_arg)
                    12744   ; *                            {
                    12745   ; *                                for (;;) {
                    12746   ; *                                    Task code;
                    12747   ; *                                }
                    12748   ; *                            }
                    12749   ; *
                    12750   ; *              ptos      is a pointer to the task's top of stack.  If the configuration constant
                    12751   ; *                        OS_STK_GROWTH is set to 1, the stack is assumed to grow downward (i.e. from high
                    12752   ; *                        memory to low memory).  'ptos' will thus point to the highest (valid) memory
                    12753   ; *                        location of the stack.  If OS_STK_GROWTH is set to 0, 'ptos' will point to the
                    12754   ; *                        lowest memory location of the stack and the stack will grow with increasing
                    12755   ; *                        memory locations.  'ptos' MUST point to a valid 'free' data item.
                    12756   ; *
                    12757   ; *              prio      is the task's priority.  A unique priority MUST be assigned to each task and the
                    12758   ; *                        lower the number, the higher the priority.
                    12759   ; *
                    12760   ; *              id        is the task's ID (0..65535)
                    12761   ; *
                    12762   ; *              pbos      is a pointer to the task's bottom of stack.  If the configuration constant
                    12763   ; *                        OS_STK_GROWTH is set to 1, the stack is assumed to grow downward (i.e. from high
                    12764   ; *                        memory to low memory).  'pbos' will thus point to the LOWEST (valid) memory
                    12765   ; *                        location of the stack.  If OS_STK_GROWTH is set to 0, 'pbos' will point to the
                    12766   ; *                        HIGHEST memory location of the stack and the stack will grow with increasing
                    12767   ; *                        memory locations.  'pbos' MUST point to a valid 'free' data item.
                    12768   ; *
                    12769   ; *              stk_size  is the size of the stack in number of elements.  If OS_STK is set to INT8U,
                    12770   ; *                        'stk_size' corresponds to the number of bytes available.  If OS_STK is set to
                    12771   ; *                        INT16U, 'stk_size' contains the number of 16-bit entries available.  Finally, if
                    12772   ; *                        OS_STK is set to INT32U, 'stk_size' contains the number of 32-bit entries
                    12773   ; *                        available on the stack.
                    12774   ; *
                    12775   ; *              pext      is a pointer to a user supplied memory location which is used as a TCB extension.
                    12776   ; *                        For example, this user memory can hold the contents of floating-point registers
                    12777   ; *                        during a context switch, the time each task takes to execute, the number of times
                    12778   ; *                        the task has been switched-in, etc.
                    12779   ; *
                    12780   ; *              opt       contains additional information (or options) about the behavior of the task.  The
                    12781   ; *                        LOWER 8-bits are reserved by uC/OS-II while the upper 8 bits can be application
                    12782   ; *                        specific.  See OS_TASK_OPT_??? in uCOS-II.H.  Current choices are:
                    12783   ; *
                    12784   ; *                        OS_TASK_OPT_STK_CHK      Stack checking to be allowed for the task
                    12785   ; *                        OS_TASK_OPT_STK_CLR      Clear the stack when the task is created
                    12786   ; *                        OS_TASK_OPT_SAVE_FP      If the CPU has floating-point registers, save them
                    12787   ; *                                                 during a context switch.
                    12788   ; *
                    12789   ; * Returns    : OS_ERR_NONE                      if the function was successful.
                    12790   ; *              OS_ERR_PRIO_EXIST                if the task priority already exist
                    12791   ; *                                               (each task MUST have a unique priority).
                    12792   ; *              OS_ERR_PRIO_INVALID              if the priority you specify is higher that the maximum
                    12793   ; *                                               allowed (i.e. > OS_LOWEST_PRIO)
                    12794   ; *              OS_ERR_TASK_CREATE_ISR           if you tried to create a task from an ISR.
                    12795   ; *              OS_ERR_ILLEGAL_CREATE_RUN_TIME   if you tried to create a task after safety critical
                    12796   ; *                                               operation started.
                    12797   ; *********************************************************************************************************
                    12798   ; */
                    12799   ; /*$PAGE*/
                    12800   ; #if OS_TASK_CREATE_EXT_EN > 0u
