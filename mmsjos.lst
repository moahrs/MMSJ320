                    3565   ; /*
                    3566   ; *********************************************************************************************************
                    3567   ; *                                           STATISTICS TASK
                    3568   ; *
                    3569   ; * Description: This task is internal to uC/OS-II and is used to compute some statistics about the
                    3570   ; *              multitasking environment.  Specifically, OS_TaskStat() computes the CPU usage.
                    3571   ; *              CPU usage is determined by:
                    3572   ; *
                    3573   ; *                                          OSIdleCtr
                    3574   ; *                 OSCPUUsage = 100 * (1 - ------------)     (units are in %)
                    3575   ; *                                         OSIdleCtrMax
                    3576   ; *
                    3577   ; * Arguments  : parg     this pointer is not used at this time.
                    3578   ; *
                    3579   ; * Returns    : none
                    3580   ; *
                    3581   ; * Notes      : 1) This task runs at a priority level higher than the idle task.  In fact, it runs at the
                    3582   ; *                 next higher priority, OS_TASK_IDLE_PRIO-1.
                    3583   ; *              2) You can disable this task by setting the configuration #define OS_TASK_STAT_EN to 0.
                    3584   ; *              3) You MUST have at least a delay of 2/10 seconds to allow for the system to establish the
                    3585   ; *                 maximum value for the idle counter.
                    3586   ; *********************************************************************************************************
                    3587   ; */
                    3588   ; #if OS_TASK_STAT_EN > 0u
