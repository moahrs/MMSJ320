                     671   ; *
                     672   ; * Arguments  : none
                     673   ; *
                     674   ; * Note(s)    : 1) Interrupts are disabled during this call.
                     675   ; *              2) It is assumed that the global pointer 'OSTCBHighRdy' points to the TCB of the task that
                     676   ; *                 will be 'switched in' (i.e. the highest priority task) and, 'OSTCBCur' points to the
                     677   ; *                 task being switched out (i.e. the preempted task).
                     678   ; *********************************************************************************************************
                     679   ; */
                     680   ; void OSTaskSwHook(void)
                     681   ; {
                     682   _OSTaskSwHook:
00800334  4E75       683          rts
                     684   ; }
