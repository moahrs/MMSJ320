                    14590   ; /*
                    14591   ; *********************************************************************************************************
                    14592   ; *                                    DELAY TASK FOR SPECIFIED TIME
                    14593   ; *
                    14594   ; * Description: This function is called to delay execution of the currently running task until some time
                    14595   ; *              expires.  This call allows you to specify the delay time in HOURS, MINUTES, SECONDS and
                    14596   ; *              MILLISECONDS instead of ticks.
                    14597   ; *
                    14598   ; * Arguments  : hours     specifies the number of hours that the task will be delayed (max. is 255)
                    14599   ; *              minutes   specifies the number of minutes (max. 59)
                    14600   ; *              seconds   specifies the number of seconds (max. 59)
                    14601   ; *              ms        specifies the number of milliseconds (max. 999)
                    14602   ; *
                    14603   ; * Returns    : OS_ERR_NONE
                    14604   ; *              OS_ERR_TIME_INVALID_MINUTES
                    14605   ; *              OS_ERR_TIME_INVALID_SECONDS
                    14606   ; *              OS_ERR_TIME_INVALID_MS
                    14607   ; *              OS_ERR_TIME_ZERO_DLY
