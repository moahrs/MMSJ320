0080395A  007C      11452          dc.w      124
0080395C  0700      11453          dc.w      1792
                    11454   ; if (pevent->OSEventGrp != 0u) {                        /* See if any tasks waiting on semaphore    */
0080395E  2042      11455          move.l    D2,A0
00803960  1028 0008 11456          move.b    8(A0),D0
00803964  6704      11457          beq.s     OSSemDel_6
                    11458   ; tasks_waiting = OS_TRUE;                           /* Yes                                      */
00803966  7A01      11459          moveq     #1,D5
00803968  6002      11460          bra.s     OSSemDel_7
                    11461   OSSemDel_6:
                    11462   ; } else {
                    11463   ; tasks_waiting = OS_FALSE;                          /* No                                       */
0080396A  4205      11464          clr.b     D5
                    11465   OSSemDel_7:
                    11466   ; }
                    11467   ; switch (opt) {
0080396C  102E 000F 11468          move.b    15(A6),D0
