                     377   ; /*$PAGE*/
                     378   ; /*
                     379   ; *********************************************************************************************************
                     380   ; *                                        INITIALIZE A TASK'S STACK
                     381   ; *
                     382   ; * Description: This function is called by either OSTaskCreate() or OSTaskCreateExt() to initialize the
                     383   ; *              stack frame of the task being created.  This function is highly processor specific.
                     384   ; *
                     385   ; * Arguments  : task          is a pointer to the task code
                     386   ; *
                     387   ; *              pdata         is a pointer to a user supplied data area that will be passed to the task
                     388   ; *                            when the task first executes.
                     389   ; *
                     390   ; *              ptos          is a pointer to the top of stack.  It is assumed that 'ptos' points to
                     391   ; *                            a 'free' entry on the task stack.  If OS_STK_GROWTH is set to 1 then
                     392   ; *                            'ptos' will contain the HIGHEST valid address of the stack.  Similarly, if
                     393   ; *                            OS_STK_GROWTH is set to 0, the 'ptos' will contains the LOWEST valid address
                     394   ; *                            of the stack.
                     395   ; *
                     396   ; *              opt           specifies options that can be used to alter the behavior of OSTaskStkInit().
                     397   ; *                            (see uCOS_II.H for OS_TASK_OPT_???).
                     398   ; *
                     399   ; * Returns    : Always returns the location of the new top-of-stack' once the processor registers have
                     400   ; *              been placed on the stack in the proper order.
                     401   ; *
                     402   ; * Note(s)    : 1) The initial value of the Status Register (SR) is OS_INITIAL_SR sets the 683xx processor
                     403   ; *                 to run in SUPERVISOR mode.  It is assumed that all uC/OS-II tasks run in supervisor
                     404   ; *                 mode.
                     405   ; *              2) You can pass the above options in the 'opt' argument.  You MUST only use the upper
                     406   ; *                 8 bits of 'opt' because the lower bits are reserved by uC/OS-II.  If you make changes
                     407   ; *                 to the code below, you will need to ensure that it doesn't affect the behaviour of
                     408   ; *                 OSTaskIdle() and OSTaskStat().
                     409   ; *              3) Registers are initialized to make them easy to differentiate with a debugger.
                     410   ; *********************************************************************************************************
                     411   ; */
                     412   ; OS_STK *OSTaskStkInit(void (*task)(void *pd), void *pdata, OS_STK *ptos, INT16U opt)
                     413   ; {
                     414   _OSTaskStkInit:
