00803918  48E7 3C20 11404          movem.l   D2/D3/D4/D5/A2,-(A7)
0080391C  242E 0008 11405          move.l    8(A6),D2
00803920  262E 0010 11406          move.l    16(A6),D3
00803924  45F9 0060 11407          lea       _OSEventFreeList.L,A2
00803928  240A      
                    11408   ; BOOLEAN    tasks_waiting;
                    11409   ; OS_EVENT  *pevent_return;
                    11410   ; #if OS_CRITICAL_METHOD == 3u                               /* Allocate storage for CPU status register */
                    11411   ; OS_CPU_SR  cpu_sr = 0u;
                    11412   ; #endif
                    11413   ; #ifdef OS_SAFETY_CRITICAL
                    11414   ; if (perr == (INT8U *)0) {
                    11415   ; OS_SAFETY_CRITICAL_EXCEPTION();
                    11416   ; return ((OS_EVENT *)0);
                    11417   ; }
                    11418   ; #endif
                    11419   ; #if OS_ARG_CHK_EN > 0u
                    11420   ; if (pevent == (OS_EVENT *)0) {                         /* Validate 'pevent'                        */
                    11421   ; *perr = OS_ERR_PEVENT_NULL;
                    11422   ; return (pevent);
                    11423   ; }
                    11424   ; #endif
                    11425   ; if (pevent->OSEventType != OS_EVENT_TYPE_SEM) {        /* Validate event block type                */
0080392A  2042      11426          move.l    D2,A0
0080392C  1010      11427          move.b    (A0),D0
0080392E  0C00 0003 11428          cmp.b     #3,D0
00803932  670C      11429          beq.s     OSSemDel_1
                    11430   ; *perr = OS_ERR_EVENT_TYPE;
