                    9814   ; /*
                    9815   ; *********************************************************************************************************
                    9816   ; *                                       DELETE A MESSAGE QUEUE
                    9817   ; *
                    9818   ; * Description: This function deletes a message queue and readies all tasks pending on the queue.
                    9819   ; *
                    9820   ; * Arguments  : pevent        is a pointer to the event control block associated with the desired
                    9821   ; *                            queue.
                    9822   ; *
                    9823   ; *              opt           determines delete options as follows:
                    9824   ; *                            opt == OS_DEL_NO_PEND   Delete the queue ONLY if no task pending
                    9825   ; *                            opt == OS_DEL_ALWAYS    Deletes the queue even if tasks are waiting.
                    9826   ; *                                                    In this case, all the tasks pending will be readied.
                    9827   ; *
                    9828   ; *              perr          is a pointer to an error code that can contain one of the following values:
                    9829   ; *                            OS_ERR_NONE             The call was successful and the queue was deleted
                    9830   ; *                            OS_ERR_DEL_ISR          If you tried to delete the queue from an ISR
                    9831   ; *                            OS_ERR_INVALID_OPT      An invalid option was specified
                    9832   ; *                            OS_ERR_TASK_WAITING     One or more tasks were waiting on the queue
                    9833   ; *                            OS_ERR_EVENT_TYPE       If you didn't pass a pointer to a queue
                    9834   ; *                            OS_ERR_PEVENT_NULL      If 'pevent' is a NULL pointer.
                    9835   ; *
                    9836   ; * Returns    : pevent        upon error
                    9837   ; *              (OS_EVENT *)0 if the queue was successfully deleted.
                    9838   ; *
                    9839   ; * Note(s)    : 1) This function must be used with care.  Tasks that would normally expect the presence of
                    9840   ; *                 the queue MUST check the return code of OSQPend().
                    9841   ; *              2) OSQAccept() callers will not know that the intended queue has been deleted unless
                    9842   ; *                 they check 'pevent' to see that it's a NULL pointer.
                    9843   ; *              3) This call can potentially disable interrupts for a long time.  The interrupt disable
                    9844   ; *                 time is directly proportional to the number of tasks waiting on the queue.
                    9845   ; *              4) Because ALL tasks pending on the queue will be readied, you MUST be careful in
                    9846   ; *                 applications where the queue is used for mutual exclusion because the resource(s)
                    9847   ; *                 will no longer be guarded by the queue.
                    9848   ; *              5) If the storage for the message queue was allocated dynamically (i.e. using a malloc()
                    9849   ; *                 type call) then your application MUST release the memory storage by call the counterpart
                    9850   ; *                 call of the dynamic allocation scheme used.  If the queue storage was created statically
                    9851   ; *                 then, the storage can be reused.
                    9852   ; *              6) All tasks that were waiting for the queue will be readied and returned an 
                    9853   ; *                 OS_ERR_PEND_ABORT if OSQDel() was called with OS_DEL_ALWAYS
                    9854   ; *********************************************************************************************************
                    9855   ; */
                    9856   ; #if OS_Q_DEL_EN > 0u
                    9857   ; OS_EVENT  *OSQDel (OS_EVENT  *pevent,
                    9858   ; INT8U      opt,
                    9859   ; INT8U     *perr)
                    9860   ; {
                    9861   _OSQDel:
