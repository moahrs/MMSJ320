00802A3C  47F9 0060 8739          lea       _OSRdyTbl.L,A3
00802A40  2640      
                    8740   ; INT8U      pcp;                                        /* Priority Ceiling Priority (PCP)          */
                    8741   ; INT8U      mprio;                                      /* Mutex owner priority                     */
                    8742   ; BOOLEAN    rdy;                                        /* Flag indicating task was ready           */
                    8743   ; OS_TCB    *ptcb;
                    8744   ; OS_EVENT  *pevent2;
                    8745   ; INT8U      y;
                    8746   ; #if OS_CRITICAL_METHOD == 3u                               /* Allocate storage for CPU status register */
                    8747   ; OS_CPU_SR  cpu_sr = 0u;
                    8748   ; #endif
                    8749   ; #ifdef OS_SAFETY_CRITICAL
                    8750   ; if (perr == (INT8U *)0) {
                    8751   ; OS_SAFETY_CRITICAL_EXCEPTION();
                    8752   ; return;
                    8753   ; }
