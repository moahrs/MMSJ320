                      89   ;********************************************************************************************************
                      90   ;                               START HIGHEST PRIORITY TASK READY-TO-RUN
                      91   ;
                      92   ; Description : This function is called by OSStart() to start the highest priority task that was created
                      93   ;               by your application before calling OSStart().
                      94   ;
                      95   ; Arguments   : none
                      96   ;
                      97   ; Note(s)     : 1) The stack frame is assumed to look as follows:
                      98   ;
                      99   ;                  OSTCBHighRdy->OSTCBStkPtr +  0  ---->  D0    (H)        Low Memory
                     100   ;                                            +  2         D0    (L)
                     101   ;                                            +  4         D1    (H)
                     102   ;                                            +  6         D1    (L)
                     103   ;                                            +  8         D2    (H)
                     104   ;                                            + 10         D2    (L)
                     105   ;                                            + 12         D3    (H)
                     106   ;                                            + 14         D3    (L)
                     107   ;                                            + 16         D4    (H)
                     108   ;                                            + 18         D4    (L)
                     109   ;                                            + 20         D5    (H)
                     110   ;                                            + 22         D5    (L)
                     111   ;                                            + 24         D6    (H)
                     112   ;                                            + 26         D6    (L)
                     113   ;                                            + 28         D7    (H)
                     114   ;                                            + 30         D7    (L)
                     115   ;                                            + 32         A0    (H)
                     116   ;                                            + 34         A0    (L)
                     117   ;                                            + 36         A1    (H)
                     118   ;                                            + 38         A1    (L)
                     119   ;                                            + 40         A2    (H)
                     120   ;                                            + 42         A2    (L)
                     121   ;                                            + 44         A3    (H)
                     122   ;                                            + 46         A3    (L)
                     123   ;                                            + 48         A4    (H)
                     124   ;                                            + 50         A4    (L)
                     125   ;                                            + 52         A5    (H)
                     126   ;                                            + 54         A5    (L)
                     127   ;                                            + 56         A6    (H)
                     128   ;                                            + 58         A6    (L)
                     129   ;                                            + 60         OS_INITIAL_SR
                     130   ;                                            + 62         task  (H)
                     131   ;                                            + 64         task  (L)
                     132   ;                                            + 66         task  (H)
                     133   ;                                            + 68         task  (L)
                     134   ;                                            + 70         pdata (H)
                     135   ;                                            + 72         pdata (L)        High Memory
                     136   ;
                     137   ;               2) OSStartHighRdy() MUST:
                     138   ;                      a) Call OSTaskSwHook() then,
                     139   ;                      b) Set OSRunning to TRUE,
                     140   ;                      c) Switch to the highest priority task.
                     141   ;********************************************************************************************************
                     142   
                     143   
                     144   _OSStartHighRdy:
008000AA  4EB9 0080  145           JSR       _OSTaskSwHook            ; Invoke user defined context switch hook
008000AE  0334      
008000B0  5239 0060  146           ADDQ.B    #1,_OSRunning            ; Indicate that we are multitasking
008000B4  2648      
008000B6  2079 0060  147           MOVE.L    _OSTCBHighRdy,A0         ; Point to TCB of highest priority task ready to run
008000BA  2758      
008000BC  2E50       148           MOVE.L    (A0),A7                  ; Get the stack pointer of the task to resume
008000BE  4CDF 7FFF  149           MOVEM.L   (A7)+,A0-A6/D0-D7        ; Restore the CPU registers
008000C2  4E73       150           RTE                                ; Run task
                     151   
                     152   ;********************************************************************************************************
                     153   ;                                       TASK LEVEL CONTEXT SWITCH
                     154   ;
                     155   ; Description : This function is called when a task makes a higher priority task ready-to-run.
                     156   ;
                     157   ; Arguments   : none
                     158   ;
                     159   ; Note(s)     : 1) Upon entry,
                     160   ;                  OSTCBCur     points to the OS_TCB of the task to suspend
                     161   ;                  OSTCBHighRdy points to the OS_TCB of the task to resume
                     162   ;
                     163   ;               2) The stack frame of the task to suspend looks as follows (the registers for
                     164   ;                  task to suspend need to be saved):
                     165   ;
                     166   ;                                         SP +  0  ---->  SR                   Low Memory
                     167   ;                                            +  2         PC of task  (H)
                     168   ;                                            +  4         PC of task  (L)      High Memory
                     169   ;
                     170   ;               3) The stack frame of the task to resume looks as follows:
                     171   ;
                     172   ;                  OSTCBHighRdy->OSTCBStkPtr +  0  ---->  D0    (H)           Low Memory
                     173   ;                                            +  2         D0    (L)
                     174   ;                                            +  4         D1    (H)
                     175   ;                                            +  6         D1    (L)
                     176   ;                                            +  8         D2    (H)
                     177   ;                                            + 10         D2    (L)
                     178   ;                                            + 12         D3    (H)
                     179   ;                                            + 14         D3    (L)
                     180   ;                                            + 16         D4    (H)
                     181   ;                                            + 18         D4    (L)
                     182   ;                                            + 20         D5    (H)
                     183   ;                                            + 22         D5    (L)
                     184   ;                                            + 24         D6    (H)
                     185   ;                                            + 26         D6    (L)
                     186   ;                                            + 28         D7    (H)
                     187   ;                                            + 30         D7    (L)
                     188   ;                                            + 32         A0    (H)
                     189   ;                                            + 34         A0    (L)
                     190   ;                                            + 36         A1    (H)
                     191   ;                                            + 38         A1    (L)
                     192   ;                                            + 40         A2    (H)
                     193   ;                                            + 42         A2    (L)
                     194   ;                                            + 44         A3    (H)
                     195   ;                                            + 46         A3    (L)
                     196   ;                                            + 48         A4    (H)
                     197   ;                                            + 50         A4    (L)
                     198   ;                                            + 52         A5    (H)
                     199   ;                                            + 54         A5    (L)
                     200   ;                                            + 56         A6    (H)
                     201   ;                                            + 58         A6    (L)
                     202   ;                                            + 60         OS_INITIAL_SR       (See OS_CPU.H)
                     203   ;                                            + 62         PC of task  (H)
                     204   ;                                            + 64         PC of task  (L)     High Memory
                     205   ;********************************************************************************************************
                     206   
                     207   _OSCtxSw:
008000C4  48E7 FFFE  208           MOVEM.L   A0-A6/D0-D7,-(A7)              ; Save the registers of the current task
008000C8  2079 0060  209           MOVE.L    _OSTCBCur,A0                   ; Save the stack pointer in the suspended task TCB
008000CC  2750      
008000CE  208F       210           MOVE.L    A7,(A0)
008000D0  4EB9 0080  211           JSR       _OSTaskSwHook                  ; Invoke user defined context switch hook
008000D4  0334      
008000D6  2079 0060  212           MOVE.L    _OSTCBHighRdy,A0               ; OSTCBCur  = OSTCBHighRdy
008000DA  2758      
008000DC  23C8 0060  213           MOVE.L    A0,_OSTCBCur
008000E0  2750      
008000E2  2E50       214           MOVE.L    (A0),A7                        ; Get the stack pointer of the task to resume
008000E4  13F9 0060  215           MOVE.B    _OSPrioHighRdy,_OSPrioCur      ; OSPrioCur = OSPrioHighRdy
008000E8  263C 0060 
008000EC  263A      
008000EE  4CDF 7FFF  216           MOVEM.L   (A7)+,A0-A6/D0-D7              ; Restore the CPU registers
008000F2  4E73       217           RTE                                      ; Run task
                     218   
                     219   ;********************************************************************************************************
                     220   ;                                      INTERRUPT LEVEL CONTEXT SWITCH
                     221   ;
                     222   ; Description : This function is called from OSIntExit() in OS_CORE.C
                     223   ;               Provided for backward compatibility. The ISR MUST NOT call OSIntExit(), but should jump
                     224   ;               to OSIntExit68K().
                     225   ;********************************************************************************************************
                     226   
                     227   _OSIntCtxSw:
008000F4  DFFC 0000  228           ADDA.L    #10,A7                         ; Adjust the stack
008000F8  000A      
008000FA  2279 0060  229           MOVE.L    _OSTCBCur,A1                   ; Save the stack pointer in the suspended task TCB
008000FE  2750      
00800100  228F       230           MOVE.L    A7,(A1)
00800102  4EB9 0080  231           JSR       _OSTaskSwHook                  ; Invoke user defined context switch hook
00800106  0334      
00800108  2279 0060  232           MOVE.L    _OSTCBHighRdy,A1               ; OSTCBCur  = OSTCBHighRdy
0080010C  2758      
0080010E  23C9 0060  233           MOVE.L    A1,_OSTCBCur
00800112  2750      
00800114  2E51       234           MOVE.L    (A1),A7                        ; Get the stack pointer of the task to resume
00800116  13F9 0060  235           MOVE.B    _OSPrioHighRdy,_OSPrioCur      ; OSPrioCur = OSPrioHighRdy
0080011A  263C 0060 
0080011E  263A      
00800120  4CDF 7FFF  236           MOVEM.L   (A7)+,A0-A6/D0-D7              ; Restore the CPU registers
00800124  4E73       237           RTE                                      ; Run task
                     238   
                     239   ;********************************************************************************************************
                     240   ;                           INTERRUPT EXIT FUNCTION (68K specific)
                     241   ;
                     242   ; Description : ISR's (written in Assembly) must directly JUMP to OSIntExit68K
                     243   ;
                     244   ;
                     245   ; Notes       : You must NOT use call OSIntExit() to exit an ISR with the 68K, but jump to OSIntExit68K().
                     246   ;
                     247   ; Stack frame upon entry:
                     248   ;
                     249   ;                  SP +  0  ---->  D0    (H)
                     250   ;                     +  2         D0    (L)
                     251   ;                     +  4         D1    (H)
                     252   ;                     +  6         D1    (L)
                     253   ;                     +  8         D2    (H)
                     254   ;                     + 10         D2    (L)
                     255   ;                     + 12         D3    (H)
                     256   ;                     + 14         D3    (L)
                     257   ;                     + 16         D4    (H)
                     258   ;                     + 18         D4    (L)
                     259   ;                     + 20         D5    (H)
                     260   ;                     + 22         D5    (L)
                     261   ;                     + 24         D6    (H)
                     262   ;                     + 26         D6    (L)
                     263   ;                     + 28         D7    (H)
                     264   ;                     + 30         D7    (L)
                     265   ;                     + 32         A0    (H)
                     266   ;                     + 34         A0    (L)
                     267   ;                     + 36         A1    (H)
                     268   ;                     + 38         A1    (L)
                     269   ;                     + 40         A2    (H)
                     270   ;                     + 42         A2    (L)
                     271   ;                     + 44         A3    (H)
                     272   ;                     + 46         A3    (L)
                     273   ;                     + 48         A4    (H)
                     274   ;                     + 50         A4    (L)
                     275   ;                     + 52         A5    (H)
                     276   ;                     + 54         A5    (L)
                     277   ;                     + 56         A6    (H)
                     278   ;                     + 58         A6    (L)
                     279   ;                     + 60         Task or ISR's SR
                     280   ;                     + 62         PC of task  (H)
                     281   ;                     + 64         PC of task  (L)                   High Memory
                     282   ;********************************************************************************************************
                     283   
                     284   OSIntExit68K:
00800126  5339 0060  285           SUBQ.B    #1,_OSIntNesting              ; if (--OSIntNesting == 0)
0080012A  2636      
0080012C  6600 009C  286           BNE       OSIntExit68K_1
00800130  4A39 0060  287           TST.B     _OSLockNesting                ; if (OSLockNesting == 0)
00800134  2638      
00800136  6600 0092  288           BNE       OSIntExit68K_1
0080013A  302F 003C  289           MOVE.W    (60,A7),D0                    ;  if (LAST nested ISR)
0080013E  C07C 0700  290           AND.W     #$0700,D0
00800142  6600 0086  291           BNE       OSIntExit68K_1
00800146  41F9 0080  292           LEA       _OSUnMapTbl,A0                ;  y = OSUnMapTbl[OSRdyGrp];
0080014A  FE3E      
0080014C  4280       293           CLR.L     D0
0080014E  1039 0060  294           MOVE.B    _OSRdyGrp,D0
00800152  263E      
00800154  1230 0800  295           MOVE.B    0(A0,D0.L),D1                 ;  y in D1
00800158  41F9 0060  296           LEA       _OSRdyTbl,A0                  ;  OSPrioHighRdy = (INT8U)((y << 3) + OSUnMapTbl[OSRdyTbl[y]]);
0080015C  2640      
0080015E  4280       297           CLR.L     D0
00800160  1001       298           MOVE.B    D1,D0
00800162  41F0 0800  299           LEA       0(A0,D0.L),A0
00800166  4280       300           CLR.L     D0
00800168  1010       301           MOVE.B    (A0),D0                       ;  OSRdyTbl[y] in D0
0080016A  41F9 0080  302           LEA       _OSUnMapTbl,A0
0080016E  FE3E      
00800170  41F0 0800  303           LEA       0(A0,D0.L),A0                 ;  &OSUnMapTbl[OSRdyTbl[y]] in A0
00800174  1001       304           MOVE.B    D1,D0
00800176  E708       305           LSL.B     #3,D0                         ;  (y << 3) in D0
00800178  D010       306           ADD.B     (A0),D0
0080017A  13C0 0060  307           MOVE.B    D0,_OSPrioHighRdy
0080017E  263C      
00800180  B039 0060  308           CMP.B     _OSPrioCur,D0                 ;  if (OSPrioCur != OSPrioHighRdy) {
00800184  263A      
00800186  6742       309           BEQ.S     OSIntExit68K_1
00800188  41F9 0060  310           LEA       _OSTCBPrioTbl,A0              ;    OSTCBHighRdy  = OSTCBPrioTbl[OSPrioHighRdy];
0080018C  2760      
0080018E  4281       311           CLR.L     D1
00800190  1200       312           MOVE.B    D0,D1
00800192  E589       313           LSL.L     #2,D1
00800194  41F0 1800  314           LEA       0(A0,D1.L),A0
00800198  23D0 0060  315           MOVE.L    (A0),_OSTCBHighRdy
0080019C  2758      
0080019E  52B9 0060  316           ADDQ.L    #1,_OSCtxSwCtr                ;    OSCtxSwCtr++;
008001A2  2406      
008001A4  2079 0060  317           MOVE.L    _OSTCBCur,A0                  ;    Save the stack pointer in the suspended task TCB
008001A8  2750      
008001AA  208F       318           MOVE.L    A7,(A0)
008001AC  4EB9 0080  319           JSR       _OSTaskSwHook                 ;    Invoke user defined context switch hook
008001B0  0334      
008001B2  2079 0060  320           MOVE.L    _OSTCBHighRdy,A0              ;    OSTCBCur  = OSTCBHighRdy
008001B6  2758      
008001B8  23C8 0060  321           MOVE.L    A0,_OSTCBCur
008001BC  2750      
008001BE  13F9 0060  322           MOVE.B    _OSPrioHighRdy,_OSPrioCur     ;    OSPrioCur = OSPrioHighRdy
008001C2  263C 0060 
008001C6  263A      
008001C8  2E50       323           MOVE.L    (A0),A7                       ;    Get the stack pointer of the task to resume
                     324   OSIntExit68K_1:
008001CA  4CDF 7FFF  325           MOVEM.L   (A7)+,A0-A6/D0-D7             ;  Restore the CPU registers
008001CE  4E73       326           RTE                                     ;  Return to task or nested ISR
                     327   
                     328   ;********************************************************************************************************
                     329   ;                                           SYSTEM TICK ISR
                     330   ;
                     331   ; Description : This function is the ISR used to notify uC/OS-II that a system tick has occurred.
                     332   ;
                     333   ; Arguments   : none
                     334   ;
                     335   ; Notes       : 1) You MUST increment 'OSIntNesting' and NOT call OSIntEnter()
                     336   ;               2) You MUST save ALL the CPU registers as shown below
                     337   ;               3) You MUST JUMP to OSIntExit68K() instead of call the function.
                     338   ;********************************************************************************************************
                     339   
                     340   _OSTickISR:
008001D0  007C 0700  341           OR.W      #$0700,SR                     ; Disable ALL interrupts
008001D4  5239 0060  342           ADDQ.B    #1,_OSIntNesting              ; OSIntNesting++;
008001D8  2636      
008001DA  48E7 FFFE  343           MOVEM.L   A0-A6/D0-D7,-(A7)             ; Save the registers of the current task
008001DE  4EB9 0080  344           JSR       _OSTimeTick                   ; Call uC/OS-II's tick updating function
008001E2  099A      
008001E4  6000 FF40  345           BRA       OSIntExit68K                  ; Exit ISR
