                    14306   ; *                        than OS_TASK_REG_TBL_SIZE
                    14307   ; *
                    14308   ; *              value     is the desired value for the task register.
                    14309   ; *
                    14310   ; *              perr      is a pointer to a variable that will hold an error code related to this call.
                    14311   ; *
                    14312   ; *                        OS_ERR_NONE            if the call was successful
                    14313   ; *                        OS_ERR_PRIO_INVALID    if you specified an invalid priority
                    14314   ; *                        OS_ERR_ID_INVALID      if the 'id' is not between 0 and OS_TASK_REG_TBL_SIZE-1
                    14315   ; *
                    14316   ; * Returns    : The current value of the task's variable or 0 if an error is detected.
                    14317   ; *
                    14318   ; * Note(s)    : The maximum number of task variables is 254
                    14319   ; *********************************************************************************************************
                    14320   ; */
