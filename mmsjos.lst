                    11359   ; /*
                    11360   ; *********************************************************************************************************
                    11361   ; *                                         DELETE A SEMAPHORE
                    11362   ; *
                    11363   ; * Description: This function deletes a semaphore and readies all tasks pending on the semaphore.
                    11364   ; *
                    11365   ; * Arguments  : pevent        is a pointer to the event control block associated with the desired
                    11366   ; *                            semaphore.
                    11367   ; *
                    11368   ; *              opt           determines delete options as follows:
                    11369   ; *                            opt == OS_DEL_NO_PEND   Delete semaphore ONLY if no task pending
                    11370   ; *                            opt == OS_DEL_ALWAYS    Deletes the semaphore even if tasks are waiting.
                    11371   ; *                                                    In this case, all the tasks pending will be readied.
                    11372   ; *
                    11373   ; *              perr          is a pointer to an error code that can contain one of the following values:
                    11374   ; *                            OS_ERR_NONE             The call was successful and the semaphore was deleted
                    11375   ; *                            OS_ERR_DEL_ISR          If you attempted to delete the semaphore from an ISR
                    11376   ; *                            OS_ERR_INVALID_OPT      An invalid option was specified
                    11377   ; *                            OS_ERR_TASK_WAITING     One or more tasks were waiting on the semaphore
                    11378   ; *                            OS_ERR_EVENT_TYPE       If you didn't pass a pointer to a semaphore
                    11379   ; *                            OS_ERR_PEVENT_NULL      If 'pevent' is a NULL pointer.
                    11380   ; *
                    11381   ; * Returns    : pevent        upon error
                    11382   ; *              (OS_EVENT *)0 if the semaphore was successfully deleted.
                    11383   ; *
                    11384   ; * Note(s)    : 1) This function must be used with care.  Tasks that would normally expect the presence of
                    11385   ; *                 the semaphore MUST check the return code of OSSemPend().
                    11386   ; *              2) OSSemAccept() callers will not know that the intended semaphore has been deleted unless
                    11387   ; *                 they check 'pevent' to see that it's a NULL pointer.
                    11388   ; *              3) This call can potentially disable interrupts for a long time.  The interrupt disable
                    11389   ; *                 time is directly proportional to the number of tasks waiting on the semaphore.
                    11390   ; *              4) Because ALL tasks pending on the semaphore will be readied, you MUST be careful in
                    11391   ; *                 applications where the semaphore is used for mutual exclusion because the resource(s)
                    11392   ; *                 will no longer be guarded by the semaphore.
                    11393   ; *              5) All tasks that were waiting for the semaphore will be readied and returned an 
                    11394   ; *                 OS_ERR_PEND_ABORT if OSSemDel() was called with OS_DEL_ALWAYS
                    11395   ; *********************************************************************************************************
                    11396   ; */
                    11397   ; #if OS_SEM_DEL_EN > 0u
                    11398   ; OS_EVENT  *OSSemDel (OS_EVENT  *pevent,
                    11399   ; INT8U      opt,
                    11400   ; INT8U     *perr)
                    11401   ; {
                    11402   _OSSemDel:
