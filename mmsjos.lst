                    3521   ; /*
                    3522   ; *********************************************************************************************************
                    3523   ; *                                              IDLE TASK
                    3524   ; *
                    3525   ; * Description: This task is internal to uC/OS-II and executes whenever no other higher priority tasks
                    3526   ; *              executes because they are ALL waiting for event(s) to occur.
                    3527   ; *
                    3528   ; * Arguments  : none
                    3529   ; *
                    3530   ; * Returns    : none
