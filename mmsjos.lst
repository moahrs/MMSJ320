                    13219   ; /*
                    13220   ; *********************************************************************************************************
                    13221   ; *                                  REQUEST THAT A TASK DELETE ITSELF
                    13222   ; *
                    13223   ; * Description: This function is used to:
                    13224   ; *                   a) notify a task to delete itself.
                    13225   ; *                   b) to see if a task requested that the current task delete itself.
                    13226   ; *              This function is a little tricky to understand.  Basically, you have a task that needs
                    13227   ; *              to be deleted however, this task has resources that it has allocated (memory buffers,
                    13228   ; *              semaphores, mailboxes, queues etc.).  The task cannot be deleted otherwise these
                    13229   ; *              resources would not be freed.  The requesting task calls OSTaskDelReq() to indicate that
                    13230   ; *              the task needs to be deleted.  Deleting of the task is however, deferred to the task to
                    13231   ; *              be deleted.  For example, suppose that task #10 needs to be deleted.  The requesting task
                    13232   ; *              example, task #5, would call OSTaskDelReq(10).  When task #10 gets to execute, it calls
                    13233   ; *              this function by specifying OS_PRIO_SELF and monitors the returned value.  If the return
                    13234   ; *              value is OS_ERR_TASK_DEL_REQ, another task requested a task delete.  Task #10 would look like
                    13235   ; *              this:
                    13236   ; *
                    13237   ; *                   void Task(void *p_arg)
                    13238   ; *                   {
                    13239   ; *                       .
                    13240   ; *                       .
                    13241   ; *                       while (1) {
                    13242   ; *                           OSTimeDly(1);
                    13243   ; *                           if (OSTaskDelReq(OS_PRIO_SELF) == OS_ERR_TASK_DEL_REQ) {
                    13244   ; *                               Release any owned resources;
                    13245   ; *                               De-allocate any dynamic memory;
                    13246   ; *                               OSTaskDel(OS_PRIO_SELF);
                    13247   ; *                           }
                    13248   ; *                       }
                    13249   ; *                   }
                    13250   ; *
                    13251   ; * Arguments  : prio    is the priority of the task to request the delete from
                    13252   ; *
                    13253   ; * Returns    : OS_ERR_NONE            if the task exist and the request has been registered
                    13254   ; *              OS_ERR_TASK_NOT_EXIST  if the task has been deleted.  This allows the caller to know whether
                    13255   ; *                                     the request has been executed.
                    13256   ; *              OS_ERR_TASK_DEL        if the task is assigned to a Mutex.
                    13257   ; *              OS_ERR_TASK_DEL_IDLE   if you requested to delete uC/OS-II's idle task
                    13258   ; *              OS_ERR_PRIO_INVALID    if the priority you specify is higher that the maximum allowed
                    13259   ; *                                     (i.e. >= OS_LOWEST_PRIO) or, you have not specified OS_PRIO_SELF.
                    13260   ; *              OS_ERR_TASK_DEL_REQ    if a task (possibly another task) requested that the running task be
                    13261   ; *                                     deleted.
                    13262   ; *********************************************************************************************************
                    13263   ; */
                    13264   ; /*$PAGE*/
                    13265   ; #if OS_TASK_DEL_EN > 0u
                    13266   ; INT8U  OSTaskDelReq (INT8U prio)
                    13267   ; {
                    13268   _OSTaskDelReq:
