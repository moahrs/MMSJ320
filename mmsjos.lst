                    8211   ; /*
                    8212   ; *********************************************************************************************************
                    8213   ; *                                 CREATE A MUTUAL EXCLUSION SEMAPHORE
                    8214   ; *
                    8215   ; * Description: This function creates a mutual exclusion semaphore.
                    8216   ; *
                    8217   ; * Arguments  : prio          is the priority to use when accessing the mutual exclusion semaphore.  In
                    8218   ; *                            other words, when the semaphore is acquired and a higher priority task
                    8219   ; *                            attempts to obtain the semaphore then the priority of the task owning the
                    8220   ; *                            semaphore is raised to this priority.  It is assumed that you will specify
                    8221   ; *                            a priority that is LOWER in value than ANY of the tasks competing for the
                    8222   ; *                            mutex. If the priority is specified as OS_PRIO_MUTEX_CEIL_DIS, then the
                    8223   ; *                            priority ceiling promotion is disabled. This way, the tasks accessing the
                    8224   ; *                            semaphore do not have their priority promoted.
                    8225   ; *
                    8226   ; *              perr          is a pointer to an error code which will be returned to your application:
                    8227   ; *                               OS_ERR_NONE         if the call was successful.
                    8228   ; *                               OS_ERR_CREATE_ISR   if you attempted to create a MUTEX from an ISR
                    8229   ; *                               OS_ERR_PRIO_EXIST   if a task at the priority ceiling priority
                    8230   ; *                                                   already exist.
                    8231   ; *                               OS_ERR_PEVENT_NULL  No more event control blocks available.
                    8232   ; *                               OS_ERR_PRIO_INVALID if the priority you specify is higher that the
                    8233   ; *                                                   maximum allowed (i.e. > OS_LOWEST_PRIO)
                    8234   ; *
                    8235   ; * Returns    : != (void *)0  is a pointer to the event control clock (OS_EVENT) associated with the
                    8236   ; *                            created mutex.
                    8237   ; *              == (void *)0  if an error is detected.
                    8238   ; *
                    8239   ; * Note(s)    : 1) The LEAST significant 8 bits of '.OSEventCnt' hold the priority number of the task
                    8240   ; *                 owning the mutex or 0xFF if no task owns the mutex.
                    8241   ; *
                    8242   ; *              2) The MOST  significant 8 bits of '.OSEventCnt' hold the priority number used to
                    8243   ; *                 reduce priority inversion or 0xFF (OS_PRIO_MUTEX_CEIL_DIS) if priority ceiling
                    8244   ; *                 promotion is disabled.
                    8245   ; *********************************************************************************************************
                    8246   ; */
                    8247   ; OS_EVENT  *OSMutexCreate (INT8U   prio,
                    8248   ; INT8U  *perr)
                    8249   ; {
                    8250   _OSMutexCreate:
0080278C  4E56 0000 8251          link      A6,#0
