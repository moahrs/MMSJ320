                    8690   ; /*
                    8691   ; *********************************************************************************************************
                    8692   ; *                                 PEND ON MUTUAL EXCLUSION SEMAPHORE
                    8693   ; *
                    8694   ; * Description: This function waits for a mutual exclusion semaphore.
                    8695   ; *
                    8696   ; * Arguments  : pevent        is a pointer to the event control block associated with the desired
                    8697   ; *                            mutex.
                    8698   ; *
                    8699   ; *              timeout       is an optional timeout period (in clock ticks).  If non-zero, your task will
                    8700   ; *                            wait for the resource up to the amount of time specified by this argument.
                    8701   ; *                            If you specify 0, however, your task will wait forever at the specified
                    8702   ; *                            mutex or, until the resource becomes available.
                    8703   ; *
                    8704   ; *              perr          is a pointer to where an error message will be deposited.  Possible error
                    8705   ; *                            messages are:
                    8706   ; *                               OS_ERR_NONE        The call was successful and your task owns the mutex
                    8707   ; *                               OS_ERR_TIMEOUT     The mutex was not available within the specified 'timeout'.
                    8708   ; *                               OS_ERR_PEND_ABORT  The wait on the mutex was aborted.
                    8709   ; *                               OS_ERR_EVENT_TYPE  If you didn't pass a pointer to a mutex
                    8710   ; *                               OS_ERR_PEVENT_NULL 'pevent' is a NULL pointer
                    8711   ; *                               OS_ERR_PEND_ISR    If you called this function from an ISR and the result
                    8712   ; *                                                  would lead to a suspension.
                    8713   ; *                               OS_ERR_PCP_LOWER   If the priority of the task that owns the Mutex is
                    8714   ; *                                                  HIGHER (i.e. a lower number) than the PCP.  This error
                    8715   ; *                                                  indicates that you did not set the PCP higher (lower
                    8716   ; *                                                  number) than ALL the tasks that compete for the Mutex.
                    8717   ; *                                                  Unfortunately, this is something that could not be
                    8718   ; *                                                  detected when the Mutex is created because we don't know
                    8719   ; *                                                  what tasks will be using the Mutex.
                    8720   ; *                               OS_ERR_PEND_LOCKED If you called this function when the scheduler is locked
                    8721   ; *
                    8722   ; * Returns    : none
                    8723   ; *
                    8724   ; * Note(s)    : 1) The task that owns the Mutex MUST NOT pend on any other event while it owns the mutex.
                    8725   ; *
                    8726   ; *              2) You MUST NOT change the priority of the task that owns the mutex
                    8727   ; *********************************************************************************************************
                    8728   ; */
                    8729   ; void  OSMutexPend (OS_EVENT  *pevent,
                    8730   ; INT32U     timeout,
                    8731   ; INT8U     *perr)
                    8732   ; {
                    8733   _OSMutexPend:
00802A26  4E56 FFFC 8734          link      A6,#-4
00802A2A  48E7 3F30 8735          movem.l   D2/D3/D4/D5/D6/D7/A2/A3,-(A7)
