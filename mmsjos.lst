                    12940   ; /*
                    12941   ; *********************************************************************************************************
                    12942   ; *                                            DELETE A TASK
                    12943   ; *
                    12944   ; * Description: This function allows you to delete a task.  The calling task can delete itself by
                    12945   ; *              its own priority number.  The deleted task is returned to the dormant state and can be
                    12946   ; *              re-activated by creating the deleted task again.
                    12947   ; *
                    12948   ; * Arguments  : prio    is the priority of the task to delete.  Note that you can explicitly delete
                    12949   ; *                      the current task without knowing its priority level by setting 'prio' to
                    12950   ; *                      OS_PRIO_SELF.
                    12951   ; *
                    12952   ; * Returns    : OS_ERR_NONE             if the call is successful
                    12953   ; *              OS_ERR_TASK_DEL_IDLE    if you attempted to delete uC/OS-II's idle task
                    12954   ; *              OS_ERR_PRIO_INVALID     if the priority you specify is higher that the maximum allowed
                    12955   ; *                                      (i.e. >= OS_LOWEST_PRIO) or, you have not specified OS_PRIO_SELF.
                    12956   ; *              OS_ERR_TASK_DEL         if the task is assigned to a Mutex PIP.
                    12957   ; *              OS_ERR_TASK_NOT_EXIST   if the task you want to delete does not exist.
                    12958   ; *              OS_ERR_TASK_DEL_ISR     if you tried to delete a task from an ISR
                    12959   ; *
                    12960   ; * Notes      : 1) To reduce interrupt latency, OSTaskDel() 'disables' the task:
                    12961   ; *                    a) by making it not ready
                    12962   ; *                    b) by removing it from any wait lists
                    12963   ; *                    c) by preventing OSTimeTick() from making the task ready to run.
                    12964   ; *                 The task can then be 'unlinked' from the miscellaneous structures in uC/OS-II.
                    12965   ; *              2) The function OS_Dummy() is called after OS_EXIT_CRITICAL() because, on most processors,
                    12966   ; *                 the next instruction following the enable interrupt instruction is ignored.
                    12967   ; *              3) An ISR cannot delete a task.
                    12968   ; *              4) The lock nesting counter is incremented because, for a brief instant, if the current
                    12969   ; *                 task is being deleted, the current task would not be able to be rescheduled because it
                    12970   ; *                 is removed from the ready list.  Incrementing the nesting counter prevents another task
                    12971   ; *                 from being schedule.  This means that an ISR would return to the current task which is
                    12972   ; *                 being deleted.  The rest of the deletion would thus be able to be completed.
                    12973   ; *********************************************************************************************************
                    12974   ; */
                    12975   ; #if OS_TASK_DEL_EN > 0u
                    12976   ; INT8U  OSTaskDel (INT8U prio)
                    12977   ; {
                    12978   _OSTaskDel:
00804150  4E56 0000 12979          link      A6,#0
00804154  48E7 3800 12980          movem.l   D2/D3/D4,-(A7)
00804158  162E 000B 12981          move.b    11(A6),D3
