                    13354   ; /*
                    13355   ; *********************************************************************************************************
                    13356   ; *                                       GET THE NAME OF A TASK
                    13357   ; *
                    13358   ; * Description: This function is called to obtain the name of a task.
                    13359   ; *
                    13360   ; * Arguments  : prio      is the priority of the task that you want to obtain the name from.
                    13361   ; *
                    13362   ; *              pname     is a pointer to a pointer to an ASCII string that will receive the name of the task.
                    13363   ; *
                    13364   ; *              perr      is a pointer to an error code that can contain one of the following values:
                    13365   ; *
                    13366   ; *                        OS_ERR_NONE                if the requested task is resumed
                    13367   ; *                        OS_ERR_TASK_NOT_EXIST      if the task has not been created or is assigned to a Mutex
                    13368   ; *                        OS_ERR_PRIO_INVALID        if you specified an invalid priority:
                    13369   ; *                                                   A higher value than the idle task or not OS_PRIO_SELF.
                    13370   ; *                        OS_ERR_PNAME_NULL          You passed a NULL pointer for 'pname'
                    13371   ; *                        OS_ERR_NAME_GET_ISR        You called this function from an ISR
                    13372   ; *
                    13373   ; *
                    13374   ; * Returns    : The length of the string or 0 if the task does not exist.
                    13375   ; *********************************************************************************************************
                    13376   ; */
                    13377   ; #if OS_TASK_NAME_EN > 0u
                    13378   ; INT8U  OSTaskNameGet (INT8U    prio,
