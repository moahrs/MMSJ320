                    1212   ; *perr =  OS_ERR_PEVENT_NULL;
                    1213   ; return (0u);
                    1214   ; }
                    1215   ; if (pevents_rdy  == (OS_EVENT **)0) {               /* Validate 'pevents_rdy'                      */
                    1216   ; *perr =  OS_ERR_PEVENT_NULL;
                    1217   ; return (0u);
                    1218   ; }
                    1219   ; if (pmsgs_rdy == (void **)0) {                      /* Validate 'pmsgs_rdy'                        */
                    1220   ; *perr =  OS_ERR_PEVENT_NULL;
                    1221   ; return (0u);
                    1222   ; }
                    1223   ; #endif
                    1224   ; *pevents_rdy = (OS_EVENT *)0;                        /* Init array to NULL in case of errors        */
00800490  2045      1225          move.l    D5,A0
00800492  4290      1226          clr.l     (A0)
                    1227   ; pevents     =  pevents_pend;
