                    11442   ; *perr = OS_ERR_DEL_ISR;                            /* ... can't DELETE from an ISR             */
0080394C  2043      11443          move.l    D3,A0
0080394E  10BC 000F 11444          move.b    #15,(A0)
                    11445   ; return (pevent);
00803952  2002      11446          move.l    D2,D0
00803954  6000 00D6 11447          bra       OSSemDel_3
                    11448   OSSemDel_4:
                    11449   ; }
                    11450   ; OS_ENTER_CRITICAL();
