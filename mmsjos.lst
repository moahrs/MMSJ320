                    14979   ; *                                           CREATE A TIMER
                    14980   ; *
                    14981   ; * Description: This function is called by your application code to create a timer.
                    14982   ; *
                    14983   ; * Arguments  : dly           Initial delay.
                    14984   ; *                            If the timer is configured for ONE-SHOT mode, this is the timeout used.
                    14985   ; *                            If the timer is configured for PERIODIC mode, this is the first timeout to 
                    14986   ; *                               wait for before the timer starts entering periodic mode.
                    14987   ; *
                    14988   ; *              period        The 'period' being repeated for the timer.
                    14989   ; *                               If you specified 'OS_TMR_OPT_PERIODIC' as an option, when the timer 
                    14990   ; *                               expires, it will automatically restart with the same period.
                    14991   ; *
                    14992   ; *              opt           Specifies either:
                    14993   ; *                               OS_TMR_OPT_ONE_SHOT       The timer counts down only once
                    14994   ; *                               OS_TMR_OPT_PERIODIC       The timer counts down and then reloads itself
                    14995   ; *
                    14996   ; *              callback      Is a pointer to a callback function that will be called when the timer expires. 
                    14997   ; *                               The callback function must be declared as follows:
                    14998   ; *
                    14999   ; *                               void MyCallback (OS_TMR *ptmr, void *p_arg);
                    15000   ; *
                    15001   ; *              callback_arg  Is an argument (a pointer) that is passed to the callback function when it is called.
                    15002   ; *
                    15003   ; *              pname         Is a pointer to an ASCII string that is used to name the timer.  Names are 
                    15004   ; *                               useful for debugging.
                    15005   ; *
                    15006   ; *              perr          Is a pointer to an error code.  '*perr' will contain one of the following:
                    15007   ; *                               OS_ERR_NONE
                    15008   ; *                               OS_ERR_TMR_INVALID_DLY     you specified an invalid delay
                    15009   ; *                               OS_ERR_TMR_INVALID_PERIOD  you specified an invalid period
                    15010   ; *                               OS_ERR_TMR_INVALID_OPT     you specified an invalid option
                    15011   ; *                               OS_ERR_TMR_ISR             if the call was made from an ISR
                    15012   ; *                               OS_ERR_TMR_NON_AVAIL       if there are no free timers from the timer pool
                    15013   ; *
                    15014   ; * Returns    : A pointer to an OS_TMR data structure.
                    15015   ; *              This is the 'handle' that your application will use to reference the timer created.
                    15016   ; *********************************************************************************************************
                    15017   ; */
                    15018   ; #if OS_TMR_EN > 0u
                    15019   ; OS_TMR  *OSTmrCreate (INT32U           dly,
