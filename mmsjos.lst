                    14426   ; /*
                    14427   ; *********************************************************************************************************
                    14428   ; *                                          CLEAR TASK STACK
                    14429   ; *
                    14430   ; * Description: This function is used to clear the stack of a task (i.e. write all zeros)
                    14431   ; *
                    14432   ; * Arguments  : pbos     is a pointer to the task's bottom of stack.  If the configuration constant
                    14433   ; *                       OS_STK_GROWTH is set to 1, the stack is assumed to grow downward (i.e. from high
                    14434   ; *                       memory to low memory).  'pbos' will thus point to the lowest (valid) memory
                    14435   ; *                       location of the stack.  If OS_STK_GROWTH is set to 0, 'pbos' will point to the
                    14436   ; *                       highest memory location of the stack and the stack will grow with increasing
                    14437   ; *                       memory locations.  'pbos' MUST point to a valid 'free' data item.
                    14438   ; *
                    14439   ; *              size     is the number of 'stack elements' to clear.
                    14440   ; *
                    14441   ; *              opt      contains additional information (or options) about the behavior of the task.  The
                    14442   ; *                       LOWER 8-bits are reserved by uC/OS-II while the upper 8 bits can be application
                    14443   ; *                       specific.  See OS_TASK_OPT_??? in uCOS-II.H.
                    14444   ; *
                    14445   ; * Returns    : none
                    14446   ; *********************************************************************************************************
                    14447   ; */
                    14448   ; #if (OS_TASK_STAT_STK_CHK_EN > 0u) && (OS_TASK_CREATE_EXT_EN > 0u)
                    14449   ; void  OS_TaskStkClr (OS_STK  *pbos,
                    14450   ; INT32U   size,
                    14451   ; INT16U   opt)
                    14452   ; {
                    14453   _OS_TaskStkClr:
008048B4  4E56 0000 14454          link      A6,#0
                    14455   ; if ((opt & OS_TASK_OPT_STK_CHK) != 0x0000u) {      /* See if stack checking has been enabled       */
008048B8  302E 0012 14456          move.w    18(A6),D0
008048BC  C07C 0001 14457          and.w     #1,D0
008048C0  6726      14458          beq.s     OS_TaskStkClr_7
                    14459   ; if ((opt & OS_TASK_OPT_STK_CLR) != 0x0000u) {  /* See if stack needs to be cleared             */
008048C2  302E 0012 14460          move.w    18(A6),D0
008048C6  C07C 0002 14461          and.w     #2,D0
008048CA  671C      14462          beq.s     OS_TaskStkClr_7
                    14463   ; #if OS_STK_GROWTH == 1u
                    14464   ; while (size > 0u) {                        /* Stack grows from HIGH to LOW memory          */
                    14465   OS_TaskStkClr_5:
008048CC  202E 000C 14466          move.l    12(A6),D0
008048D0  0C80 0000 14467          cmp.l     #0,D0
008048D4  0000      
008048D6  6310      14468          bls.s     OS_TaskStkClr_7
                    14469   ; size--;
008048D8  53AE 000C 14470          subq.l    #1,12(A6)
                    14471   ; *pbos++ = (OS_STK)0;                   /* Clear from bottom of stack and up!           */
008048DC  206E 0008 14472          move.l    8(A6),A0
008048E0  54AE 0008 14473          addq.l    #2,8(A6)
008048E4  4250      14474          clr.w     (A0)
008048E6  60E4      14475          bra       OS_TaskStkClr_5
                    14476   OS_TaskStkClr_7:
008048E8  4E5E      14477          unlk      A6
008048EA  4E75      14478          rts
