008048EC  4E56 0000 14523          link      A6,#0
008048F0  48E7 2020 14524          movem.l   D2/A2,-(A7)
008048F4  45F9 0060 14525          lea       _OSTCBCur.L,A2
008048F8  2750      
                    14526   ; INT8U      y;
                    14527   ; #if OS_CRITICAL_METHOD == 3u                     /* Allocate storage for CPU status register           */
                    14528   ; OS_CPU_SR  cpu_sr = 0u;
