10 HGR
12 SZ = 50 : CX = 140 : CY = 96
15 SC = 0
18 ANGLE = 0
20 DIM PT(7,2)
25 DIM RZ(7,2) : DIM RY(7,2) : DIM RX(7,2)
30 GOSUB 5000

100 REM DRAW LOOP
110 GOSUB 2000 : REM ROTATE POINTS
120 GOSUB 6000 : REM DRAW LINES
125 HCOLOR = 1
130 GOSUB 6000 : REM CLEAR LINES
140 ANGLE = ANGLE + 0.1
160 GOTO 100

500 X1 = RY(A,0) * SZ + CX
510 Y1 = RY(A,1) * SZ + CY
520 X2 = RY(B,0) * SZ + CX
530 Y2 = RY(B,1) * SZ + CY
535 HCOLOR=3
540 HPLOT X1,Y1 TO X2,Y2
550 RETURN 

2000 CS = COS(ANGLE)
2010 SN = SIN(ANGLE)
2020 FOR N = 0 TO 7
2030 RZ(N,0) = -CS * PT(N,0) + SN * PT(N,1) +  0 * PT(N,2)
2040 RZ(N,1) =  SN * PT(N,0) + CS * PT(N,1) +  0 * PT(N,2)
2050 RZ(N,2) =   0 * PT(N,0) +  0 * PT(N,1) +  1 * PT(N,2)
2060 RY(N,0) =  CS * RZ(N,0) +  0 * RZ(N,1) + SN * RZ(N,2)
2070 RY(N,1) =   0 * RZ(N,0) +  1 * RZ(N,1) +  0 * RZ(N,2)
2080 RY(N,2) = -SN * RZ(N,0) +  0 * RZ(N,1) + CS * RZ(N,2)
2090 RX(N,0) =  RY(N,0)
2100 RX(N,1) =  CS * RY(N,1) - SN * RY(N,2)
2110 RX(N,2) =  SN * RY(N,1) + CS * RY(N,2)
2120 NEXT N
2130 RETURN 

5000 PT(0,0) = -1: PT(0,1) = -1 : PT(0,2) = -1
5010 PT(1,0) =  1: PT(1,1) = -1 : PT(1,2) = -1
5020 PT(2,0) =  1: PT(2,1) =  1 : PT(2,2) = -1
5030 PT(3,0) = -1: PT(3,1) =  1 : PT(3,2) = -1
5040 PT(4,0) = -1: PT(4,1) = -1 : PT(4,2) =  1
5050 PT(5,0) =  1: PT(5,1) = -1 : PT(5,2) =  1
5060 PT(6,0) =  1: PT(6,1) =  1 : PT(6,2) =  1
5070 PT(7,0) = -1: PT(7,1) =  1 : PT(7,2) =  1
5080 RETURN 

6000 REM DRAW LINES
6010 A = 0 : B = 1 : GOSUB 500
6020 A = 1 : B = 2 : GOSUB 500
6030 A = 2 : B = 3 : GOSUB 500
6040 A = 3 : B = 0 : GOSUB 500
6050 A = 4 : B = 5 : GOSUB 500
6060 A = 5 : B = 6 : GOSUB 500
6070 A = 6 : B = 7 : GOSUB 500
6080 A = 7 : B = 4 : GOSUB 500
6090 A = 0 : B = 4 : GOSUB 500
6100 A = 1 : B = 5 : GOSUB 500
6110 A = 2 : B = 6 : GOSUB 500
6120 A = 3 : B = 7 : GOSUB 500
6130 RETURN 