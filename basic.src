; nextToken();
       jsr       _nextToken
; if (*vErroProc) return 0;
       move.l    (A3),A0
       tst.w     (A0)
       beq.s     procParam_1
       clr.l     D0
       bra       procParam_3
procParam_1:
; // Se obriga parenteses, primeiro caracter deve ser abre parenteses
; if (temParenteses)
       tst.b     15(A6)
       beq       procParam_9
; {
; if (*tok == EOL || *tok == FINISHED || *token_type != OPENPARENT)
       move.l    _tok.L,A0
       move.b    (A0),D0
       and.w     #255,D0
       cmp.w     #226,D0
       beq.s     procParam_8
       move.l    _tok.L,A0
       move.b    (A0),D0
