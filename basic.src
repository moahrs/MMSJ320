         DC.W      -33       10**-10
         DC.L      $DBE6FECF
         DC.W      -36       10**-11
         DC.L      $AFEBFF0C
         DC.W      -39       10**-12
         DC.L      $8CBCCC09
         DC.W      -43       10**-13
         DC.L      $E12E1342
         DC.W      -46       10**-14
         DC.L      $B424DC35
         DC.W      -49       10**-15
         DC.L      $901D7CF7
         DC.W      -53       10**-16
         DC.L      $E69594BF
         DC.W      -56       10**-17
         DC.L      $B877AA32
         DC.W      -59       10**-18
         DC.L      $9392EE8F
         DC.W      -63       10**-19
         DC.L      $EC1E4A7E
         DC.W      -66       10**-20
         DC.L      $BCE50865
         DC.W      -69       10**-21
         DC.L      $971DA050
         DC.W      -73       10**-22
         DC.L      $F1C90081
         DC.W      -76       10**-23
         DC.L      $C16D9A01
         DC.W      -79       10**-24
