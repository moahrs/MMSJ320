10 REM CUBO 3D - COM INT() EXPLICITO
20 CLEAR
30 SCREEN 2,0
40 CLS
50 BUFDRAWON
60 CX%=128:CY%=96:DD=180:SS=45
70 DIM XX(7):DIM YY(7):DIM ZZ(7)
80 DIM NX%(7):DIM NY%(7)
90 DIM EA(11):DIM EB(11)
100 FOR I=0 TO 11:READ EA(I):READ EB(I):NEXT I
110 XX(0)=-SS:YY(0)=-SS:ZZ(0)=-SS
120 XX(1)= SS:YY(1)=-SS:ZZ(1)=-SS
130 XX(2)= SS:YY(2)= SS:ZZ(2)=-SS
140 XX(3)=-SS:YY(3)= SS:ZZ(3)=-SS
150 XX(4)=-SS:YY(4)=-SS:ZZ(4)= SS
160 XX(5)= SS:YY(5)=-SS:ZZ(5)= SS
170 XX(6)= SS:YY(6)= SS:ZZ(6)= SS
180 XX(7)=-SS:YY(7)= SS:ZZ(7)= SS
190 AX=0:AY=0
200 IX=0.08:IY=0.11
210 WHILE 1
220 FILL 0,0,255,191,0
230 GOSUB 1000
240 COLOR 7
250 GOSUB 2000
260 BUFSHOW 0,0,255,191
270 AX=AX+IX
280 AY=AY+IY
290 IF AX>6.28318 THEN AX=AX-6.28318
300 IF AY>6.28318 THEN AY=AY-6.28318
310 WEND
320 END
1000 REM ROTACAO + PROJECAO
1010 SA=SIN(AX)
1020 CA=COS(AX)
1030 SB=SIN(AY)
1040 CB=COS(AY)
1050 FOR I=0 TO 7
1060 X1=XX(I)*CB+ZZ(I)*SB
1070 Z1=ZZ(I)*CB-XX(I)*SB
1080 Y1=YY(I)*CA-Z1*SA
1090 Z2=Z1*CA+YY(I)*SA
1100 PP=DD+Z2
1110 NX%(I)=INT(CX%+(X1*DD)/PP)
1120 NY%(I)=INT(CY%-(Y1*DD)/PP)
1130 NEXT I
1140 RETURN
2000 REM DESENHA ARESTAS
2010 FOR E=0 TO 11
2020 I=EA(E):J=EB(E)
2030 LINE NX%(I),NY%(I) TO NX%(J),NY%(J)
2040 NEXT E
2050 RETURN
3000 REM ARESTAS DO CUBO
3010 DATA 0,1,1,2,2,3,3,0
3020 DATA 4,5,5,6,6,7,7,4
3030 DATA 0,4,1,5,2,6,3,7
