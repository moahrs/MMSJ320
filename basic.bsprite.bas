10 SCREEN 2,0
12 s$=""
15 for i%=1 to 8
20 read o%
25 s$=s$+chr$(o%)
27 next i%
30 SPRITESET 0,S$
40 X=100: Y=100
50 SPRITEPUT 0,1,X,Y,15
60 get K$
70 IF K$="W" THEN Y=Y-1
80 IF K$="S" THEN Y=Y+1
90 IF K$="A" THEN X=X-1
100 IF K$="D" THEN X=X+1
105 IF K$=CHR$(27) THEN GOTO 130
110 SPRITEPOS 0,X,Y
120 GOTO 50
130 END
2000 DATA 255,129,129,129,129,129,129,255
