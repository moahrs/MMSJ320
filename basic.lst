                    22514   ******************************
                    22515   *        FFPTNORM            *
                    22516   * NORMALIZE BIN(29,31) VALUE *
                    22517   *   AND CONVERT TO FLOAT     *
                    22518   *                            *
                    22519   * INPUT: D6 - INTERNAL FIXED *
                    22520   * OUTPUT: D6 - FFP FLOAT     *
                    22521   *         CC - REFLECT VALUE *
                    22522   * NOTES:                     *
                    22523   *  1) D4 IS DESTROYED.       *
                    22524   *                            *
                    22525   * TIME: (8MHZ NO WAIT STATE) *
                    22526   *       ZERO  4.0 MICROSEC.  *
                    22527   *   AVG ELSE 17.0 MICROSEC.  *
                    22528   *                            *
                    22529   ******************************
                    22530   
                    22531   
00012226  7842      22532   FFPTNORM MOVEQ     #$42,D4             SETUP INITIAL EXPONENT
00012228  4A86      22533            TST.L     D6                  TEST FOR NON-NEGATIVE
0001222A  672E      22534            BEQ.S     FSFRTN              RETURN IF ZERO
0001222C  6A06      22535            BPL.S     FSFPLS              BRANCH IS >= 0
0001222E  4486      22536            NEG.L     D6                  ABSOLUTIZE INPUT
00012230  183C 00C2 22537            MOVE.B    #$C2,D4             SETUP INITIAL NEGATIVE EXPONENT
00012234  0C86 0000 22538   FSFPLS   CMP.L     #$00007FFF,D6       TEST FOR A SMALL NUMBER
00012238  7FFF      
0001223A  6206      22539            BHI.S     FSFCONT             BRANCH IF NOT SMALL
0001223C  4846      22540            SWAP.W    D6                  SWAP HALVES
0001223E  0404 0010 22541            SUB.B     #16,D4              OFFSET BY 16 SHIFTS
00012242  DC86      22542   FSFCONT  ADD.L     D6,D6               SHIFT ANOTHER BIT
00012244  5BCC FFFC 22543            DBMI      D4,FSFCONT          SHIFT LEFT UNTIL NORMALIZED
00012248  4A06      22544            TST.B     D6                  ? SHOULD WE ROUND UP
0001224A  6A0C      22545            BPL.S     FSFNRM              NO, BRANCH ROUNDED
0001224C  0686 0000 22546            ADD.L     #$100,D6            ROUND UP
00012250  0100      
00012252  6404      22547            BCC.S     FSFNRM              BRANCH NO OVERFLOW
00012254  E296      22548            ROXR.L    #1,D6               ADJUST BACK FOR BIT IN 31
00012256  5204      22549            ADDQ.B    #1,D4               MAKE UP FOR LAST SHIFT RIGHT
00012258  1C04      22550   FSFNRM   MOVE.B    D4,D6               INSERT SIGN+EXPONENT
0001225A  4E75      22551   FSFRTN   RTS                           RETURN TO CALLER
