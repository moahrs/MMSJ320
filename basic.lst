                    20767   ***********************************************
                    20768   *                  FFPARND                    *
                    20769   *           ASCII ROUND SUBROUTINE            *
                    20770   *                                             *
                    20771   *  THIS ROUTINE IS NORMALLY CALLED AFTER THE  *
                    20772   *  'FFPFPA' FLOAT TO ASCII ROUTINE AND ACTS   *
                    20773   *  UPON ITS RESULTS.                          *
                    20774   *                                             *
                    20775   *  INPUT:  D6 - ROUNDING MAGNITUDE IN BINARY  *
                    20776   *               AS EXPLAINED BELOW.           *
                    20777   *          D7 - BINARY REPRESENTATION OF THE  *
                    20778   *               BASE 10 EXPONENT.             *
                    20779   *          SP ->  RETURN ADDRESS AND OUTPUT   *
                    20780   *                 FROM FFPFPA ROUTINE         *
                    20781   *                                             *
                    20782   *  OUTPUT: THE ASCII VALUE ON THE STACK IS    *
                    20783   *          CORRECTLY ROUNDED                  *
                    20784   *                                             *
                    20785   *          THE CONDITION CODES ARE UNDEFINED  *
                    20786   *                                             *
                    20787   *          ALL REGISTERS TRANSPARENT          *
                    20788   *                                             *
                    20789   *     THE ROUNDING PRECISION REPRESENTS THE   *
                    20790   *     POWER OF TEN TO WHICH THE ROUNDING WILL *
                    20791   *     OCCUR.  (I.E. A -2 MEANS ROUND THE DIGIT*
                    20792   *     IN THE HUNDREDTH POSITION FOR RESULTANT *
                    20793   *     ROUNDING TO TENTHS.)  A POSITIVE VALUE  *
                    20794   *     INDICATES ROUNDING TO THE LEFT OF THE   *
                    20795   *     DECIMAL POINT (0 IS UNITS, 1 IS TENS    *
                    20796   *     E.T.C.)                                 *
                    20797   *                                             *
                    20798   *     THE BASE TEN EXPONENT IN BINARY IS D7   *
                    20799   *     FROM THE 'FFPFPA' ROUTINE OR COMPUTED BY*
                    20800   *     THE CALLER.                             *
                    20801   *                                             *
                    20802   *     THE STACK CONTAINS THE RETURN ADDRESS   *
                    20803   *     FOLLOWED BY THE ASCII NUMBER AS FROM    *
                    20804   *     THE 'FFPFPA' ROUTINE.  SEE THE          *
                    20805   *     DESCRIPTION OF THAT ROUTINE FOR THE     *
                    20806   *     REQUIRED FORMAT.                        *
                    20807   *                                             *
                    20808   *  EXAMPLE:                                   *
                    20809   *                                             *
                    20810   *  INPUT PATTERN '+.98765432+01' = 9.8765432  *
                    20811   *                                             *
                    20812   *     ROUND +1 IS +.00000000+00 =  0.         *
                    20813   *     ROUND  0 IS +.10000000+02 = 10.         *
                    20814   *     ROUND -1 IS +.10000000+02 = 10.         *
                    20815   *     ROUND -2 IS +.99000000+01 =  9.9        *
                    20816   *     ROUND -3 IS +.98800000+01 =  9.88       *
                    20817   *     ROUND -6 IS +.98765400+01 =  9.87654    *
                    20818   *                                             *
                    20819   *  NOTES:                                     *
                    20820   *     1) IF THE ROUNDING DIGIT IS TO THE LEFT *
                    20821   *        OF THE MOST SIGNIFICANT DIGIT, A ZERO*
                    20822   *        RESULTS.  IF THE ROUNDING DIGIT IS TO*
                    20823   *        THE RIGHT OF THE LEAST SIGNIFICANT   *
                    20824   *        DIGIT, THEN NO ROUNDING OCCURS       *
                    20825   *     2) ROUNDING IS HANDY FOR ELIMINATING THE*
                    20826   *        DANGLING '999...' PROBLEM COMMON WITH*
                    20827   *        FLOAT TO DECIMAL CONVERSIONS.        *
                    20828   *     3) POSITIONS FROM THE ROUNDED DIGIT AND *
                    20829   *        TO THE RIGHT ARE SET TO ZEROES.      *
                    20830   *     4) THE EXPONENT MAY BE AFFECTED.        *
                    20831   *     5) ROUNDING IS FORCED BY ADDING FIVE.   *
                    20832   *     6) THE BINARY EXPONENT IN D7 MAY BE     *
                    20833   *        PRE-BIASED BY THE CALLER TO PROVIDE  *
                    20834   *        ENHANCED EDITING CONTROL.            *
                    20835   *     7) THE RETURN ADDRESS IS REMOVED FROM   *
                    20836   *        THE STACK UPON EXIT.                 *
                    20837   ***********************************************
                    20838   
                    20839   
000119B6  48E7 0180 20840   FFPARND  MOVEM.L   D7/A0,-(SP)         SAVE WORK ON STACK
000119BA  9E46      20841            SUB.W     D6,D7               COMPUTE ROUNDING DIGIT OFFSET
000119BC  6F18      20842            BLE.S     FAFZRO              BRANCH IF LARGER THAN VALUE
000119BE  0C47 0008 20843            CMP.W     #8,D7               INSURE NOT PAST LAST DIGIT
000119C2  6200 008E 20844            BHI       FARTN               RETURN IF SO
000119C6  41F7 780D 20845            LEA       8+4+1(SP,D7),A0       POINT TO ROUNDING DIGIT
000119CA  0C10 0035 20846            CMP.B     #'5',(A0)           ? MUST ROUND UP
000119CE  641A      20847            BCC.S     FADORND             YEP - GO ROUND
000119D0  5347      20848            SUBQ.W    #1,D7               ? ROUND LEADING DIGIT ZERO (D7=1)
000119D2  6600 0072 20849            BNE       FAZEROL             NOPE, JUST ZERO OUT
000119D6  41EF 000E 20850   FAFZRO   LEA       8+4+2(SP),A0        FORCE ZEROES ALL THE WAY ACROSS
000119DA  2F7C 452B 20851            MOVE.L    #'E+00',8+4+10(SP)  FORCE ZERO EXPONENT
000119DE  3030 0016 
000119E2  1F7C 002B 20852            MOVE.B    #'+',8+4(SP)        ZERO IS ALWAYS POSITIVE
000119E6  000C      
000119E8  605C      20853            BRA.S     FAZEROL            ZERO MANTISSA THEN RETURN
                    20854   
                    20855   * ROUND UP MUST OCCUR
000119EA  2F08      20856   FADORND  MOVE.L    A0,-(SP)            SAVE ZERO START ADDRESS ON STACK
000119EC  0C20 002E 20857   FACARRY  CMP.B     #'.',-(A0)          ? HIT BEGINNING
000119F0  670E      20858            BEQ.S     FASHIFT             YES, MUST SHIFT DOWN
000119F2  5210      20859            ADDQ.B    #1,(A0)             UP BY ONE
000119F4  0C10 003A 20860            CMP.B     #'9'+1,(A0)         ? PAST NINE
000119F8  664A      20861            BNE.S     FAZERO              NO, NOW ZERO THE END
000119FA  10BC 0030 20862            MOVE.B    #'0',(A0)           FORCE ZERO FOR OVERFLOW
000119FE  60EC      20863            BRA       FACARRY             LOOP FOR CARRY
                    20864   
                    20865   * OVERFLOW PAST TOP DIGIT - SHIFT RIGHT AND UP EXPONENT
00011A00  5297      20866   FASHIFT  ADDQ.L    #1,(SP)             ZERO PADD STARTS ONE LOWER NOW
00011A02  5288      20867            ADDQ.L    #1,A0               BACK TO LEADING DIGIT
00011A04  7E31      20868            MOVEQ     #$31,D7             DEFAULT FIRST DIGIT ASCII ONE
00011A06  4847      20869            SWAP.W    D7                  INITIALIZE OLD DIGIT
00011A08  1E10      20870            MOVE.B    (A0),D7             PRE-LOAD CURRENT DIGIT
00011A0A  4847      20871   FASHFTR  SWAP.W    D7                  TO PREVIOUS DIGIT
00011A0C  10C7      20872            MOVE.B    D7,(A0)+            STORE INTO THIS POSITION
00011A0E  1E10      20873            MOVE.B    (A0),D7             LOAD UP NEXT DIGIT
00011A10  0C07 0045 20874            CMP.B     #'E',D7             ? THE END
00011A14  66F4      20875            BNE.S     FASHFTR             NO, SHIFT ANOTHER TO THE RIGHT
                    20876   
                    20877   * INCREMENT EXPONENT FOR SHIFT RIGHT
00011A16  0C28 002B 20878            CMP.B     #'+',1(A0)          ? POSITIVE EXPONENT
00011A1A  0001      
00011A1C  5688      20879            ADDQ.L    #3,A0               POINT TO LEAST EXP DIGIT
00011A1E  660C      20880            BNE.S     FANGEXP             BRANCH NEGATIVE EXPONENT
00011A20  5210      20881            ADDQ.B    #1,(A0)             ADD ONE TO EXPONENT
00011A22  0C10 003A 20882            CMP.B     #'9'+1,(A0)         ? OVERFLOW PAST NINE
00011A26  661C      20883            BNE.S     FAZERO              NO, NOW ZERO
00011A28  5220      20884            ADDQ.B    #1,-(A0)            CARRY TO NEXT DIGIT
00011A2A  6018      20885            BRA.S     FAZERO              AND NOW ZERO END
00011A2C  0C68 3031 20886   FANGEXP  CMP.W     #'01',-1(A0)        ? GOING FROM -1 TO +0
00011A30  FFFF      
00011A32  6606      20887            BNE.S     FANGOK              BRANCH IF NOT
00011A34  117C 002B 20888            MOVE.B    #'+',-2(A0)         CHANGE MINUS TO PLUS
00011A38  FFFE      
00011A3A  5310      20889   FANGOK   SUBQ.B    #1,(A0)             SUBTRACT ONE FROM EXPONENT
00011A3C  0C10 002F 20890            CMP.B     #'0'-1,(A0)         ? UNDERFLOW BELOW ZERO
00011A40  6602      20891            BNE.S     FAZERO              NO, ZERO REMAINDER
00011A42  5320      20892            SUBQ.B    #1,-(A0)            BORROW FROM NEXT DIGIT
                    20893   
                    20894   * ZERO THE DIGITS PAST PRECISION REQUIRED
00011A44  205F      20895   FAZERO   MOVE.L    (SP)+,A0            RELOAD SAVED PRECISION
00011A46  0C10 0045 20896   FAZEROL  CMP.B     #'E',(A0)           ? AT END
00011A4A  6706      20897            BEQ.S     FARTN               BRANCH IF SO
00011A4C  10FC 0030 20898            MOVE.B    #'0',(A0)+          ZERO NEXT DIGIT
00011A50  60F4      20899            BRA.S     FAZEROL             AND TEST AGAIN
                    20900   
                    20901   * RETURN TO THE CALLER
00011A52  4CDF 0180 20902   FARTN    MOVEM.L   (SP)+,D7/A0         RESTORE REGISTERS
00011A56  4E75      20903            RTS                           RETURN TO CALLER
                    20904   ***************************************
                    20905   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    20906   ***************************************
                    20907   
                    20908   *************************************************
                    20909   *                  FFPATAN                      *
                    20910   *       FAST FLOATING POINT ARCTANGENT          *
                    20911   *                                               *
                    20912   *  INPUT:   D7 - INPUT ARGUMENT                 *
                    20913   *                                               *
                    20914   *  OUTPUT:  D7 - ARCTANGENT RADIAN RESULT       *
                    20915   *                                               *
                    20916   *     ALL OTHER REGISTERS TOTALLY TRANSPARENT   *
                    20917   *                                               *
                    20918   *  CODE SIZE: 132 BYTES   STACK WORK: 32 BYTES  *
                    20919   *                                               *
                    20920   *  CONDITION CODES:                             *
                    20921   *        Z - SET IF THE RESULT IS ZERO          *
                    20922   *        N - CLEARED                            *
                    20923   *        V - CLEARED                            *
                    20924   *        C - UNDEFINED                          *
                    20925   *        X - UNDEFINED                          *
                    20926   *                                               *
                    20927   *                                               *
                    20928   *  NOTES:                                       *
                    20929   *    1) SPOT CHECKS SHOW AT LEAST SIX DIGIT     *
                    20930   *       PRECISION ON ALL SAMPLED CASES.         *
                    20931   *                                               *
                    20932   *  TIME: (8MHZ NO WAIT STATES ASSUMED)          *
                    20933   *                                               *
                    20934   *        THE TIME IS VERY DATA SENSITIVE WITH   *
                    20935   *        SAMPLE VALUES RANGING FROM 238 TO      *
                    20936   *        465 MICROSECONDS                       *
                    20937   *                                               *
                    20938   *************************************************
                    20939   
                    20940   
                    20941   
                    20942   
          C90F DB41 20943   PIOV2    EQU       $C90FDB41           FLOAT PI/2
          8000 0041 20944   FPONEAT  EQU       $80000041           FLOAT 1
                    20945   
                    20946   ********************
                    20947   * ARCTANGENT ENTRY *
                    20948   ********************
                    20949   
                    20950   * SAVE REGISTERS AND PERFORM ARGUMENT REDUCTION
00011A58  48E7 7E80 20951   FFPATAN  MOVEM.L   D1-D6/A0,-(SP)      SAVE CALLER'S REGISTERS
00011A5C  1F07      20952            MOVE.B    D7,-(SP)            SAVE ORIGINAL SIGN ON STACK
00011A5E  CE3C 007F 20953            AND.B     #$7F,D7             TAKE ABSOLUTE VALUE OF ARG
                    20954   * INSURE LESS THAN ONE FOR CORDIC LOOP
00011A62  2C3C 8000 20955            MOVE.L    #FPONEAT,D6           LOAD UP 1
00011A66  0041      
00011A68  4227      20956            CLR.B     -(SP)               DEFAULT NO INVERSE REQUIRED
00011A6A  BE06      20957            CMP.B     D6,D7               ? LESS THAN ONE
00011A6C  650E      20958            BCS.S     FPAINRG             BRANCH IN RANGE
00011A6E  6204      20959            BHI.S     FPARDC              HIGHER - MUST REDUCE
00011A70  BE86      20960            CMP.L     D6,D7               ? LESS OR EQUAL TO ONE
00011A72  6308      20961            BLS.S     FPAINRG             BRANCH YES, IS IN RANGE
                    20962   * ARGUMENT > 1:  ATAN(1/X) =  PI/2 - ATAN(X)
00011A74  4617      20963   FPARDC   NOT.B     (SP)                FLAG INVERSE TAKEN
00011A76  CD47      20964            EXG.L     D6,D7               TAKE INVERSE OF ARGUMENT
00011A78  6100 00A8 20965            BSR       FFPDIV              PERFORM DIVIDE
                    20966   
                    20967   * PERFORM CORDIC FUNCTION
                    20968   * CONVERT TO BIN(31,29) PRECISION
00011A7C  0407 0043 20969   FPAINRG  SUB.B     #64+3,D7            ADJUST EXPONENT
00011A80  4407      20970            NEG.B     D7                  FOR SHIFT NECESSARY
00011A82  0C07 001F 20971            CMP.B     #31,D7              ? TOO SMALL TO WORRY ABOUT
00011A86  6304      20972            BLS.S     FPANOTZ             BRANCH IF NOT TOO SMALL
00011A88  7C00      20973            MOVEQ     #0,D6               CONVERT TO A ZERO
00011A8A  6034      20974            BRA.S     FPAZROz             BRANCH IF ZERO
00011A8C  EEAF      20975   FPANOTZ  LSR.L     D7,D7               SHIFT TO BIN(31,29) PRECISION
                    20976   
                    20977   *****************************************
                    20978   * CORDIC CALCULATION REGISTERS:         *
                    20979   * D1 - LOOP COUNT   A0 - TABLE POINTER  *
                    20980   * D2 - SHIFT COUNT                      *
                    20981   * D3 - Y'   D5 - Y                      *
                    20982   * D4 - X'   D6 - Z                      *
                    20983   * D7 - X                                *
                    20984   *****************************************
                    20985   
00011A8E  7C00      20986            MOVEQ     #0,D6               Z=0
00011A90  2A3C 2000 20987            MOVE.L    #1<<29,D5           Y=1
00011A94  0000      
00011A96  41FA 0726 20988            LEA       (FFPTHETA+4,PC),A0  TO ARCTANGENT TABLE
00011A9A  7218      20989            MOVEQ     #24,D1              LOOP 25 TIMES
00011A9C  7401      20990            MOVEQ     #1,D2               PRIME SHIFT COUNTER
00011A9E  6006      20991            BRA.S     CORDIC              ENTER CORDIC LOOP
                    20992   
                    20993   * CORDIC LOOP
00011AA0  E4A4      20994   FPLPLS   ASR.L     D2,D4               SHIFT(X')
00011AA2  DA84      20995            ADD.L     D4,D5               Y = Y + X'
00011AA4  DC90      20996            ADD.L     (A0),D6             Z = Z + ARCTAN(I)
00011AA6  2807      20997   CORDIC   MOVE.L    D7,D4               X' = X
00011AA8  2605      20998            MOVE.L    D5,D3               Y' = Y
00011AAA  E4A3      20999            ASR.L     D2,D3               SHIFT(Y')
00011AAC  9E83      21000   FPLNLP   SUB.L     D3,D7               X = X - Y'
00011AAE  6AF0      21001            BPL.S     FPLPLS              BRANCH NEGATIVE
00011AB0  2E04      21002            MOVE.L    D4,D7               RESTORE X
00011AB2  5888      21003            ADDQ.L    #4,A0               TO NEXT TABLE ENTRY
00011AB4  5202      21004            ADDQ.B    #1,D2               INCREMENT SHIFT COUNT
00011AB6  E28B      21005            LSR.L     #1,D3               SHIFT(Y')
00011AB8  51C9 FFF2 21006            DBRA      D1,FPLNLP           AND LOOP UNTIL DONE
                    21007   
                    21008   * NOW CONVERT TO FLOAT AND RECONSTRUCT THE RESULT
00011ABC  6100 0768 21009            BSR       FFPTNORM            FLOAT Z
00011AC0  2E06      21010   FPAZROz  MOVE.L    D6,D7               COPY ANSWER TO D7
00011AC2  4A1F      21011            TST.B     (SP)+               ? WAS INVERSE TAKEN
00011AC4  670A      21012            BEQ.S     FPANINV             BRANCH IF NOT
00011AC6  2E3C C90F 21013            MOVE.L    #PIOV2,D7           TAKE AWAY FROM PI OVER TWO
00011ACA  DB41      
00011ACC  6100 FE04 21014            BSR       FFPSUB              SUBTRACT
00011AD0  1C1F      21015   FPANINV  MOVE.B    (SP)+,D6            LOAD ORIGINAL SIGN
00011AD2  4A07      21016            TST.B     D7                  ? RESULT ZERO
00011AD4  6706      21017            BEQ.S     FPARTN              RETURN IF SO
00011AD6  CC3C 0080 21018            AND.B     #$80,D6             CLEAR EXPONENT PORTION
00011ADA  8E06      21019            OR.B      D6,D7               IF MINUS, GIVE MINUS RESULT
00011ADC  4CDF 017E 21020   FPARTN   MOVEM.L   (SP)+,D1-D6/A0      RESTORE CALLER'S REGISTERS
00011AE0  4E75      21021            RTS                           RETURN TO CALLER
                    21022   ***************************************
                    21023   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    21024   ***************************************
                    21025   
                    21026   *************************************************************
                    21027   *                      FFPCMP                               *
                    21028   *              FAST FLOATING POINT COMPARE                  *
                    21029   *                                                           *
                    21030   *  INPUT:  D6 - FAST FLOATING POINT ARGUMENT (SOURCE)       *
                    21031   *          D7 - FAST FLOATING POINT ARGUMENT (DESTINATION)  *
                    21032   *                                                           *
                    21033   *  OUTPUT: CONDITION CODE REFLECTING THE FOLLOWING BRANCHES *
                    21034   *          FOR THE RESULT OF COMPARING THE DESTINATION      *
                    21035   *          MINUS THE SOURCE:                                *
                    21036   *                                                           *
                    21037   *                  GT - DESTINATION GREATER                 *
                    21038   *                  GE - DESTINATION GREATER OR EQUAL TO     *
                    21039   *                  EQ - DESTINATION EQUAL                   *
                    21040   *                  NE - DESTINATION NOT EQUAL               *
                    21041   *                  LT - DESTINATION LESS THAN               *
                    21042   *                  LE - DESTINATION LESS THAN OR EQUAL TO   *
                    21043   *                                                           *
                    21044   *      CONDITION CODES:                                     *
                    21045   *              N - CLEARED                                  *
                    21046   *              Z - SET IF RESULT IS ZERO                    *
                    21047   *              V - CLEARED                                  *
                    21048   *              C - UNDEFINED                                *
                    21049   *              X - UNDEFINED                                *
                    21050   *                                                           *
                    21051   *               ALL REGISTERS TRANSPARENT                   *
                    21052   *                                                           *
                    21053   *************************************************************
                    21054   
                    21055   
                    21056   ***********************
                    21057   * COMPARE ENTRY POINT *
                    21058   ***********************
00011AE2  4A06      21059   FFPCMP   TST.B     D6        ? FIRST NEGATIVE
00011AE4  6A0C      21060            BPL.S     FFPCP     NO FIRST IS POSITIVE
00011AE6  4A07      21061            TST.B     D7        ? SECOND NEGATIVE
00011AE8  6A08      21062            BPL.S     FFPCP     NO, ONE IS POSITIVE
                    21063   * IF BOTH NEGATIVE THEN COMPARE MUST BE DONE BACKWARDS
00011AEA  BC07      21064            CMP.B     D7,D6     COMPARE SIGN AND EXPONENT ONLY FIRST
00011AEC  660A      21065            BNE.S     FFPCRTN   RETURN IF THAT IS SUFFICIENT
00011AEE  BC87      21066            CMP.L     D7,D6     COMPARE REVERSE ORDER IF BOTH NEGATIVE
00011AF0  4E75      21067            RTS                 RETURN TO CALLER
00011AF2  BE06      21068   FFPCP    CMP.B     D6,D7     COMPARE SIGN AND EXPONENT ONLY FIRST
00011AF4  6602      21069            BNE.S     FFPCRTN   RETURN IF THAT IS SUFFICIENT
00011AF6  BE86      21070            CMP.L     D6,D7     NO, COMPARE FULL LONGWORDS THEN
00011AF8  4E75      21071   FFPCRTN  RTS                 AND RETURN TO THE CALLER
                    21072   
                    21073   *************************************************************
                    21074   *                     FFPTST                                *
                    21075   *           FAST FLOATING POINT TEST                        *
                    21076   *                                                           *
                    21077   *  INPUT:  D7 - FAST FLOATING POINT ARGUMENT                *
                    21078   *                                                           *
                    21079   *  OUTPUT: CONDITION CODES SET FOR THE FOLLOWING BRANCHES:  *
                    21080   *                                                           *
                    21081   *                  EQ - ARGUMENT EQUALS ZERO                *
                    21082   *                  NE - ARGUMENT NOT EQUAL ZERO             *
                    21083   *                  PL - ARGUMENT IS POSITIVE (INCLUDES ZERO)*
                    21084   *                  MI - ARGUMENT IS NEGATIVE                *
                    21085   *                                                           *
                    21086   *      CONDITION CODES:                                     *
                    21087   *              N - SET IF RESULT IS NEGATIVE                *
                    21088   *              Z - SET IF RESULT IS ZERO                    *
                    21089   *              V - CLEARED                                  *
                    21090   *              C - UNDEFINED                                *
                    21091   *              X - UNDEFINED                                *
                    21092   *                                                           *
                    21093   *               ALL REGISTERS TRANSPARENT                   *
                    21094   *                                                           *
                    21095   *************************************************************
                    21096   
                    21097   ********************
                    21098   * TEST ENTRY POINT *
                    21099   ********************
00011AFA  4A07      21100   FFPTST   TST.B     D7        RETURN TESTED CONDITION CODE
00011AFC  4E75      21101            RTS                 TO CALLER
                    21102   *****************************************
                    21103   *  (C) COPYRIGHT 1980 BY MOTOROLA INC.  *
                    21104   *****************************************
                    21105   
                    21106   ********************************************
                    21107   *           FFPDIV SUBROUTINE              *
                    21108   *                                          *
                    21109   * INPUT:                                   *
                    21110   *        D6 - FLOATING POINT DIVISOR       *
                    21111   *        D7 - FLOATING POINT DIVIDEND      *
                    21112   *                                          *
                    21113   * OUTPUT:                                  *
                    21114   *        D7 - FLOATING POINT QUOTIENT      *
                    21115   *                                          *
                    21116   * CONDITION CODES:                         *
                    21117   *        N - SET IF RESULT NEGATIVE        *
                    21118   *        Z - SET IF RESULT ZERO            *
                    21119   *        V - SET IF RESULT OVERFLOWED      *
                    21120   *        C - UNDEFINED                     *
                    21121   *        X - UNDEFINED                     *
                    21122   *                                          *
                    21123   * REGISTERS D3 THRU D5 VOLATILE            *
                    21124   *                                          *
                    21125   * CODE: 150 BYTES     STACK WORK: 0 BYTES  *
                    21126   *                                          *
                    21127   * NOTES:                                   *
                    21128   *   1) DIVISOR IS UNALTERED (D6).          *
                    21129   *   2) UNDERFLOWS RETURN ZERO WITHOUT      *
                    21130   *      ANY INDICATORS SET.                 *
                    21131   *   3) OVERFLOWS RETURN THE HIGHEST VALUE  *
                    21132   *      WITH THE PROPER SIGN AND THE 'V'    *
                    21133   *      BIT SET IN THE CCR.                 *
                    21134   *   4) IF A DIVIDE BY ZERO IS ATTEMPTED    *
                    21135   *      THE DIVIDE BY ZERO EXCEPTION TRAP   *
                    21136   *      IS FORCED BY THIS CODE WITH THE     *
                    21137   *      ORIGINAL ARGUMENTS INTACT.  IF THE  *
                    21138   *      EXCEPTION RETURNS WITH THE DENOM-   *
                    21139   *      INATOR ALTERED THE DIVIDE OPERATION *
                    21140   *      CONTINUES, OTHERWISE AN OVERFLOW    *
                    21141   *      IS FORCED WITH THE PROPER SIGN.     *
                    21142   *      THE FLOATING DIVIDE BY ZERO CAN BE  *
                    21143   *      DISTINGUISHED FROM TRUE ZERO DIVIDE *
                    21144   *      BY THE FACT THAT IT IS AN IMMEDIATE *
                    21145   *      ZERO DIVIDING INTO REGISTER D7.     *
                    21146   *                                          *
                    21147   * TIME: (8 MHZ NO WAIT STATES ASSUMED)     *
                    21148   * DIVIDEND ZERO         5.250 MICROSECONDS *
                    21149   * MINIMUM TIME OTHERS  72.750 MICROSECONDS *
                    21150   * MAXIMUM TIME OTHERS  85.000 MICROSECONDS *
                    21151   * AVERAGE OTHERS       76.687 MICROSECONDS *
                    21152   *                                          *
                    21153   ********************************************
                    21154   
                    21155   
                    21156   * DIVIDE BY ZERO EXIT
00011AFE  8EFC 0000 21157   FPDDZR DIVU.W #0,D7     **FORCE DIVIDE BY ZERO **
                    21158   
                    21159   * IF THE EXCEPTION RETURNS WITH ALTERED DENOMINATOR - CONTINUE DIVIDE
00011B02  4A86      21160          TST.L     D6        ? EXCEPTION ALTER THE ZERO
00011B04  661C      21161          BNE.S     FFPDIV    BRANCH IF SO TO CONTINUE
                    21162   * SETUP MAXIMUM NUMBER FOR DIVIDE OVERFLOW
00011B06  8EBC FFFF 21163   FPDOVF OR.L      #$FFFFFF7F,D7 MAXIMIZE WITH PROPER SIGN
00011B0A  FF7F      
00011B0C  4A07      21164          TST.B     D7        SET CONDITION CODE FOR SIGN
00011B0E  003C 0002 21165          OR.B      #$02,CCR  SET OVERFLOW BIT
00011B12  4E75      21166   FPDRTN RTS                 RETURN TO CALLER
                    21167   
                    21168   * OVER OR UNDERFLOW DETECTED
00011B14  4846      21169   FPDOV2 SWAP.W    D6        RESTORE ARG1
00011B16  4847      21170          SWAP.W    D7        RESTORE ARG2 FOR SIGN
00011B18  BD07      21171   FPDOVFS EOR.B    D6,D7     SETUP CORRECT SIGN
00011B1A  60EA      21172          BRA.S     FPDOVF    AND ENTER OVERFLOW HANDLING
00011B1C  6BFA      21173   FPDOUF BMI.S     FPDOVFS   BRANCH IF OVERFLOW
00011B1E  7E00      21174   FPDUND MOVEQ     #0,D7     UNDERFLOW TO ZERO
00011B20  4E75      21175          RTS                 AND RETURN TO CALLER
                    21176   
                    21177   ***************
                    21178   * ENTRY POINT *
                    21179   ***************
                    21180   
                    21181   * FIRST SUBTRACT EXPONENTS
00011B22  1A06      21182   FFPDIV MOVE.B D6,D5     COPY ARG1 (DIVISOR)
00011B24  67D8      21183          BEQ.S  FPDDZR    BRANCH IF DIVIDE BY ZERO
00011B26  2807      21184          MOVE.L D7,D4     COPY ARG2 (DIVIDEND)
00011B28  67E8      21185          BEQ.S  FPDRTN    RETURN ZERO IF DIVIDEND ZERO
00011B2A  7680      21186          MOVEQ  #-128,D3  SETUP SIGN MASK
00011B2C  DA45      21187          ADD.W  D5,D5     ISOLATE ARG1 SIGN FROM EXPONENT
00011B2E  D844      21188          ADD.W  D4,D4     ISOLATE ARG2 SIGN FROM EXPONENT
00011B30  B705      21189          EOR.B  D3,D5     ADJUST ARG1 EXPONENT TO BINARY
00011B32  B704      21190          EOR.B  D3,D4     ADJUST ARG2 EXPONENT TO BINARY
00011B34  9805      21191          SUB.B  D5,D4     SUBTRACT EXPONENTS
00011B36  69E4      21192          BVS.S  FPDOUF    BRANCH IF OVERFLOW/UNDERFLOW
00011B38  4207      21193          CLR.B  D7        CLEAR ARG2 S+EXP
00011B3A  4847      21194          SWAP.W D7        PREPARE HIGH 16 BIT COMPARE
00011B3C  4846      21195          SWAP.W D6        AGAINST ARG1 AND ARG2
00011B3E  BE46      21196          CMP.W  D6,D7     ? CHECK IF OVERFLOW WILL OCCUR
00011B40  6B06      21197          BMI.S  FPDNOV    BRANCH IF NOT
                    21198   * ADJUST FOR FIXED POINT DIVIDE OVERFLOW
00011B42  5404      21199          ADDQ.B #2,D4     ADJUST EXPONENT UP ONE
00011B44  69CE      21200          BVS.S  FPDOV2    BRANCH OVERFLOW HERE
00011B46  E29F      21201          ROR.L  #1,D7     SHIFT DOWN BY POWER OF TWO
00011B48  4847      21202   FPDNOV SWAP.W D7        CORRECT ARG2
00011B4A  1A03      21203          MOVE.B D3,D5     MOVE $80 INTO D5.B
00011B4C  BB44      21204          EOR.W  D5,D4     CREATE SIGN AND ABSOLUTIZE EXPONENT
00011B4E  E24C      21205          LSR.W  #1,D4     D4.B NOW HAS SIGN+EXPONENT OF RESULT
                    21206   
                    21207   * NOW DIVIDE JUST USING 16 BITS INTO 24
00011B50  2607      21208          MOVE.L D7,D3     COPY ARG1 FOR INITIAL DIVIDE
00011B52  86C6      21209          DIVU.W D6,D3     OBTAIN TEST QUOTIENT
00011B54  3A03      21210          MOVE.W D3,D5     SAVE TEST QUOTIENT
                    21211   
                    21212   * NOW MULTIPLY 16-BIT DIVIDE RESULT TIMES FULL 24 BIT DIVISOR AND COMPARE
                    21213   * WITH THE DIVIDEND.  MULTIPLYING BACK OUT WITH THE FULL 24-BITS ALLOWS
                    21214   * US TO SEE IF THE RESULT WAS TOO LARGE DUE TO THE 8 MISSING DIVISOR BITS
                    21215   * USED IN THE HARDWARE DIVIDE.  THE RESULT CAN ONLY BE TOO LARGE BY 1 UNIT.
00011B56  C6C6      21216          MULU.W D6,D3     HIGH DIVISOR X QUOTIENT
00011B58  9E83      21217          SUB.L  D3,D7     D7=PARTIAL SUBTRACTION
00011B5A  4847      21218          SWAP.W D7        TO LOW DIVISOR
00011B5C  4846      21219          SWAP.W D6        REBUILD ARG1 TO NORMAL
00011B5E  3606      21220          MOVE.W D6,D3     SETUP ARG1 FOR PRODUCT
00011B60  4203      21221          CLR.B  D3        ZERO LOW BYTE
00011B62  C6C5      21222          MULU.W D5,D3     FIND REMAINING PRODUCT
00011B64  9E83      21223          SUB.L  D3,D7     NOW HAVE FULL SUBTRACTION
00011B66  6408      21224          BCC.S  FPDQOK    BRANCH FIRST 16 BITS CORRECT
                    21225   
                    21226   * ESTIMATE TOO HIGH, DECREMENT QUOTIENT BY ONE
00011B68  2606      21227          MOVE.L D6,D3     REBUILD DIVISOR
00011B6A  4203      21228          CLR.B  D3        REVERSE HALVES
00011B6C  DE83      21229          ADD.L  D3,D7     ADD ANOTHER DIVISOR
00011B6E  5345      21230          SUBQ.W #1,D5     DECREMENT QUOTIENT
                    21231   
                    21232   * COMPUTE LAST 8 BITS WITH ANOTHER DIVIDE.  THE EXACT REMAINDER FROM THE
                    21233   * MULTIPLY AND COMPARE ABOVE IS DIVIDED AGAIN BY A 16-BIT ONLY DIVISOR.
                    21234   * HOWEVER, THIS TIME WE REQUIRE ONLY 9 BITS OF ACCURACY IN THE RESULT
                    21235   * (8 TO MAKE 24 BITS TOTAL AND 1 EXTRA BIT FOR ROUNDING PURPOSES) AND THIS
                    21236   * DIVIDE ALWAYS RETURNS A PRECISION OF AT LEAST 9 BITS.
00011B70  2606      21237   FPDQOK MOVE.L D6,D3     COPY ARG1 AGAIN
00011B72  4843      21238          SWAP.W D3        FIRST 16 BITS DIVISOR IN D3.W
00011B74  4247      21239          CLR.W  D7        INTO FIRST 16 BITS OF DIVIDEND
00011B76  8EC3      21240          DIVU.W D3,D7     OBTAIN FINAL 16 BIT RESULT
00011B78  4845      21241          SWAP.W D5        FIRST 16 QUOTIENT TO HIGH HALF
00011B7A  6B08      21242          BMI.S  FPDISN    BRANCH IF NORMALIZED
                    21243   * RARE OCCURRANCE - UNNORMALIZED
                    21244   * HAPPENDS WHEN MANTISSA ARG1 < ARG2 AND THEY DIFFER ONLY IN LAST 8 BITS
00011B7C  3A07      21245          MOVE.W D7,D5     INSERT LOW WORD OF QUOTIENT
00011B7E  DA85      21246          ADD.L  D5,D5     SHIFT MANTISSA LEFT ONE
00011B80  5304      21247          SUBQ.B #1,D4     ADJUST EXPONENT DOWN (CANNOT ZERO)
00011B82  3E05      21248          MOVE.W D5,D7     CANCEL NEXT INSTRUCTION
                    21249   
                    21250   * REBUILD OUR FINAL RESULT AND RETURN
00011B84  3A07      21251   FPDISN MOVE.W D7,D5     APPEND NEXT 16 BITS
00011B86  0685 0000 21252          ADD.L  #$80,D5   ROUND TO 24 BITS (CANNOT OVERFLOW)
00011B8A  0080      
00011B8C  2E05      21253          MOVE.L D5,D7     RETURN IN D7
00011B8E  1E04      21254          MOVE.B D4,D7     FINISH RESULT WITH SIGN+EXPONENT
00011B90  678C      21255          BEQ.S  FPDUND    UNDERFLOW IF ZERO EXPONENT
00011B92  4E75      21256          RTS              RETURN RESULT TO CALLER
                    21257   ***************************************
                    21258   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    21259   ***************************************
                    21260   
                    21261   *************************************************
                    21262   *                  FFPEXP                       *
                    21263   *       FAST FLOATING POINT EXPONENT            *
                    21264   *                                               *
                    21265   *  INPUT:   D7 - INPUT ARGUMENT                 *
                    21266   *                                               *
                    21267   *  OUTPUT:  D7 - EXPONENTIAL RESULT             *
                    21268   *                                               *
                    21269   *     ALL OTHER REGISTERS ARE TRANSPARENT       *
                    21270   *                                               *
                    21271   *  CODE SIZE: 256 BYTES   STACK WORK: 34 BYTES  *
                    21272   *                                               *
                    21273   *  CONDITION CODES:                             *
                    21274   *        Z - SET IF RESULT IN D7 IS ZERO        *
                    21275   *        N - CLEARED                            *
                    21276   *        V - SET IF OVERLOW OCCURRED            *
                    21277   *        C - UNDEFINED                          *
                    21278   *        X - UNDEFINED                          *
                    21279   *                                               *
                    21280   *                                               *
                    21281   *  NOTES:                                       *
                    21282   *    1) AN OVERFLOW RETURNS THE LARGEST         *
                    21283   *       MAGNITUDE NUMBER.                       *
                    21284   *    2) SPOT CHECKS SHOW AT LEAST 6.8 DIGIT     *
                    21285   *       ACCURACY FOR ALL ABS(ARG) < 30.         *
                    21286   *                                               *
                    21287   *  TIME: (8MHZ NO WAIT STATES ASSUMED)          *
                    21288   *                                               *
                    21289   *              488 MICROSECONDS                 *
                    21290   *                                               *
                    21291   *  LOGIC:   1) FIND N = INT(ARG/LN 2).  THIS IS *
                    21292   *              ADDED TO THE MANTISSA AT THE END.*
                    21293   *           3) REDUCE ARGUMENT TO RANGE BY      *
                    21294   *              FINDING ARG = MOD(ARG, LN 2).    *
                    21295   *           4) DERIVE EXP(ARG) WITH CORDIC LOOP.*
                    21296   *           5) ADD N TO EXPONENT GIVING RESULT. *
                    21297   *                                               *
                    21298   *************************************************
                    21299   
                    21300   
                    21301   
                    21302   
          B172 1840 21303   LN2      EQU       $B1721840           LN 2 (BASE E)             .693147180
          B8AA 3B41 21304   LN2INV   EQU       $B8AA3B41           INVERSE OF LN 2 (BASE E) 1.44269504
          9A8F 4441 21305   CNJKHINV EQU       $9A8F4441           FLOATING CONJUGATE OF K INVERSE
                    21306   *                                      CORRECTED FOR THE EXTRA CONVERGENCE
                    21307   *                                      DURING SHIFTS FOR 4 AND 13
          26A3 D100 21308   KFCTSEED EQU       $26A3D100           K CORDIC SEED
                    21309   
                    21310   
                    21311   * OVERFLOW - RETURN ZERO OR HIGHEST VALUE AND "V" BIT
00011B94  3C1F      21312   FPEOVFLW MOVE.W    (SP)+,D6            LOAD SIGN WORD AND WORK OFF STACK
00011B96  4A06      21313            TST.B     D6                  ? WAS ARGUMENT NEGATIVE
00011B98  6A04      21314            BPL.S     FPOVNZRO            NO, CONTINUE
00011B9A  7E00      21315            MOVEQ     #0,D7               RETURN A ZERO
00011B9C  6008      21316            BRA.S     FPOVRTN             AS RESULT IS TOO SMALL
00011B9E  7EFF      21317   FPOVNZRO MOVEQ     #-1,D7              SET ALL ZEROES
00011BA0  E20F      21318            LSR.B     #1,D7               ZERO SIGN BIT
00011BA2  003C 0002 21319            OR.B      #$02,CCR            SET OVERFLOW BIT
00011BA6  4CDF 017E 21320   FPOVRTN  MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011BAA  4E75      21321            RTS                           RETURN TO CALLER
                    21322   
                    21323   * RETURN ONE FOR ZERO ARGUMENT
00011BAC  2E3C 8000 21324   FFPE1    MOVE.L    #$80000041,D7       RETURN A TRUE ONE
00011BB0  0041      
00011BB2  4FEF 001E 21325            LEA       7*4+2(SP),SP        IGNORE STACK SAVES
00011BB6  4A07      21326            TST.B     D7                  SET CONDITION CODE PROPERLY
00011BB8  4E75      21327            RTS                           RETURN TO CALLER
                    21328   
                    21329   **************
                    21330   * EXP ENTRY  *
                    21331   **************
                    21332   
                    21333   * SAVE WORK REGISTERS AND INSURE POSITIVE ARGUMENT
00011BBA  48E7 7E80 21334   FFPEXP   MOVEM.L   D1-D6/A0,-(SP)      SAVE ALL WORK REGISTERS
00011BBE  3F07      21335            MOVE.W    D7,-(SP)            SAVE SIGN IN LOW ORDER BYTE FOR LATER
00011BC0  67EA      21336            BEQ.S     FFPE1               RETURN A TRUE ONE FOR ZERO EXPONENT
00011BC2  CE3C 007F 21337            AND.B     #$7F,D7             TAKE ABSOLUTE VALUE
                    21338   
                    21339   * DIVIDE BY LOG 2 BASE E FOR PARTIAL RESULT
00011BC6  2407      21340   FPEPOS   MOVE.L    D7,D2               SAVE ORIGINAL ARGUMENT
00011BC8  2C3C B8AA 21341            MOVE.L    #LN2INV,D6          LOAD INVERSE TO MULTIPLY (FASTER)
00011BCC  3B41      
00011BCE  6100 0206 21342            BSR       FFPMUL2             OBTAIN DIVISION THRU MULTIPLY
00011BD2  69C0      21343            BVS       FPEOVFLW            BRANCH IF TOO LARGE
                    21344   * CONVERT QUOTIENT TO BOTH FIXED AND FLOAT INTEGER
00011BD4  1A07      21345            MOVE.B    D7,D5               COPY EXPONENT OVER
00011BD6  1C07      21346            MOVE.B    D7,D6               COPY EXPONENT OVER
00011BD8  0405 0060 21347            SUB.B     #64+32,D5           FIND NON-FRACTIONAL PRECISION
00011BDC  4405      21348            NEG.B     D5                  MAKE POSITIVE
00011BDE  0C05 0018 21349            CMP.B     #24,D5              ? INSURE NOT TOO LARGE
00011BE2  6FB0      21350            BLE.S     FPEOVFLW            BRANCH TOO LARGE
00011BE4  0C05 0020 21351            CMP.B     #32,D5              ? TEST UPPER RANGE
00011BE8  6C1E      21352            BGE.S     FPESML              BRANCH LESS THAN ONE
00011BEA  EAAF      21353            LSR.L     D5,D7               SHIFT TO INTEGER
00011BEC  1E87      21354            MOVE.B    D7,(SP)             PLACE ADJUSTED EXPONENT WITH SIGN BYTE
00011BEE  EBAF      21355            LSL.L     D5,D7               BACK TO NORMAL WITHOUT FRACTION
00011BF0  1E06      21356            MOVE.B    D6,D7               RE-INSERT SIGN+EXPONENT
00011BF2  2C3C B172 21357            MOVE.L    #LN2,D6             MULTIPLY BY LN2 TO FIND RESIDUE
00011BF6  1840      
00011BF8  6100 01DC 21358            BSR       FFPMUL2             MULTIPLY BACK OUT
00011BFC  2C07      21359            MOVE.L    D7,D6               SETUP TO SUBTRACT MULTIPLE OF LN 2
00011BFE  2E02      21360            MOVE.L    D2,D7               MOVE ARGUMENT IN
00011C00  6100 FCD0 21361            BSR       FFPSUB              FIND REMAINDER OF LN 2 DIVIDE
00011C04  2407      21362            MOVE.L    D7,D2               COPY FLOAT ARGUMENT
00011C06  6004      21363            BRA.S     FPEADJ              ADJUST TO FIXED
                    21364   
                    21365   * MULTIPLE LESS THAN ONE
00011C08  4217      21366   FPESML   CLR.B     (SP)                DEFAULT INITIAL MULTIPLY TO ZERO
00011C0A  2E02      21367            MOVE.L    D2,D7               BACK TO ORIGINAL ARGUMENT
                    21368   
                    21369   * CONVERT ARGUMENT TO BINARY(31,29) PRECISION
00011C0C  4207      21370   FPEADJ   CLR.B     D7                  CLEAR SIGN AND EXPONENT
00011C0E  0402 0043 21371            SUB.B     #64+3,D2            OBTAIN SHIFT VALUE
00011C12  4402      21372            NEG.B     D2                  FOR 2 NON-FRACTION BITS
00011C14  0C02 001F 21373            CMP.B     #31,D2              INSURE NOT TOO SMALL
00011C18  6302      21374            BLS.S     FPESHF              BRANCH TO SHIFT IF OK
00011C1A  7E00      21375            MOVEQ     #0,D7               FORCE TO ZERO
00011C1C  E4AF      21376   FPESHF   LSR.L     D2,D7               CONVERT TO FIXED POINT
                    21377   
                    21378   *****************************************
                    21379   * CORDIC CALCULATION REGISTERS:         *
                    21380   * D1 - LOOP COUNT   A0 - TABLE POINTER  *
                    21381   * D2 - SHIFT COUNT                      *
                    21382   * D3 - Y'   D5 - Y                      *
                    21383   * D4 - X'   D6 - X                      *
                    21384   * D7 - TEST ARGUMENT                    *
                    21385   *****************************************
                    21386   
                    21387   * INPUT WITHIN RANGE, NOW START CORDIC SETUP
00011C1E  7A00      21388   FPECOM   MOVEQ     #0,D5               Y=0
00011C20  2C3C 26A3 21389            MOVE.L    #KFCTSEED,D6        X=1 WITH JKHINVERSE FACTORED OUT
00011C24  D100      
00011C26  41FA 0532 21390            LEA       (FFPHTHET,PC),A0    POINT TO HPERBOLIC TANGENT TABLE
00011C2A  7400      21391            MOVEQ     #0,D2               PRIME SHIFT COUNTER
                    21392   
                    21393   * PERFORM CORDIC LOOP REPEATING SHIFTS 4 AND 13 TO GUARANTEE CONVERGENCE
                    21394   * (REF. "A UNIFIED ALGORITHM FOR ELEMENTARY FUNCTIONS" J.S.WALTHER
                    21395   *        PG. 380 SPRING JOINT COMPUTER CONFERENCE 1971)
00011C2C  7203      21396            MOVEQ     #3,D1               DO SHIFTS 1 THRU 4
00011C2E  6134      21397            BSR.S     CORDICx             FIRST CORDIC LOOPS
00011C30  5988      21398            SUBQ.L    #4,A0               REDO TABLE ENTRY
00011C32  5342      21399            SUBQ.W    #1,D2               REDO SHIFT COUNT
00011C34  7209      21400            MOVEQ     #9,D1               DO FOUR THROUGH 13
00011C36  612C      21401            BSR.S     CORDICx             SECOND CORDIC LOOPS
00011C38  5988      21402            SUBQ.L    #4,A0               BACK TO ENTRY 13
00011C3A  5342      21403            SUBQ.W    #1,D2               REDO SHIFT FOR 13
00011C3C  720A      21404            MOVEQ     #10,D1              NOW 13 THROUGH 23
00011C3E  6124      21405            BSR.S     CORDICx             AND FINISH UP
                    21406   
                    21407   * NOW FINALIZE THE RESULT
00011C40  4A2F 0001 21408            TST.B     1(SP)               TEST ORIGINAL SIGN
00011C44  6A04      21409            BPL.S     FSEPOS              BRANCH POSITIVE ARGUMENT
00011C46  4485      21410            NEG.L     D5                  CHANGE Y FOR SUBTRACTION
00011C48  4417      21411            NEG.B     (SP)                NEGATE ADJUSTED EXPONENT TO SUBTRACT
00011C4A  DC85      21412   FSEPOS   ADD.L     D5,D6               ADD OR SUBTRACT Y TO/FROM X
00011C4C  6100 05D8 21413            BSR       FFPTNORM            FLOAT X
00011C50  2E06      21414            MOVE.L    D6,D7               SETUP RESULT
                    21415   * ADD LN2 FACTOR INTEGER TO THE EXPONENT
00011C52  DE17      21416            ADD.B     (SP),D7             ADD TO EXPONENT
00011C54  6B00 FF3E 21417            BMI       FPEOVFLW            BRANCH IF TOO LARGE
00011C58  6700 FF3A 21418            BEQ       FPEOVFLW            BRANCH IF TOO SMALL
00011C5C  548F      21419            ADDQ.L    #2,SP               RID WORK DATA OFF STACK
00011C5E  4CDF 017E 21420            MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011C62  4E75      21421            RTS                           RETURN TO CALLER
                    21422   
                    21423   *************************
                    21424   * CORDIC LOOP SUBROUTINE*
                    21425   *************************
00011C64  5242      21426   CORDICx  ADDQ.W    #1,D2               INCREMENT SHIFT COUNT
00011C66  2605      21427            MOVE.L    D5,D3               COPY Y
00011C68  2806      21428            MOVE.L    D6,D4               COPY X
00011C6A  E4A3      21429            ASR.L     D2,D3               SHIFT FOR Y'
00011C6C  E4A4      21430            ASR.L     D2,D4               SHIFT FOR X'
00011C6E  4A87      21431            TST.L     D7                  TEST ARG VALUE
00011C70  6B0C      21432            BMI.S     FEBMI               BRANCH MINUS TEST
00011C72  DA84      21433            ADD.L     D4,D5               Y=Y+X'
00011C74  DC83      21434            ADD.L     D3,D6               X=X+Y'
00011C76  9E98      21435            SUB.L     (A0)+,D7            ARG=ARG-TABLE(N)
00011C78  51C9 FFEA 21436            DBRA      D1,CORDICx          LOOP UNTIL DONE
00011C7C  4E75      21437            RTS                           RETURN
                    21438   
00011C7E  9A84      21439   FEBMI    SUB.L     D4,D5               Y=Y-X'
00011C80  9C83      21440            SUB.L     D3,D6               X=X-Y'
00011C82  DE98      21441            ADD.L     (A0)+,D7            ARG=ARG+TABLE(N)
00011C84  51C9 FFDE 21442            DBRA      D1,CORDICx          LOOP UNTIL DONE
00011C88  4E75      21443            RTS                           RETURN
