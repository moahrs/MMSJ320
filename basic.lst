                    20565   ***************************************
                    20566   
                    20567   *************************************************************
                    20568   *                  FFPADD/FFPSUB                            *
                    20569   *             FAST FLOATING POINT ADD/SUBTRACT              *
                    20570   *                                                           *
                    20571   *  FFPADD/FFPSUB - FAST FLOATING POINT ADD AND SUBTRACT     *
                    20572   *                                                           *
                    20573   *  INPUT:                                                   *
                    20574   *      FFPADD                                               *
                    20575   *          D6 - FLOATING POINT ADDEND                       *
                    20576   *          D7 - FLOATING POINT ADDER                        *
                    20577   *      FFPSUB                                               *
                    20578   *          D6 - FLOATING POINT SUBTRAHEND                   *
                    20579   *          D7 - FLOATING POINT MINUEND                      *
                    20580   *                                                           *
                    20581   *  OUTPUT:                                                  *
                    20582   *          D7 - FLOATING POINT ADD RESULT                   *
                    20583   *                                                           *
                    20584   *  CONDITION CODES:                                         *
                    20585   *          N - RESULT IS NEGATIVE                           *
                    20586   *          Z - RESULT IS ZERO                               *
                    20587   *          V - OVERFLOW HAS OCCURED                         *
                    20588   *          C - UNDEFINED                                    *
                    20589   *          X - UNDEFINED                                    *
                    20590   *                                                           *
                    20591   *           REGISTERS D3 THRU D5 ARE VOLATILE               *
                    20592   *                                                           *
                    20593   *  CODE SIZE: 228 BYTES       STACK WORK AREA:  0 BYTES     *
                    20594   *                                                           *
                    20595   *  NOTES:                                                   *
                    20596   *    1) ADDEND/SUBTRAHEND UNALTERED (D6).                   *
                    20597   *    2) UNDERFLOW RETURNS ZERO AND IS UNFLAGGED.            *
                    20598   *    3) OVERFLOW RETURNS THE HIGHEST VALUE WITH THE         *
                    20599   *       CORRECT SIGN AND THE 'V' BIT SET IN THE CCR.        *
                    20600   *                                                           *
                    20601   *  TIME: (8 MHZ NO WAIT STATES ASSUMED)                     *
                    20602   *                                                           *
                    20603   *           COMPOSITE AVERAGE  20.625 MICROSECONDS          *
                    20604   *                                                           *
                    20605   *  ADD:         ARG1=0              7.75 MICROSECONDS       *
                    20606   *               ARG2=0              5.25 MICROSECONDS       *
                    20607   *                                                           *
                    20608   *          LIKE SIGNS  14.50 - 26.00  MICROSECONDS          *
                    20609   *                    AVERAGE   18.00  MICROSECONDS          *
                    20610   *         UNLIKE SIGNS 20.13 - 54.38  MICROCECONDS          *
                    20611   *                    AVERAGE   22.00  MICROSECONDS          *
                    20612   *                                                           *
                    20613   *  SUBTRACT:    ARG1=0              4.25 MICROSECONDS       *
                    20614   *               ARG2=0              9.88 MICROSECONDS       *
                    20615   *                                                           *
                    20616   *          LIKE SIGNS  15.75 - 27.25  MICROSECONDS          *
                    20617   *                    AVERAGE   19.25  MICROSECONDS          *
                    20618   *         UNLIKE SIGNS 21.38 - 55.63  MICROSECONDS          *
                    20619   *                    AVERAGE   23.25  MICROSECONDS          *
                    20620   *                                                           *
                    20621   *************************************************************
                    20622   
                    20623   
                    20624   ************************
                    20625   * SUBTRACT ENTRY POINT *
                    20626   ************************
000118D2  1806      20627   FFPSUB   MOVE.B  D6,D4    TEST ARG1
000118D4  6752      20628            BEQ.S   FPART2   RETURN ARG2 IF ARG1 ZERO
000118D6  0A04 0080 20629            EOR.B   #$80,D4  INVERT COPIED SIGN OF ARG1
000118DA  6B6A      20630            BMI.S   FPAMI1   BRANCH ARG1 MINUS
                    20631   * + ARG1
000118DC  1A07      20632            MOVE.B  D7,D5    COPY AND TEST ARG2
000118DE  6B6C      20633            BMI.S   FPAMS    BRANCH ARG2 MINUS
000118E0  660E      20634            BNE.S   FPALS    BRANCH POSITIVE NOT ZERO
000118E2  603E      20635            BRA.S   FPART1   RETURN ARG1 SINCE ARG2 IS ZERO
                    20636   
                    20637   *******************
                    20638   * ADD ENTRY POINT *
                    20639   *******************
000118E4  1806      20640   FFPADD   MOVE.B  D6,D4    TEST ARGUMENT1
000118E6  6B5E      20641            BMI.S   FPAMI1   BRANCH IF ARG1 MINUS
000118E8  673E      20642            BEQ.S   FPART2   RETURN ARG2 IF ZERO
                    20643   
                    20644   * + ARG1
000118EA  1A07      20645            MOVE.B  D7,D5    TEST ARGUMENT2
000118EC  6B5E      20646            BMI.S   FPAMS    BRANCH IF MIXED SIGNS
000118EE  6732      20647            BEQ.S   FPART1   ZERO SO RETURN ARGUMENT1
                    20648   
                    20649   * +ARG1 +ARG2
                    20650   * -ARG1 -ARG2
000118F0  9A04      20651   FPALS    SUB.B   D4,D5    TEST EXPONENT MAGNITUDES
000118F2  6B38      20652            BMI.S   FPA2LT   BRANCH ARG1 GREATER
000118F4  1807      20653            MOVE.B  D7,D4    SETUP STRONGER S+EXP IN D4
                    20654   
                    20655   * ARG1EXP <= ARG2EXP
000118F6  0C05 0018 20656            CMP.B   #24,D5   OVERBEARING SIZE
000118FA  642C      20657            BCC.S   FPART2   BRANCH YES, RETURN ARG2
000118FC  2606      20658            MOVE.L  D6,D3    COPY ARG1
000118FE  4203      20659            CLR.B   D3       CLEAN OFF SIGN+EXPONENT
00011900  EAAB      20660            LSR.L   D5,D3    SHIFT TO SAME MAGNITUDE
00011902  1E3C 0080 20661            MOVE.B  #$80,D7  FORCE CARRY IF LSB-1 ON
00011906  DE83      20662            ADD.L   D3,D7    ADD ARGUMENTS
00011908  6504      20663            BCS.S   FPA2GC   BRANCH IF CARRY PRODUCED
0001190A  1E04      20664   FPARSR   MOVE.B  D4,D7    RESTORE SIGN/EXPONENT
0001190C  4E75      20665            RTS              RETURN TO CALLER
                    20666   
                    20667   * ADD SAME SIGN OVERFLOW NORMALIZATION
0001190E  E297      20668   FPA2GC   ROXR.L  #1,D7    SHIFT CARRY BACK INTO RESULT
00011910  5204      20669            ADDQ.B  #1,D4    ADD ONE TO EXPONENT
00011912  6902      20670            BVS.S   FPA2OS   BRANCH OVERFLOW
00011914  64F4      20671            BCC.S   FPARSR   BRANCH IF NO EXPONENT OVERFLOW
00011916  7EFF      20672   FPA2OS   MOVEQ   #-1,D7   CREATE ALL ONES
00011918  5304      20673            SUBQ.B  #1,D4    BACK TO HIGHEST EXPONENT+SIGN
0001191A  1E04      20674            MOVE.B  D4,D7    REPLACE IN RESULT
0001191C  003C 0002 20675            OR.B    #$02,CCR SHOW OVERFLOW OCCURRED
00011920  4E75      20676            RTS              RETURN TO CALLER
                    20677   
                    20678   * RETURN ARGUMENT1
00011922  2E06      20679   FPART1   MOVE.L  D6,D7    MOVE IN AS RESULT
00011924  1E04      20680            MOVE.B  D4,D7    MOVE IN PREPARED SIGN+EXPONENT
00011926  4E75      20681            RTS              RETURN TO CALLER
                    20682   
                    20683   * RETURN ARGUMENT2
00011928  4A07      20684   FPART2   TST.B   D7       TEST FOR RETURNED VALUE
0001192A  4E75      20685            RTS              RETURN TO CALLER
                    20686   
                    20687   * -ARG1EXP > -ARG2EXP
                    20688   * +ARG1EXP > +ARG2EXP
0001192C  0C05 00E8 20689   FPA2LT   CMP.B   #-24,D5  ? ARGUMENTS WITHIN RANGE
00011930  6FF0      20690            BLE.S   FPART1   NOPE, RETURN LARGER
00011932  4405      20691            NEG.B   D5       CHANGE DIFFERENCE TO POSITIVE
00011934  2606      20692            MOVE.L  D6,D3    SETUP LARGER VALUE
00011936  4207      20693            CLR.B   D7       CLEAN OFF SIGN+EXPONENT
00011938  EAAF      20694            LSR.L   D5,D7    SHIFT TO SAME MAGNITUDE
0001193A  163C 0080 20695            MOVE.B  #$80,D3  FORCE CARRY IF LSB-1 ON
0001193E  DE83      20696            ADD.L   D3,D7    ADD ARGUMENTS
00011940  65CC      20697            BCS.S   FPA2GC   BRANCH IF CARRY PRODUCED
00011942  1E04      20698            MOVE.B  D4,D7    RESTORE SIGN/EXPONENT
00011944  4E75      20699            RTS              RETURN TO CALLER
                    20700   
                    20701   * -ARG1
00011946  1A07      20702   FPAMI1   MOVE.B  D7,D5    TEST ARG2'S SIGN
00011948  6BA6      20703            BMI.S   FPALS    BRANCH FOR LIKE SIGNS
0001194A  67D6      20704            BEQ.S   FPART1   IF ZERO RETURN ARGUMENT1
                    20705   
                    20706   * -ARG1 +ARG2
                    20707   * +ARG1 -ARG2
0001194C  7680      20708   FPAMS    MOVEQ   #-128,D3  CREATE A CARRY MASK ($80)
0001194E  B705      20709            EOR.B   D3,D5    STRIP SIGN OFF ARG2 S+EXP COPY
00011950  9A04      20710            SUB.B   D4,D5    COMPARE MAGNITUDES
00011952  6750      20711            BEQ.S   FPAEQ    BRANCH EQUAL MAGNITUDES
00011954  6B3C      20712            BMI.S   FPATLT   BRANCH IF ARG1 LARGER
                    20713   * ARG1 <= ARG2
00011956  0C05 0018 20714            CMP.B   #24,D5   COMPARE MAGNITUDE DIFFERENCE
0001195A  64CC      20715            BCC.S   FPART2   BRANCH ARG2 MUCH BIGGER
0001195C  1807      20716            MOVE.B  D7,D4    ARG2 S+EXP DOMINATES
0001195E  1E03      20717            MOVE.B  D3,D7    SETUP CARRY ON ARG2
00011960  2606      20718            MOVE.L  D6,D3    COPY ARG1
00011962  4203      20719   FPAMSS   CLR.B   D3       CLEAR EXTRANEOUS BITS
00011964  EAAB      20720            LSR.L   D5,D3    ADJUST FOR MAGNITUDE
00011966  9E83      20721            SUB.L   D3,D7    SUBTRACT SMALLER FROM LARGER
00011968  6BA0      20722            BMI.S   FPARSR   RETURN FINAL RESULT IF NO OVERFLOW
                    20723   
                    20724   * MIXED SIGNS NORMALIZE
0001196A  1A04      20725   FPANOR   MOVE.B  D4,D5    SAVE CORRECT SIGN
0001196C  4207      20726   FPANRM   CLR.B   D7       CLEAR SUBTRACT RESIDUE
0001196E  5304      20727            SUBQ.B  #1,D4    MAKE UP FOR FIRST SHIFT
00011970  0C87 0000 20728            CMP.L   #$00007FFF,D7 ? SMALL ENOUGH FOR SWAP
00011974  7FFF      
00011976  6206      20729            BHI.S   FPAXQN   BRANCH NOPE
00011978  4847      20730            SWAP.W  D7       SHIFT LEFT 16 BITS REAL FAST
0001197A  0404 0010 20731            SUB.B   #16,D4   MAKE UP FOR 16 BIT SHIFT
0001197E  DE87      20732   FPAXQN   ADD.L   D7,D7    SHIFT UP ONE BIT
00011980  5BCC FFFC 20733            DBMI    D4,FPAXQN DECREMENT AND BRANCH IF POSITIVE
00011984  B905      20734            EOR.B   D4,D5    ? SAME SIGN
00011986  6B06      20735            BMI.S   FPAZRO   BRANCH UNDERFLOW TO ZERO
00011988  1E04      20736            MOVE.B  D4,D7    RESTORE SIGN/EXPONENT
0001198A  6702      20737            BEQ.S   FPAZRO   RETURN ZERO IF EXPONENT UNDERFLOWED
0001198C  4E75      20738            RTS              RETURN TO CALLER
                    20739   
                    20740   * EXPONENT UNDERFLOWED - RETURN ZERO
0001198E  7E00      20741   FPAZRO   MOVEQ   #0,D7    CREATE A TRUE ZERO
00011990  4E75      20742            RTS              RETURN TO THE CALLER
                    20743   
                    20744   * ARG1 > ARG2
00011992  0C05 00E8 20745   FPATLT   CMP.B   #-24,D5  ? ARG1 >> ARG2
00011996  6F8A      20746            BLE.S   FPART1   RETURN IT IF SO
00011998  4405      20747            NEG.B   D5       ABSOLUTIZE DIFFERENCE
0001199A  2607      20748            MOVE.L  D7,D3    MOVE ARG2 AS LOWER VALUE
0001199C  2E06      20749            MOVE.L  D6,D7    SETUP ARG1 AS HIGH
0001199E  1E3C 0080 20750            MOVE.B  #$80,D7  SETUP ROUNDING BIT
000119A2  60BE      20751            BRA.S   FPAMSS   PERFORM THE ADDITION
                    20752   
                    20753   * EQUAL MAGNITUDES
000119A4  1A07      20754   FPAEQ    MOVE.B  D7,D5    SAVE ARG1 SIGN
000119A6  CB44      20755            EXG     D5,D4    SWAP ARG2 WITH ARG1 S+EXP
000119A8  1E06      20756            MOVE.B  D6,D7    INSURE SAME LOW BYTE
000119AA  9E86      20757            SUB.L   D6,D7    OBTAIN DIFFERENCE
000119AC  67E0      20758            BEQ.S   FPAZRO   RETURN ZERO IF IDENTICAL
000119AE  6ABA      20759            BPL.S   FPANOR   BRANCH IF ARG2 BIGGER
000119B0  4487      20760            NEG.L   D7       CORRECT DIFFERENCE TO POSITIVE
000119B2  1805      20761            MOVE.B  D5,D4    USE ARG2'S SIGN+EXPONENT
000119B4  60B6      20762            BRA.S   FPANRM   AND GO NORMALIZE
