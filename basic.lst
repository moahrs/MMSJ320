                    22322   *******************************************
                    22323   
                    22324   ********************************************
                    22325   *           FFPSQRT SUBROUTINE             *
                    22326   *                                          *
                    22327   * INPUT:                                   *
                    22328   *          D7 - FLOATING POINT ARGUMENT    *
                    22329   *                                          *
                    22330   * OUTPUT:                                  *
                    22331   *          D7 - FLOATING POINT SQUARE ROOT *
                    22332   *                                          *
                    22333   * CONDITION CODES:                         *
                    22334   *                                          *
                    22335   *          N - CLEARED                     *
                    22336   *          Z - SET IF RESULT IS ZERO       *
                    22337   *          V - SET IF ARGUMENT WAS NEGATIVE*
                    22338   *          C - CLEARED                     *
                    22339   *          X - UNDEFINED                   *
                    22340   *                                          *
                    22341   *    REGISTERS D3 THRU D6 ARE VOLATILE     *
                    22342   *                                          *
                    22343   * CODE: 194 BYTES    STACK WORK: 4 BYTES   *
                    22344   *                                          *
                    22345   * NOTES:                                   *
                    22346   *   1) NO OVERFLOWS OR UNDERFLOWS CAN      *
                    22347   *      OCCUR.                              *
                    22348   *   2) A NEGATIVE ARGUMENT CAUSES THE      *
                    22349   *      ABSOLUTE VALUE TO BE USED AND THE   *
                    22350   *      "V" BIT SET TO INDICATE THAT A      *
                    22351   *      NEGATIVE SQUARE ROOT WAS ATTEMPTED. *
                    22352   *                                          *
                    22353   * TIMES:                                   *
                    22354   * ARGUMENT ZERO         3.50 MICROSECONDS  *
                    22355   * MINIMUM TIME > 0    187.50 MICROSECONDS  *
                    22356   * AVERAGE TIME > 0    193.75 MICROSECONDS  *
                    22357   * MAXIMUM TIME > 0    200.00 MICROSECONDS  *
                    22358   ********************************************
                    22359   
                    22360   
                    22361   * NEGATIVE ARGUMENT HANDLER
00012094  CE3C 007F 22362   FPSINV   AND.B     #$7F,D7   TAKE ABSOLUTE VALUE
00012098  6106      22363            BSR.S     FFPSQRT   FIND SQRT(ABS(X))
0001209A  003C 0002 22364            OR.B      #$02,CCR  SET "V" BIT
0001209E  4E75      22365            RTS                 RETURN TO CALLER
                    22366   
                    22367   *********************
                    22368   * SQUARE ROOT ENTRY *
                    22369   *********************
000120A0  1607      22370   FFPSQRT  MOVE.B    D7,D3     COPY S+EXPONENT OVER
000120A2  6758      22371            BEQ.S     FPSRTN    RETURN ZERO IF ZERO ARGUMENT
000120A4  6BEE      22372            BMI.S     FPSINV    NEGATIVE, REJECT WITH SPECIAL CONDITION CODES
000120A6  E20B      22373            LSR.B     #1,D3     DIVIDE EXPONENT BY TWO
000120A8  6404      22374            BCC.S     FPSEVEN   BRANCH EXPONENT WAS EVEN
000120AA  5203      22375            ADDQ.B    #1,D3     ADJUST ODD VALUES UP BY ONE
000120AC  E28F      22376            LSR.L     #1,D7     OFFSET ODD EXPONENT'S MANTISSA ONE BIT
000120AE  0603 0020 22377   FPSEVEN  ADD.B     #$20,D3   RENORMALIZE EXPONENT
000120B2  4843      22378            SWAP.W    D3        SAVE RESULT S+EXP FOR FINAL MOVE
000120B4  363C 0017 22379            MOVE.W    #23,D3    SETUP LOOP FOR 24 BIT GENERATION
000120B8  EE8F      22380            LSR.L     #7,D7     PREPARE FIRST TEST VALUE
000120BA  2807      22381            MOVE.L    D7,D4     D4 - PREVIOUS VALUE DURING LOOP
000120BC  2A07      22382            MOVE.L    D7,D5     D5 - NEW TEST VALUE DURING LOOP
000120BE  2C08      22383            MOVE.L    A0,D6     SAVE ADDRESS REGISTER
000120C0  41FA 003C 22384            LEA       (FPSTBL,PC),A0 LOAD TABLE ADDRESS
000120C4  2E3C 0080 22385            MOVE.L    #$00800000,D7 D7 - INITIAL RESULT (MUST BE A ONE)
000120C8  0000      
000120CA  9887      22386            SUB.L     D7,D4     PRESET OLD VALUE IN CASE ZERO BIT NEXT
000120CC  0485 0120 22387            SUB.L     #$01200000,D5 COMBINE FIRST LOOP CALCULATIONS
000120D0  0000      
000120D2  600C      22388            BRA.S     FPSENT    GO ENTER LOOP CALCULATIONS
                    22389   
                    22390   *                   SQUARE ROOT CALCULATION
                    22391   * THIS IS AN OPTIMIZED SCHEME FOR THE RECURSIVE SQUARE ROOT ALGORITHM:
                    22392   *
                    22393   *  STEP N+1:
                    22394   *     TEST VALUE <= .0  0  0  R  R  R  0 1  THEN GENERATE A ONE IN RESULT R
                    22395   *                     N  2  1  N  2  1        ELSE A ZERO IN RESULT R      N+1
                    22396   *                                                                    N+1
                    22397   * PRECALCULATIONS ARE DONE SUCH THAT THE ENTRY IS MIDWAY INTO STEP 2
                    22398   
000120D4  07C7      22399   FPSONE   BSET      D3,D7     INSERT A ONE INTO THIS POSITION
000120D6  2805      22400            MOVE.L    D5,D4     UPDATE NEW TEST VALUE
000120D8  D884      22401   FPSZERO  ADD.L     D4,D4     MULTIPLY TEST RESULT BY TWO
000120DA  2A04      22402            MOVE.L    D4,D5     COPY IN CASE NEXT BIT ZERO
000120DC  9A98      22403            SUB.L     (A0)+,D5  SUBTRACT THE '01' ENDING PATTERN
000120DE  9A87      22404            SUB.L     D7,D5     SUBTRACT RESULT BITS COLLECTED SO FAR
000120E0  5BCB FFF2 22405   FPSENT   DBMI      D3,FPSONE BRANCH IF A ONE GENERATED IN THE RESULT
000120E4  5ACB FFF2 22406            DBPL      D3,FPSZERO BRANCH IF A ZERO GENERATED
                    22407   
                    22408   * ALL 24 BITS CALCULATED. NOW TEST RESULT OF 25TH BIT
000120E8  630A      22409            BLS.S     FPSFIN    BRANCH NEXT BIT ZERO, NO ROUNDING
000120EA  0C87 00FF 22410            CMP.L     #$00FFFFFF,D7   INSURE NO OVERFLOW
000120EE  FFFF      
000120F0  6702      22411            BEQ.S     FPSFIN    BRANCH MANTISSA ALL 1'S
000120F2  5287      22412            ADDQ.L    #1,D7     ROUND UP (CANNOT OVERFLOW)
000120F4  E18F      22413   FPSFIN   LSL.L     #8,D7     NORMALIZE RESULT
000120F6  2046      22414            MOVE.L    D6,A0     RESTORE ADDRESS REGISTER
000120F8  4843      22415            SWAP.W    D3        RESTORE S+EXP SAVE
000120FA  1E03      22416            MOVE.B    D3,D7     MOVE IN FINAL SIGN+EXPONENT
000120FC  4E75      22417   FPSRTN   RTS                 RETURN TO CALLER
                    22418   
