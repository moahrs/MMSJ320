                    22177   
                    22178   *************************************************
                    22179   *            FFPSINH/FFPCOSH/FFPTANH            *
                    22180   *       FAST FLOATING POINT HYPERBOLICS         *
                    22181   *                                               *
                    22182   *  INPUT:   D7 - FLOATING POINT ARGUMENT        *
                    22183   *                                               *
                    22184   *  OUTPUT:  D7 - HYPERBOLIC RESULT              *
                    22185   *                                               *
                    22186   *     ALL OTHER REGISTERS ARE TRANSPARENT       *
                    22187   *                                               *
                    22188   *  CODE SIZE:  36 BYTES   STACK WORK: 50 BYTES  *
                    22189   *                                               *
                    22190   *  CALLS: FFPEXP, FFPDIV, FFPADD AND FFPSUB     *
                    22191   *                                               *
                    22192   *  CONDITION CODES:                             *
                    22193   *        Z - SET IF THE RESULT IS ZERO          *
                    22194   *        N - SET IF THE RESULT IS NEGATIVE      *
                    22195   *        V - SET IF OVERFLOW OCCURRED           *
                    22196   *        C - UNDEFINED                          *
                    22197   *        X - UNDEFINED                          *
                    22198   *                                               *
                    22199   *  NOTES:                                       *
                    22200   *    1) AN OVERFLOW WILL PRODUCE THE MAXIMUM    *
                    22201   *       SIGNED VALUE WITH THE "V" BIT SET.      *
                    22202   *    2) SPOT CHECKS SHOW AT LEAST SEVEN DIGIT   *
                    22203   *       PRECISION.                              *
                    22204   *                                               *
                    22205   *  TIME: (8MHZ NO WAIT STATES ASSUMED)          *
                    22206   *                                               *
                    22207   *        SINH  623 MICROSECONDS                 *
                    22208   *        COSH  601 MICROSECONDS                 *
                    22209   *        TANH  623 MICROSECONDS                 *
                    22210   *                                               *
                    22211   *************************************************
                    22212   
                    22213   
                    22214   
          8000 0041 22215   FPONESN    EQU       $80000041           FLOATING ONE
                    22216   
                    22217   **********************************
                    22218   *            FFPCOSH             *
                    22219   *  THIS FUNCTION IS DEFINED AS   *
                    22220   *            X    -X             *
                    22221   *           E  + E               *
                    22222   *           --------             *
                    22223   *              2                 *
                    22224   * WE EVALUATE EXACTLY AS DEFINED *
                    22225   **********************************
                    22226   
00011FF4  2F06      22227   FFPCOSH  MOVE.L    D6,-(SP)  SAVE OUR ONE WORK REGISTER
00011FF6  CE3C 007F 22228            AND.B     #$7F,D7   FORCE POSITIVE (RESULTS SAME BUT EXP FASTER)
00011FFA  6100 FBBE 22229            BSR       FFPEXP    EVALUATE E TO THE X
00011FFE  691C      22230            BVS.S     FHCRTN    RETURN IF OVERFLOW (RESULT IS HIGHEST NUMBER)
00012000  2F07      22231            MOVE.L    D7,-(SP)  SAVE RESULT
00012002  2C07      22232            MOVE.L    D7,D6     SETUP FOR DIVIDE INTO ONE
00012004  2E3C 8000 22233            MOVE.L    #FPONESN,D7 LOAD FLOATING POINT ONE
00012008  0041      
0001200A  6100 FB16 22234            BSR       FFPDIV    COMPUTE E TO -X AS THE INVERSE
0001200E  2C1F      22235            MOVE.L    (SP)+,D6  PREPARE TO ADD TOGETHER
00012010  6100 F8D2 22236            BSR       FFPADD    CREATE THE NUMERATOR
00012014  6706      22237            BEQ.S     FHCRTN    RETURN IF ZERO RESULT
00012016  5307      22238            SUBQ.B    #1,D7     DIVIDE BY TWO
00012018  6802      22239            BVC.S     FHCRTN    RETURN IF NO UNDERFLOW
0001201A  7E00      22240            MOVEQ     #0,D7     RETURN ZERO IF UNDERFLOW
0001201C  2C1F      22241   FHCRTN   MOVE.L    (SP)+,D6  RESTORE OUR WORK REGISTER
0001201E  4E75      22242            RTS                 RETURN TO CALLER WITH ANSWER
                    22243   
                    22244   **********************************
                    22245   *            FFPSINH             *
                    22246   *  THIS FUNCTION IS DEFINED AS   *
                    22247   *            X    -X             *
                    22248   *           E  - E               *
                    22249   *           --------             *
                    22250   *              2                 *
                    22251   * HOWEVER, WE EVALUATE IT VIA    *
                    22252   * THE COSH FORMULA SINCE ITS     *
                    22253   * ADDITION IN THE NUMERATOR      *
                    22254   * IS SAFER THAN OUR SUBTRACTION  *
                    22255   *                                *
                    22256   * THUS THE FUNCTION BECOMES:     *
                    22257   *            X                   *
                    22258   *    SINH = E  - COSH            *
                    22259   *                                *
                    22260   **********************************
                    22261   
00012020  2F06      22262   FFPSINH  MOVE.L    D6,-(SP)  SAVE OUR ONE WORK REGISTER
00012022  6100 FB96 22263            BSR       FFPEXP    EVALUATE E TO THE X
00012026  6924      22264            BVS.S     FHSRTN    RETURN IF OVERLOW FOR MAXIMUM VALUE
00012028  2F07      22265            MOVE.L    D7,-(SP)  SAVE RESULT
0001202A  2C07      22266            MOVE.L    D7,D6     SETUP FOR DIVIDE INTO ONE
0001202C  2E3C 8000 22267            MOVE.L    #FPONESN,D7 LOAD FLOATING POINT ONE
00012030  0041      
00012032  6100 FAEE 22268            BSR       FFPDIV    COMPUTE E TO -X AS THE INVERSE
00012036  2C17      22269            MOVE.L    (SP),D6   PREPARE TO ADD TOGETHER
00012038  6100 F8AA 22270            BSR       FFPADD    CREATE THE NUMERATOR
0001203C  6706      22271            BEQ.S     FHSZRO    BRANCH IF ZERO RESULT
0001203E  5307      22272            SUBQ.B    #1,D7     DIVIDE BY TWO
00012040  6802      22273            BVC.S     FHSZRO    BRANCH IF NO UNDERFLOW
00012042  7E00      22274            MOVEQ     #0,D7     ZERO IF UNDERFLOW
00012044  2C07      22275   FHSZRO   MOVE.L    D7,D6     MOVE FOR FINAL SUBTRACT
00012046  2E1F      22276            MOVE.L    (SP)+,D7  RELOAD E TO X AGAIN AND FREE
00012048  6100 F888 22277            BSR       FFPSUB    RESULT IS E TO X MINUS COSH
0001204C  2C1F      22278   FHSRTN   MOVE.L    (SP)+,D6  RESTORE OUR WORK REGISTER
0001204E  4E75      22279            RTS                 RETURN TO CALLER WITH ANSWER
                    22280   
                    22281   **********************************
                    22282   *            FFPTANH             *
                    22283   *  THIS FUNCTION IS DEFINED AS   *
                    22284   *  SINH/COSH WHICH REDUCES TO:   *
                    22285   *            2X                  *
                    22286   *           E  - 1               *
                    22287   *           ------               *
                    22288   *            2X                  *
                    22289   *           E  + 1               *
                    22290   *                                *
                    22291   * WHICH WE EVALUATE.             *
                    22292   **********************************
                    22293   
00012050  2F06      22294   FFPTANH  MOVE.L    D6,-(SP)  SAVE OUR ONE WORK REGISTER
00012052  4A07      22295            TST.B     D7        ? ZERO
00012054  6728      22296            BEQ.S     FFPTRTN   RETURN TRUE ZERO IF SO
00012056  5207      22297            ADDQ.B    #1,D7     X TIMES TWO
00012058  6928      22298            BVS.S     FFPTOVF   BRANCH IF OVERFLOW/UNDERFLOW
0001205A  6100 FB5E 22299            BSR       FFPEXP    EVALUATE E TO THE 2X
0001205E  692C      22300            BVS.S     FFPTOVF2  BRANCH IF TOO LARGE
00012060  2F07      22301            MOVE.L    D7,-(SP)  SAVE RESULT
00012062  2C3C 8000 22302            MOVE.L    #FPONESN,D6 LOAD FLOATING POINT ONE
00012066  0041      
00012068  6100 F87A 22303            BSR       FFPADD    ADD 1 TO E**2X
0001206C  2F07      22304            MOVE.L    D7,-(SP)  SAVE DENOMINATOR
0001206E  2E2F 0004 22305            MOVE.L    4(SP),D7  NOW PREPARE TO SUBTRACT
00012072  6100 F85E 22306            BSR       FFPSUB    CREATE NUMERATOR
00012076  2C1F      22307            MOVE.L    (SP)+,D6  RESTORE DENOMINATOR
00012078  6100 FAA8 22308            BSR       FFPDIV    CREATE RESULT
0001207C  588F      22309            ADDQ.L    #4,SP     FREE E**2X OFF OF STACK
0001207E  2C1F      22310   FFPTRTN  MOVE.L    (SP)+,D6  RESTORE OUR WORK REGISTER
00012080  4E75      22311            RTS                 RETURN TO CALLER WITH ANSWER
                    22312   
00012082  2E3C 8000 22313   FFPTOVF  MOVE.L    #$80000082,D7 FLOAT ONE WITH EXPONENT OVER TO LEFT
00012086  0082      
00012088  E217      22314            ROXR.B    #1,D7     SHIFT IN CORRECT SIGN
0001208A  60F2      22315            BRA.S     FFPTRTN   AND RETURN
                    22316   
0001208C  2E3C 8000 22317   FFPTOVF2 MOVE.L    #FPONESN,D7 RETURN +1 AS RESULT
00012090  0041      
00012092  60EA      22318            BRA.S     FFPTRTN
                    22319   
                    22320   *******************************************
