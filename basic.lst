                    19945   ************************************
                    19946   * (C) COPYRIGHT 1980 MOTORLA INC.  *
                    19947   ************************************
                    19948   
                    19949   ***********************************************************
                    19950   *                                                         *
                    19951   *          FAST FLOATING POINT DUAL-BINARY TO FLOAT       *
                    19952   *                                                         *
                    19953   *      INPUT:  D6 BIT #16 - REPRESENTS SIGN (0=POSITIVE)  *
                    19954   *                                           (1=NEGATIVE)  *
                    19955   *              D6.W - REPRESENTS BASE TEN EXPONENT        *
                    19956   *                     CONSIDERING D7 A BINARY INTEGER     *
                    19957   *              D7 -   BINARY INTEGER MANTISSA             *
                    19958   *                                                         *
                    19959   *      OUTPUT: D7 - FAST FLOATING POINT EQUIVALENT        *
                    19960   *                                                         *
                    19961   *      CONDITION CODES:                                   *
                    19962   *                N - SET IF RESULT IS NEGATIVE            *
                    19963   *                Z - SET IF RESULT IS ZERO                *
                    19964   *                V - SET IF RESULT OVERFLOWED             *
                    19965   *                C - CLEARED                              *
                    19966   *                X - UNDEFINED                            *
                    19967   *                                                         *
                    19968   *      REGISTERS D3 THRU D6 DESTROYED                     *
                    19969   *                                                         *
                    19970   *      CODE SIZE: 164 BYTES     STACK WORK AREA: 4 BYTES  *
                    19971   *                                                         *
                    19972   *                                                         *
                    19973   *      FLOATING POINT RANGE:                              *
                    19974   *                                                         *
                    19975   *          FAST FLOATING POINT SUPPORTS THE VALUE ZERO    *
                    19976   *          AND NON-ZERO VALUES WITHIN THE FOLLOWING       *
                    19977   *          BOUNDS -                                       *
                    19978   *                                                         *
                    19979   * BASE 10                                                 *
                    19980   *                  18                             -20     *
                    19981   *   9.22337177 X 10   > +NUMBER >  5.42101070 X 10        *
                    19982   *                                                         *
                    19983   *                  18                             -20     *
                    19984   *  -9.22337177 X 10   > -NUMBER > -2.71050535 X 10        *
                    19985   *                                                         *
                    19986   * BASE 2                                                  *
                    19987   *                   63                            -63     *
                    19988   *      .FFFFFF  X  2   > +NUMBER >  .FFFFFF  X  2         *
                    19989   *                                                         *
                    19990   *                   63                            -64     *
                    19991   *     -.FFFFFF  X  2   > -NUMBER > -.FFFFFF  X  2         *
                    19992   *                                                         *
                    19993   *      PRECISION:                                         *
                    19994   *                                                         *
                    19995   *          THIS CONVERSION RESULTS IN A 24 BIT PRECISION  *
                    19996   *          WITH GUARANTEED ERROR LESS THAN OR EQUAL TO    *
                    19997   *          ONE-HALF LEAST SIGNIFICANT BIT.                *
                    19998   *                                                         *
                    19999   *                                                         *
                    20000   *      NOTES:                                             *
                    20001   *          1) THE INPUT FORMATS HAVE BEEN DESIGNED FOR    *
                    20002   *             EASE OF PARSING TEXT FOR CONVERSION TO      *
                    20003   *             FLOATING POINT.  SEE FFPASF FOR COMMENTS    *
                    20004   *             DESCRIBING THE METHOD FOR SETUP TO THIS     *
                    20005   *             ROUTINE.                                    *
                    20006   *          2) UNDERFLOWS RETURN A ZERO WITHOUT ANY        *
                    20007   *             INDICATORS SET.                             *
                    20008   *          3) OVERFLOWS WILL RETURN THE MAXIMUM VALUE     *
                    20009   *             POSSIBLE WITH PROPER SIGN AND THE 'V' BIT   *
                    20010   *             SET IN THE CCR REGISTER.                    *
                    20011   *                                                         *
                    20012   ***********************************************************
                    20013   
                    20014   
                    20015   
                    20016   * NORMALIZE THE INPUT BINARY MANTISSA
0001166A  7A20      20017   FFPDBF   MOVEQ     #32,D5    SETUP BASE 2 EXPONENT MAX
0001166C  4A87      20018            TST.L     D7        ? TEST FOR ZERO
0001166E  6700 0086 20019            BEQ       FPDzRTN   RETURN, NO CONVERSION NEEDED
00011672  6B08      20020            BMI.S     FPDINM    BRANCH INPUT ALREADY NORMALIZED
00011674  7A1F      20021            MOVEQ     #31,D5    PREPARE FOR NORMALIZE LOOP
00011676  DE87      20022   FPDNMI   ADD.L     D7,D7     SHIFT UP BY ONE
00011678  5BCD FFFC 20023            DBMI      D5,FPDNMI DECREMENT AND LOOP IF NOT YET
                    20024   
                    20025   * INSURE INPUT 10 POWER INDEX NOT WAY OFF BASE
0001167C  0C46 0012 20026   FPDINM   CMP.W     #18,D6    ? WAY TOO LARGE
00011680  6E00 007E 20027            BGT       FPDzOVF   BRANCH OVERFLOW
00011684  0C46 FFE4 20028            CMP.W     #-28,D6   ? WAY TOO SMALL
00011688  6D6E      20029            BLT.S     FPDRT0    RETURN ZERO IF UNDERFLOW
0001168A  3806      20030            MOVE.W    D6,D4     COPY 10 POWER INDEX
0001168C  4444      20031            NEG.W     D4        INVERT TO GO PROPER DIRECTION
0001168E  C9FC 0006 20032            MULS.W    #6,D4     TIMES FOUR FOR INDEX
00011692  2F08      20033            MOVE.L    A0,-(SP)  SAVE WORK ADDRESS REGISTER
00011694  41FA FF26 20034            LEA       (FFP10TBL,PC),A0 LOAD TABLE ADDRESS
00011698  DA70 4000 20035            ADD.W     0(A0,D4.W),D5 ADD EXPONENTS FOR MULTIPLY
0001169C  3C05      20036            MOVE.W    D5,D6     SAVE RESULT EXPONENT IN D6.W
                    20037   
                    20038   * NOW PERFORM 32 BIT MULTIPLY OF INPUT WITH POWER OF TEN TABLE
0001169E  2630 4002 20039            MOVE.L    2(A0,D4.W),D3 LOAD TABLE MANTISSA VALUE
000116A2  2057      20040            MOVE.L    (SP),A0   RESTORE WORK REGISTER
000116A4  2E83      20041            MOVE.L    D3,(SP)   NOW SAVE TABLE MANTISSA ON STACK
000116A6  3A07      20042            MOVE.W    D7,D5     COPY INPUT VALUE
000116A8  CAC3      20043            MULU.W    D3,D5     TABLELOW X INPUTLOW
000116AA  4245      20044            CLR.W     D5        LOW END NO LONGER TAKES AFFECT
000116AC  4845      20045            SWAP.W    D5        SAVE INTERMEDIATE SUM
000116AE  7800      20046            MOVEQ     #0,D4     CREATE A ZERO FOR DOUBLE PRECISION
000116B0  4843      20047            SWAP.W    D3        TO HIGH TABLE WORD
000116B2  C6C7      20048            MULU.W    D7,D3     INPUTLOW X TABLEHIGH
000116B4  DA83      20049            ADD.L     D3,D5     ADD ANOTHER PARTIAL SUM
000116B6  D904      20050            ADDX.B    D4,D4     CREATE CARRY IF ANY
000116B8  4847      20051            SWAP.W    D7        NOW TO INPUT HIGH
000116BA  3607      20052            MOVE.W    D7,D3     COPY TO WORK REGISTER
000116BC  C6EF 0002 20053            MULU.W    2(SP),D3  TABLELOW X INPUTHIGH
000116C0  DA83      20054            ADD.L     D3,D5     ADD ANOTHER PARTIAL
000116C2  6402      20055            BCC.S     FPDNOC    BRANCH NO CARRY
000116C4  5204      20056            ADDQ.B    #1,D4     ADD ANOTHER CARRY
000116C6  3A04      20057   FPDNOC   MOVE.W    D4,D5     CONCAT HIGH WORK WITH LOW
000116C8  4845      20058            SWAP.W    D5        AND CORRECT POSITIONS
000116CA  CED7      20059            MULU.W    (SP),D7   TABLEHIGH X INPUTHIGH
000116CC  4FEF 0004 20060            LEA       4(SP),SP  CLEAN UP STACK
000116D0  DE85      20061            ADD.L     D5,D7     FINAL PARTIAL PRODUCT
000116D2  6B04      20062            BMI.S     FPDNON    BRANCH IF NO NEED TO NORMALIZE
000116D4  DE87      20063            ADD.L     D7,D7     NORMALIZE
000116D6  5346      20064            SUBQ.W    #1,D6     ADJUST EXPONENT
000116D8  0687 0000 20065   FPDNON   ADD.L     #$80,D7   ROUND RESULT TO 24 BITS
000116DC  0080      
000116DE  6404      20066            BCC.S     FPDROK    BRANCH ROUND DID NOT OVERFLOW
000116E0  E297      20067            ROXR.L    #1,D7     ADJUST BACK
000116E2  5246      20068            ADDQ.W    #1,D6     AND INCREMENT EXPONENT
000116E4  7609      20069   FPDROK   MOVEQ     #9,D3     PREPARE TO FINALIZE EXPONENT TO 7 BITS
000116E6  3806      20070            MOVE.W    D6,D4     SAVE SIGN OF EXPONENT
000116E8  E766      20071            ASL.W     D3,D6     FORCE 7 BIT PRECISION
000116EA  6910      20072            BVS.S     FPDXOV    BRANCH EXPONENT OVERFLOW
000116EC  0A46 8000 20073            EOR.W     #$8000,D6 EXPONENT BACK FROM 2'S-COMPLEMENT
000116F0  E6AE      20074            LSR.L     D3,D6     PLACE INTO LOW BYTE WITH SIGN
000116F2  1E06      20075            MOVE.B    D6,D7     INSERT INTO RESULT
000116F4  6702      20076            BEQ.S     FPDRT0    RETURN ZERO IF EXPONENT ZERO
000116F6  4E75      20077   FPDzRTN  RTS                 RETURN TO CALLER
                    20078   
                    20079   * RETURN ZERO FOR UNDERFLOW
000116F8  7E00      20080   FPDRT0   MOVEQ     #0,D7     RETURN ZERO
000116FA  4E75      20081            RTS                 RETURN TO CALLER
                    20082   
                    20083   * EXPONENT OVERFLOW/UNDERFLOW
000116FC  4A44      20084   FPDXOV   TST.W     D4        TEST ORIGINAL SIGN
000116FE  6BF8      20085            BMI.S     FPDRT0    BRANCH UNDERFLOW TO RETURN ZERO
00011700  7EFF      20086   FPDzOVF  MOVEQ     #-1,D7    CREATE ALL ONES
00011702  4846      20087            SWAP.W    D6        SIGN TO LOW BIT
00011704  E216      20088            ROXR.B    #1,D6     SIGN TO X BIT
00011706  E217      20089            ROXR.B    #1,D7     SIGN INTO HIGHEST POSSIBLE RESULT
00011708  4A07      20090            TST.B     D7        CLEAR CARRY BIT
0001170A  003C 0002 20091            OR.B      #$02,CCR  SET OVERFLOW ON
0001170E  4E75      20092            RTS                 RETURN TO CALLER WITH OVERFLOW
                    20093   ************************************
                    20094   * (C) COPYRIGHT 1980 MOTORLA INC.  *
                    20095   ************************************
                    20096   
                    20097   ***********************************************************
                    20098   *                        FFPAFP                           *
                    20099   *                    ASCII TO FLOAT                       *
                    20100   *                                                         *
                    20101   *      INPUT:  A0 - POINTER TO ASCII STRING OF A FORMAT   *
                    20102   *                   DESCRIBED BELOW                       *
                    20103   *                                                         *
                    20104   *      OUTPUT: D7 - FAST FLOATING POINT EQUIVALENT        *
                    20105   *              A0 - POINTS TO THE CHARACTER WHICH         *
                    20106   *                   TERMINATED THE SCAN                   *
                    20107   *                                                         *
                    20108   *      CONDITION CODES:                                   *
                    20109   *                N - SET IF RESULT IS NEGATIVE            *
                    20110   *                Z - SET IF RESULT IS ZERO                *
                    20111   *                V - SET IF RESULT OVERFLOWED             *
                    20112   *                C - SET IF INVALID FORMAT DETECTED       *
                    20113   *                X - UNDEFINED                            *
                    20114   *                                                         *
                    20115   *      REGISTERS D3 THRU D6 ARE VOLATILE                  *
                    20116   *                                                         *
                    20117   *      CODE SIZE: 246 BYTES     STACK WORK: 8 BYTES       *
                    20118   *                                                         *
                    20119   *      INPUT FORMAT:                                      *
                    20120   *                                                         *
                    20121   *     {SIGN}{DIGITS}{'.'}{DIGITS}{'E'}{SIGN}{DIGITS}      *
                    20122   *     <*********MANTISSA********><*****EXPONENT****>      *
                    20123   *                                                         *
                    20124   *                   SYNTAX RULES                          *
                    20125   *          BOTH SIGNS ARE OPTIONAL AND ARE '+' OR '-'.    *
                    20126   *          THE MANTISSA MUST BE PRESENT.                  *
                    20127   *          THE EXPONENT NEED NOT BE PRESENT.              *
                    20128   *          THE MANTISSA MAY LEAD WITH A DECIMAL POINT.    *
                    20129   *          THE MANTISSA NEED NOT HAVE A DECIMAL POINT.    *
                    20130   *                                                         *
                    20131   *      EXAMPLES:  ALL OF THESE VALUES REPRESENT THE       *
                    20132   *                 NUMBER ONE-HUNDRED-TWENTY.              *
                    20133   *                                                         *
                    20134   *                       120            .120E3             *
                    20135   *                       120.          +.120E+03           *
                    20136   *                      +120.          0.000120E6          *
                    20137   *                   0000120.00  1200000E-4                *
                    20138   *                               1200000.00E-0004          *
                    20139   *                                                         *
                    20140   *      FLOATING POINT RANGE:                              *
                    20141   *                                                         *
                    20142   *          FAST FLOATING POINT SUPPORTS THE VALUE ZERO    *
                    20143   *          AND NON-ZERO VALUES WITHIN THE FOLLOWING       *
                    20144   *          BOUNDS -                                       *
                    20145   *                                                         *
                    20146   *                   18                             -20    *
                    20147   *    9.22337177 X 10   > +NUMBER >  5.42101070 X 10       *
                    20148   *                                                         *
                    20149   *                   18                             -20    *
                    20150   *   -9.22337177 X 10   > -NUMBER > -2.71050535 X 10       *
                    20151   *                                                         *
                    20152   *      PRECISION:                                         *
                    20153   *                                                         *
                    20154   *          THIS CONVERSION RESULTS IN A 24 BIT PRECISION  *
                    20155   *          WITH GUARANTEED ERROR LESS THAN OR EQUAL TO    *
                    20156   *          ONE-HALF LEAST SIGNIFICANT BIT.                *
                    20157   *                                                         *
                    20158   *                                                         *
                    20159   *      NOTES:                                             *
                    20160   *          1) THIS ROUTINE CALLS THE DUAL-BINARY TO FLOAT *
                    20161   *             ROUTINE AND CAN BE USED AS AN ILLUSTRATION  *
                    20162   *             OF HOW TO 'FRONT-END' THAT ROUTINE WITH     *
                    20163   *             A CUSTOMIZED SCANNER.                       *
                    20164   *          2) UNDERFLOWS RETURN A ZERO WITHOUT ANY        *
                    20165   *             INDICATORS SET.                             *
                    20166   *          3) OVERFLOWS WILL RETURN THE MAXIMUM VALUE     *
                    20167   *             POSSIBLE WITH PROPER SIGN AND THE 'V' BIT   *
                    20168   *             SET IN THE CCR.                             *
                    20169   *          4) IF THE 'C' BIT IN THE CCR INDICATES AN      *
                    20170   *             INVALID PATTERN DETECTED, THEN A0 WILL      *
                    20171   *             POINT TO THE INVALID CHARACTER.             *
                    20172   *                                                         *
                    20173   *      LOGIC SUMMARY:                                     *
                    20174   *                                                         *
                    20175   *          A) PROCESS LEADING SIGN                        *
                    20176   *          B) PROCESS PRE-DECIMALPOINT DIGITS AND         *
                    20177   *             INCREMENT 10 POWER BIAS FOR EACH            *
                    20178   *             DIGIT BYPASSED DUE TO 32 BIT OVERFLOW       *
                    20179   *          C) PROCESS POST-DECIMALPOINT DIGITS            *
                    20180   *             DECREMENTING THE 10 POWER BIAS FOR EACH     *
                    20181   *          D) PROCESS THE EXPONENT                        *
                    20182   *          E) ADD THE 10 POWER BIAS TO THE EXPONENT       *
                    20183   *          F) CALL 'FFPDBF' ROUTINE TO FINISH CONVERSION  *
                    20184   *                                                         *
                    20185   *   TIMES: (8 MHZ NO WAIT STATES)                         *
                    20186   *          374 MICROSECONDS CONVERTING THE STRING         *
                    20187   *                                                         *
                    20188   *                                                         *
                    20189   ***********************************************************
                    20190   
                    20191   
                    20192   
00011710  7E00      20193   FFPAFP   MOVEQ     #0,D7     CLEAR MANTISSA BUILD
00011712  7C00      20194            MOVEQ     #0,D6     CLEAR SIGN+BASE10 BUILD
                    20195   
                    20196   * CHECK FOR LEADING SIGN
00011714  6100 00B4 20197            BSR       FPANXT    OBTAIN NEXT CHARACTER
00011718  672A      20198            BEQ.S     FPANMB    BRANCH DIGIT FOUND
0001171A  650E      20199            BCS.S     FPANOS    BRANCH NO SIGN ENCOUNTERED
                    20200   
                    20201   * LEADING SIGN ENCOUNTERED
0001171C  0C05 002D 20202            CMP.B     #'-',D5   COMPARE FOR MINUS
00011720  57C6      20203            SEQ.B     D6        SET ONES IF SO
00011722  4846      20204            SWAP.W    D6        SIGN TO HIGH WORD IN D6
                    20205   
                    20206   * TEST FOR DIGIT OR PERIOD
00011724  6100 00A4 20207            BSR       FPANXT    OBTAIN NEXT CHARACTER
00011728  671A      20208            BEQ.S     FPANMB    BRANCH DIGIT TO BUILD MANTISSA
0001172A  0C05 002E 20209   FPANOS   CMP.B     #'.',D5   ? LEADING DECIMALPOINT
0001172E  6606      20210            BNE.S     FPABAD    BRANCH INVALID PATTERN IF NOT
                    20211   
                    20212   * INSURE AT LEAST ONE DIGIT
00011730  6100 0098 20213            BSR       FPANXT    OBTAIN NEXT CHARACTER
00011734  676E      20214            BEQ.S     FPADOF    BRANCH IF FRACTION DIGIT
                    20215   
                    20216   * INVALID PATTERN DETECTED
00011736  5388      20217   FPABAD   SUBQ.L    #1,A0     POINT TO INVALID CHARACTER
00011738  003C 0001 20218            OR.B      #$01,CCR  FORCE CARRY BIT ON
0001173C  4E75      20219            RTS                 RETURN TO CALLER
                    20220   
                    20221   * PRE-DECIMALPOINT MANTISSA BUILD
0001173E  6100 008A 20222   FPANXD   BSR       FPANXT    NEXT CHARACTER
00011742  6656      20223            BNE.S     FPANOD    BRANCH NOT A DIGIT
00011744  6166      20224   FPANMB   BSR.S     FPAX10    MULTIPLY TIMES TEN
00011746  64F6      20225            BCC.S     FPANXD    LOOP FOR MORE DIGITS
                    20226   
                    20227   * PRE-DECIMALPOINT MANTISSA OVERFLOW, COUNT TILL END OR DECIMAL REACHED
00011748  5246      20228   FPAMOV   ADDQ.W    #1,D6     INCREMENT TEN POWER BY ONE
0001174A  617E      20229            BSR.S     FPANXT    OBTAIN NEXT PATTERN
0001174C  67FA      20230            BEQ.S     FPAMOV    LOOP UNTIL NON-DIGIT
0001174E  0C05 002E 20231            CMP.B     #'.',D5   ? DECIMAL POINT REACHED
00011752  6604      20232            BNE.S     FPATSE    NO, NO CHECK FOR EXPONENT
                    20233   
                    20234   * FLUSH REMAINING FRACTIONAL DIGITS
00011754  6174      20235   FPASRD   BSR.S     FPANXT    NEXT CHARACTER
00011756  67FC      20236            BEQ.S     FPASRD    IGNORE IT IF STILL DIGIT
00011758  0C05 0045 20237   FPATSE   CMP.B     #'E',D5   ? EXPONENT HERE
0001175C  6706      20238            BEQ.S     FPAPEXP   YES, PROCESS EXPONENT
0001175E  0C05 0065 20239            CMP.B     #'e',D5   ? EXPONENT HERE
00011762  6630      20240            BNE.S     FPACNV    NO, FINISHED - GO CONVERT
                    20241   
                    20242   * NOW PROCESS THE EXPONENT
00011764  6164      20243   FPAPEXP  BSR.S     FPANXT    OBTAIN FIRST DIGIT
00011766  6710      20244            BEQ.S     FPANTE    BRANCH GOT IT
00011768  65CC      20245            BCS.S     FPABAD    BRANCH INVALID FORMAT, NO SIGN OR DIGITS
0001176A  E19E      20246            ROL.L     #8,D6     HIGH BYTE OF D6 INTO LOW
0001176C  0C05 002D 20247            CMP.B     #'-',D5   ? MINUS SIGN
00011770  57C6      20248            SEQ.B     D6        SET ONES OR ZERO
00011772  E09E      20249            ROR.L     #8,D6     D6 HIGH BYTE IS EXPONENTS SIGN
00011774  6154      20250            BSR.S     FPANXT    NOW TO FIRST DIGIT
00011776  66BE      20251            BNE.S     FPABAD    BRANCH INVALID - DIGIT EXPECTED
                    20252   
                    20253   * PROCESS EXPONENT'S DIGITS
00011778  3805      20254   FPANTE   MOVE.W    D5,D4     COPY DIGIT JUST LOADED
0001177A  614E      20255   FPANXE   BSR.S     FPANXT    EXAMINE NEXT CHARACTER
0001177C  660E      20256            BNE.S     FPAFNE    BRANCH END OF EXPONENT
0001177E  C8FC 000A 20257            MULU.W    #10,D4    PREVIOUS VALUE TIMES TEN
00011782  0C44 07D0 20258            CMP.W     #2000,D4  ? TOO LARGE
00011786  62AE      20259            BHI.S     FPABAD    BRANCH EXPONENT WAY OFF BASE
00011788  D845      20260            ADD.W     D5,D4     ADD LATEST DIGIT
0001178A  60EE      20261            BRA.S     FPANXE    LOOP FOR NEXT CHARACTER
                    20262   
                    20263   * ADJUST FOR SIGN AND ADD TO ORIGINAL INDEX
0001178C  4A86      20264   FPAFNE   TST.L     D6        ? WAS EXPONENT NEGATIVE
0001178E  6A02      20265            BPL.S     FPAADP    BRANCH IF SO
00011790  4444      20266            NEG.W     D4        CONVERT TO NEGATIVE VALUE
00011792  DC44      20267   FPAADP   ADD.W     D4,D6     FINAL RESULT
00011794  5388      20268   FPACNV   SUBQ.L    #1,A0     POINT TO TERMINATION CHARACTER
00011796  6000 FED2 20269            BRA       FFPDBF    NOW CONVERT TO FLOAT
                    20270   
                    20271   * PRE-DECIMALPOINT NON-DIGIT ENCOUNTERED
0001179A  0C05 002E 20272   FPANOD   CMP.B     #'.',D5   ? DECIMAL POINT HERE
0001179E  66B8      20273            BNE.S     FPATSE    NOPE, TRY FOR THE 'E'
                    20274   
                    20275   * POST-DECIMALPOINT PROCESSING
000117A0  6128      20276   FPADPN   BSR.S     FPANXT    OBTAIN NEXT CHARACTER
000117A2  66B4      20277            BNE.S     FPATSE    NOT A DIGIT, TEST FOR 'E'
000117A4  6106      20278   FPADOF   BSR.S     FPAX10    TIMES TEN PREVIOUS VALUE
000117A6  65AC      20279            BCS.S     FPASRD    FLUSH IF OVERFLOW NOW
000117A8  5346      20280            SUBQ.W    #1,D6     ADJUST 10 POWER BIAS
000117AA  60F4      20281            BRA.S     FPADPN    AND TO NEXT CHARACTER
                    20282   
                    20283   *   *
                    20284   *   * FPAX10 SUBROUTINE - PROCESS NEXT DIGIT
                    20285   *   *  OUTPUT: C=0 NO OVERFLOW, C=1 OVERFLOW (D7 UNALTERED)
                    20286   *   *
000117AC  2607      20287   FPAX10   MOVE.L    D7,D3     COPY VALUE
000117AE  E38B      20288            LSL.L     #1,D3     TIMES TWO
000117B0  6516      20289            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117B2  E38B      20290            LSL.L     #1,D3     TIMES FOUR
000117B4  6512      20291            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117B6  E38B      20292            LSL.L     #1,D3     TIMES EIGHT
000117B8  650E      20293            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117BA  D687      20294            ADD.L     D7,D3     ADD ONE TO MAKE X 9
000117BC  650A      20295            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117BE  D687      20296            ADD.L     D7,D3     ADD ONE TO MAKE X 10
000117C0  6506      20297            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117C2  D685      20298            ADD.L     D5,D3     ADD NEW UNITS DIGIT
000117C4  6502      20299            BCS.S     FPAXRT    RETURN IF OVERFLOW
000117C6  2E03      20300            MOVE.L    D3,D7     UPDATE RESULT
000117C8  4E75      20301   FPAXRT   RTS                 RETURN TO CALLER
                    20302   
                    20303   
                    20304   *
                    20305   * FPANXT SUBROUTINE - RETURN NEXT INPUT PATTERN
                    20306   *
                    20307   *    INPUT:  A0
                    20308   *
                    20309   *    OUTPUT:  A0 INCREMENTED BY ONE
                    20310   *             IF Z=1 THEN DIGIT ENCOUNTERED AND D5.L SET TO BINARY VALUE
                    20311   *             IF Z=0 THEN D6.B SET TO CHARACTER ENCOUNTERED
                    20312   *                         AND C=0 IF PLUS OR MINUS SIGN
                    20313   *                             C=1 IF NOT PLUS OR MINUS SIGN
                    20314   *
                    20315   
000117CA  7A00      20316   FPANXT   MOVEQ     #0,D5     ZERO RETURN REGISTER
000117CC  1A18      20317            MOVE.B    (A0)+,D5  LOAD CHARACTER
000117CE  0C05 002B 20318            CMP.B     #'+',D5   ? PLUS SIGN
000117D2  671C      20319            BEQ.S     FPASGN    BRANCH IF SIGN
000117D4  0C05 002D 20320            CMP.B     #'-',D5   ? MINUS SIGN
000117D8  6716      20321            BEQ.S     FPASGN    BRANCH IF SIGN
000117DA  0C05 0030 20322            CMP.B     #'0',D5   ? LOWER THAN A DIGIT
000117DE  6516      20323            BCS.S     FPAOTR    BRANCH IF NON-SIGNDIGIT
000117E0  0C05 0039 20324            CMP.B     #'9',D5   ? HIGHER THAN A DIGIT
000117E4  6210      20325            BHI.S     FPAOTR    BRANCH IF NON-SIGNDIGIT
                    20326   * IT IS A DIGIT
000117E6  CA3C 000F 20327            AND.B     #$0F,D5   TO BINARY
000117EA  44FC 0004 20328            MOVE.B    #$04,CCR  SET Z=1 FOR DIGIT
000117EE  4E75      20329            RTS                 RETURN TO CALLER
                    20330   * IT IS A SIGN
000117F0  44FC 0000 20331   FPASGN   MOVE.B    #$00,CCR  SET Z=0 AND C=0
000117F4  4E75      20332            RTS                 RETURN TO CALLER
                    20333   
                    20334   * IT IS NEITHER SIGN NOR DIGIT
000117F6  44FC 0001 20335   FPAOTR   MOVE.B    #$01,CCR  SET Z=0 AND C=1
000117FA  4E75      20336            RTS       RETURN TO CALLER
                    20337   *********************************************
                    20338   * (C) COPYRIGHT 1980, 1983 BY MOTOROLA INC. *
                    20339   *********************************************
                    20340   
                    20341   *******************************************************
                    20342   *                     FFPFPA                          *
                    20343   *                 FLOAT TO ASCII                      *
                    20344   *                                                     *
                    20345   *    INPUT:  D7 - FLOATING POINT NUMBER               *
                    20346   *                                                     *
                    20347   *    OUTPUT: D7 - THE BASE TEN EXPONENT IN BINARY     *
                    20348   *                 FOR THE RETURNED FORMAT             *
                    20349   *            SP - DECREMENTED BY 14 AND               *
                    20350   *                 POINTING TO THE CONVERTED           *
                    20351   *                 NUMBER IN ASCII FORMAT              *
                    20352   *                                                     *
                    20353   *            ALL OTHER REGISTERS UNAFFECTED           *
                    20354   *                                                     *
                    20355   *    CONDITION CODES:                                 *
                    20356   *            N - SET IF THE RESULT IS NEGATIVE        *
                    20357   *            Z - SET IF THE RESULT IS ZERO            *
                    20358   *            V - CLEARED                              *
                    20359   *            C - CLEARED                              *
                    20360   *            X - UNDEFINED                            *
                    20361   *                                                     *
                    20362   *   CODE SIZE: 192 BYTES   STACK WORK AREA: 42 BYTES  *
                    20363   *                                                     *
                    20364   *                                                     *
                    20365   *            {S}{'.'}{DDDDDDDD}{'E'}{S}{DD}           *
                    20366   *            <     FRACTION   >< EXPONENT >           *
                    20367   *                                                     *
                    20368   *        WHERE  S - SIGN OF MANTISSA OR EXPONENT      *
                    20369   *                   ('+' OR '-')                      *
                    20370   *               D - DECIMAL DIGIT                     *
                    20371   *                                                     *
                    20372   *        STACK OFFSET OF RESULT  S.DDDDDDDDESDD       *
                    20373   *        AFTER RETURN            00000000001111       *
                    20374   *                                01234567890123       *
                    20375   *                                                     *
                    20376   *                                                     *
                    20377   *        EXAMPLES   +.12000000E+03  120               *
                    20378   *                   +.31415927E+01  PI                *
                    20379   *                   +.10000000E-01  ONE-HUNDREDTH     *
                    20380   *                   -.12000000E+03  MINUS 120         *
                    20381   *                                                     *
                    20382   *     NOTES:                                          *
                    20383   *       1) THE BINARY BASE 10 EXPONENT IS RETURNED    *
                    20384   *          IN D7 TO FACILITATE CONVERSIONS TO         *
                    20385   *          OTHER FORMATS.                             *
                    20386   *       2) EVEN THOUGH EIGHT DIGITS ARE RETURNED, THE *
                    20387   *          PRECISION AVAILABLE IS ONLY 7.167 DIGITS.  *
                    20388   *          ROUNDING SHOULD BE PERFORMED WHEN LESS     *
                    20389   *          THAN EIGHT DIGITS ARE ACTUALLY UTILIZED    *
                    20390   *          IN THE MANTISSA.                           *
                    20391   *       3) THE STACK IS LOWERED BY 14 BYTES BY THIS   *
                    20392   *          ROUTINE.  THE RETURN ADDRESS TO THE CALLER *
                    20393   *          IS REPLACED BY A PORTION OF THE RESULTS.   *
                    20394   *                                                     *
                    20395   *  TIME: (8MHZ NO WAIT STATES ASSUMED)                *
                    20396   *        330 MICROSECONDS CONVERTING THE SAMPLE FLOAT *
                    20397   *        VALUE OF 55.55 TO ASCII.                     *
                    20398   *                                                     *
                    20399   *******************************************************
                    20400   
                    20401   
                    20402   * STACK DEFINITION
          0000 0030 20403   STKOLD   EQU       48       PREVIOUS CALLERS STACK POINTER
          0000 002E 20404   STKEXP   EQU       46       EXPONENT
          0000 002D 20405   STKEXPS  EQU       45       EXPONENTS SIGN
          0000 002C 20406   STKLTRE  EQU       44       'E'
          0000 0024 20407   STKMANT  EQU       36       MANTISSA
          0000 0023 20408   STKPER   EQU       35       '.'
          0000 0022 20409   STKMANS  EQU       34       MANTISSA'S SIGN
          0000 001E 20410   STKNEWRT EQU       30       NEW RETURN POSITION
          0000 001C 20411   STKRTCC  EQU       28       RETURN CONDITION CODE
          0000 0000 20412   STKSAVE  EQU       0        REGISTER SAVE AREA
                    20413   
                    20414   
000117FC  4FEF FFF6 20415   FFPFPA   LEA       -10(SP),SP   SET STACK TO NEW LOCATION
00011800  2F2F 000A 20416            MOVE.L    10(SP),-(SP) SAVE RETURN
00011804  4A07      20417            TST.B     D7           TEST VALUE
00011806  40E7      20418            MOVE      SR,-(SP)     SAVE CCR OF RESULT ON THE STACK, not 68010 compatible
00011808  48E7 3EC0 20419            MOVEM.L   D2-D6/A0/A1,-(SP)  SAVE WORK ADDRESS REGISTER
                    20420   
                    20421   * ADJUST FOR ZERO VALUE
0001180C  6602      20422            BNE.S     FPFNOT0   BRANCH NO ZERO INPUT
0001180E  7E41      20423            MOVEQ     #$41,D7   SETUP PSEUDO INTEGER EXPONENT
                    20424   
                    20425   * SETUP MANTISSA'S SIGN
00011810  3F7C 2B2E 20426   FPFNOT0  MOVE.W    #'+.',STKMANS(SP) INSERT PLUS AND DECIMAL
00011814  0022      
00011816  1C07      20427            MOVE.B    D7,D6     COPY SIGN+EXPONENT
00011818  6A04      20428            BPL.S     FPFPLS    BRANCH IF PLUS
0001181A  542F 0022 20429            ADDQ.B    #2,STKMANS(SP) CHANGE PLUS TO MINUS
                    20430   
                    20431   * START SEARCH FOR MAGNITUDE IN BASE 10 POWER TABLE
0001181E  DC06      20432   FPFPLS   ADD.B     D6,D6     SIGN OUT OF PICTURE
00011820  1E3C 0080 20433            MOVE.B    #$80,D7   SET ROUDING FACTOR FOR SEARCH
00011824  BF06      20434            EOR.B     D7,D6     CONVERT EXPONENT TO BINARY
00011826  4886      20435            EXT.W     D6        EXPONENT TO WORD
00011828  E246      20436            ASR.W     #1,D6     BACK FROM SIGN EXTRACTMENT
0001182A  7601      20437            MOVEQ     #1,D3     START BASE TEN COMPUTATION
0001182C  41FA FD8E 20438            LEA       (FFP10TBL,PC),A0 START AT TEN TO THE ZERO
00011830  BC50      20439            CMP.W     (A0),D6   COMPARE TO TABLE
00011832  6D1C      20440            BLT.S     FPFMIN    BRANCH MINUS EXPONENT
00011834  6E0C      20441            BGT.S     FPFPLU    BRANCH PLUS EXPONENT
00011836  BEA8 0002 20442   FPFEQE   CMP.L     2(A0),D7  EQUAL SO COMPARE MANTISSA'S
0001183A  6420      20443            BCC.S     FPFFND    BRANCH IF INPUT GREATER OR EQUAL THAN TABLE
0001183C  5C48      20444   FPFBCK   ADDQ.W    #6,A0     TO NEXT LOWER ENTRY IN TABLE
0001183E  5343      20445            SUBQ.W    #1,D3     DECREMENT BASE 10 EXPONENT
00011840  601A      20446            BRA.S     FPFFND    BRANCH POWER OF TEN FOUND
                    20447   
                    20448   * EXPONENT IS HIGHER THAN TABLE
00011842  41E8 FFFA 20449   FPFPLU   LEA       -6(A0),A0 TO NEXT HIGHER ENTRY
00011846  5243      20450            ADDQ.W    #1,D3     INCREMENT POWER OF TEN
00011848  BC50      20451            CMP.W     (A0),D6   TEST NEW MAGNITUDE
0001184A  6EF6      20452            BGT.S     FPFPLU    LOOP IF STILL GREATER
0001184C  67E8      20453            BEQ.S     FPFEQE    BRANCH EQUAL EXPONENT
0001184E  60EC      20454            BRA.S     FPFBCK    BACK TO LOWER AND FOUND
                    20455   
                    20456   * EXPONENT IS LOWER THAN TABLE
00011850  41E8 0006 20457   FPFMIN   LEA       6(A0),A0  TO NEXT LOWER ENTRY
00011854  5343      20458            SUBQ.W    #1,D3     DECREMENT POWER OF TEN BY ONE
00011856  BC50      20459            CMP.W     (A0),D6   TEST NEW MAGNITUDE
00011858  6DF6      20460            BLT.S     FPFMIN    LOOP IF STILL LESS THAN
0001185A  67DA      20461            BEQ.S     FPFEQE    BRANCH EQUAL EXPONENT
                    20462   
                    20463   * CONVERT THE EXPONENT TO ASCII
0001185C  2F7C 452B 20464   FPFFND   MOVE.L    #'E+00',STKLTRE(SP) SETUP EXPONENT PATTERN
00011860  3030 002C 
00011864  3403      20465            MOVE.W    D3,D2     ? EXPONENT POSITIVE
00011866  6A06      20466            BPL.S     FPFPEX    BRANCH IF SO
00011868  4442      20467            NEG.W     D2        ABSOLUTIZE
0001186A  542F 002D 20468            ADDQ.B    #2,STKEXPS(SP) TURN TO MINUS SIGN
0001186E  0C42 000A 20469   FPFPEX   CMP.W     #10,D2    ? TEN OR GREATER
00011872  6508      20470            BCS.S     FPFGEN    BRANCH IF NOT
00011874  522F 002E 20471            ADDQ.B    #1,STKEXP(SP) CHANGE ZERO TO A ONE
00011878  0442 000A 20472            SUB.W     #10,D2    ADJUST TO DECIMAL
0001187C  852F 002F 20473   FPFGEN   OR.B      D2,STKEXP+1(SP) FILL IN LOW DIGIT
                    20474   
                    20475   * GENERATE THE MANTISSA IN ASCII A0->TABLE  D7=BINARY MANTISSA
                    20476   * D5 - MANTISSA FROM TABLE       D6.W = BINARY EXPONENT
                    20477   * D4 - SHIFT AND DIGIT BUILDER   D2 = DBRA MANTISSA DIGIT COUNT
                    20478   * A1->MANTISSA STACK POSITION
00011880  7407      20479            MOVEQ     #7,D2     COUNT FOR EIGHT DIGITS
00011882  43EF 0024 20480            LEA       STKMANT(SP),A1 POINT TO MANTISSA START
00011886  4A87      20481            TST.L     D7        ? ZERO TO CONVERT
00011888  6A06      20482            BPL.S     FPFZRO    BRANCH IF SO TO NOT ROUND
0001188A  4A28 0005 20483            TST.B     5(A0)     ? 24 BIT PRECISE IN TABLE
0001188E  6602      20484            BNE.S     FPFNXI    BRANCH IF NO TRAILING ZEROES
00011890  4207      20485   FPFZRO   CLR.B     D7        CLEAR ADJUSTMENT FOR .5 LSB PRECISION
00011892  3806      20486   FPFNXI   MOVE.W    D6,D4     COPY BINARY EXPONENT
00011894  9858      20487            SUB.W     (A0)+,D4  FIND NORMALIZATION FACTOR
00011896  2A18      20488            MOVE.L    (A0)+,D5  LOAD MANTISSA FROM TABLE
00011898  E8AD      20489            LSR.L     D4,D5     ADJUST TO SAME EXPONENT
0001189A  7809      20490            MOVEQ     #9,D4     START AT NINE AND COUNT DOWN
0001189C  9E85      20491   FPFINC   SUB.L     D5,D7     SUBTRACT FOR ANOTHER COUNT
0001189E  55CC FFFC 20492            DBCS      D4,FPFINC DECREMENT AND BRANCH IF OVER
000118A2  6502      20493            BCS.S     FPFNIM    BRANCH NO IMPRECISION
000118A4  4204      20494            CLR.B     D4        CORRECT RARE UNDERFLOW DUE TO TABLE IMPRECISION
000118A6  DE85      20495   FPFNIM   ADD.L     D5,D7     MAKE UP FOR OVER SUBTRACTION
000118A8  0404 0009 20496            SUB.B     #9,D4     CORRECT VALUE
000118AC  4404      20497            NEG.B     D4        TO BETWEEN 0 AND 9 BINARY
000118AE  883C 0030 20498            OR.B      #'0',D4   CONVERT TO ASCII
000118B2  12C4      20499            MOVE.B    D4,(A1)+  INSERT INTO ASCII MANTISSA PATTERN
000118B4  51CA FFDC 20500            DBRA      D2,FPFNXI BRANCH IF MORE DIGITS TO GO
                    20501   
                    20502   * RETURN WITH BASE TEN EXPONENT BINARY IN D7
000118B8  3E03      20503            MOVE.W    D3,D7     TO D7
000118BA  48C7      20504            EXT.L     D7        TO FULL WORD
000118BC  4CDF 037C 20505            MOVEM.L   (SP)+,D2-D6/A0/A1 RESTORE WORK REGISTERS
000118C0  4E77      20506            RTR       RETURN WITH PROPER CONDITION CODE
