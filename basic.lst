                    20511   *************************************************************
                    20512   *                     FFPABS                                *
                    20513   *           FAST FLOATING POINT ABSOLUTE VALUE              *
                    20514   *                                                           *
                    20515   *  INPUT:  D7 - FAST FLOATING POINT ARGUMENT                *
                    20516   *                                                           *
                    20517   *  OUTPUT: D7 - FAST FLOATING POINT ABSOLUTE VALUE RESULT   *
                    20518   *                                                           *
                    20519   *      CONDITION CODES:                                     *
                    20520   *              N - CLEARED                                  *
                    20521   *              Z - SET IF RESULT IS ZERO                    *
                    20522   *              V - CLEARED                                  *
                    20523   *              C - UNDEFINED                                *
                    20524   *              X - UNDEFINED                                *
                    20525   *                                                           *
                    20526   *               ALL REGISTERS TRANSPARENT                   *
                    20527   *                                                           *
                    20528   *************************************************************
                    20529   
                    20530   ******************************
                    20531   * ABSOLUTE VALUE ENTRY POINT *
                    20532   ******************************
000118C2  CE3C 007F 20533   FFPABS   AND.B     #$7F,D7   CLEAR THE SIGN BIT
000118C6  4E75      20534            RTS                 AND RETURN TO THE CALLER
                    20535   
                    20536   *************************************************************
                    20537   *                     FFPNEG                                *
                    20538   *           FAST FLOATING POINT NEGATE                      *
                    20539   *                                                           *
                    20540   *  INPUT:  D7 - FAST FLOATING POINT ARGUMENT                *
                    20541   *                                                           *
                    20542   *  OUTPUT: D7 - FAST FLOATING POINT NEGATED RESULT          *
                    20543   *                                                           *
                    20544   *      CONDITION CODES:                                     *
                    20545   *              N - SET IF RESULT IS NEGATIVE                *
                    20546   *              Z - SET IF RESULT IS ZERO                    *
                    20547   *              V - CLEARED                                  *
                    20548   *              C - UNDEFINED                                *
                    20549   *              X - UNDEFINED                                *
                    20550   *                                                           *
                    20551   *               ALL REGISTERS TRANSPARENT                   *
                    20552   *                                                           *
                    20553   *************************************************************
                    20554   
                    20555   **********************
                    20556   * NEGATE ENTRY POINT *
                    20557   **********************
000118C8  4A07      20558   FFPNEG   TST.B     D7        ? IS ARGUMENT A ZERO
000118CA  6704      20559            BEQ.S     FFPRTN    RETURN IF SO
000118CC  0A07 0080 20560            EOR.B     #$80,D7   INVERT THE SIGN BIT
000118D0  4E75      20561   FFPRTN   RTS                 AND RETURN TO CALLER
                    20562   
