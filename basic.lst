                    21448   ***********************************************************
                    21449   *            FAST FLOATING POINT TO INTEGER               *
                    21450   *                                                         *
                    21451   *      INPUT:  D7 = FAST FLOATING POINT NUMBER            *
                    21452   *      OUTPUT: D7 = FIXED POINT INTEGER (2'S COMPLEMENT)  *
                    21453   *                                                         *
                    21454   *  CONDITION CODES:                                       *
                    21455   *             N - SET IF RESULT IS NEGATIVE               *
                    21456   *             Z - SET IF RESULT IS ZERO                   *
                    21457   *             V - SET IF OVERFLOW OCCURRED                *
                    21458   *             C - UNDEFINED                               *
                    21459   *             X - UNDEFINED                               *
                    21460   *                                                         *
                    21461   *  REGISTER D5 IS DESTROYED                               *
                    21462   *                                                         *
                    21463   *  INTEGERS OF OVER 24 BIT PRECISION WILL BE IMPRECISE    *
                    21464   *                                                         *
                    21465   *  NOTE: MAXIMUM SIZE INTEGER RETURNED IF OVERFLOW        *
                    21466   *                                                         *
                    21467   *   CODE SIZE: 78 BYTES        STACK WORK AREA: 0 BYTES   *
                    21468   *                                                         *
                    21469   *      TIMINGS:  (8 MHZ NO WAIT STATES ASSUMED)           *
                    21470   *           COMPOSITE AVERAGE 15.00 MICROSECONDS          *
                    21471   *            ARG = 0   4.75 MICROSECONDS                  *
                    21472   *            ARG # 0   10.50 - 18.25 MICROSECONDS         *
                    21473   *                                                         *
                    21474   ***********************************************************
                    21475   
                    21476   
                    21477   
00011C8A  1A07      21478   FFPFPI  MOVE.B    D7,D5          SAVE SIGN/EXPONENT                4
00011C8C  6B24      21479           BMI.S     FPIMI          BRANCH IF MINUS VALUE             8/10
00011C8E  6712      21480           BEQ.S     FPIRTN         RETURN IF ZERO                    8/10
00011C90  4207      21481           CLR.B     D7             CLEAR FOR SHIFT                   4
00011C92  0405 0041 21482           SUB.B     #65,D5         EXPONENT-1 TO BINARY              8
00011C96  6B16      21483           BMI.S     FPIRT0         RETURN ZERO FOR FRACTION          8/10
00011C98  0405 001F 21484           SUB.B     #31,D5         ? OVERFLOW                        8
00011C9C  6A06      21485           BPL.S     FPIOVP         BRANCH IF TOO LARGE               8/10
00011C9E  4405      21486           NEG.B     D5             ADJUST FOR SHIFT                  4
00011CA0  EAAF      21487           LSR.L     D5,D7          FINALIZE INTEGER                  8-70
00011CA2  4E75      21488   FPIRTN  RTS                      RETURN TO CALLER                  16
                    21489   
                    21490   * POSITIVE OVERFLOW
00011CA4  7EFF      21491   FPIOVP  MOVEQ     #-1,D7         LOAD ALL ONES
00011CA6  E28F      21492           LSR.L     #1,D7          PUT ZERO IN AS SIGN
00011CA8  003C 0002 21493           OR.B      #$02,CCR       SET OVERFLOW BIT ON
00011CAC  4E75      21494           RTS                      RETURN TO CALLER
                    21495   
                    21496   * FRACTION ONLY RETURNS ZERO
00011CAE  7E00      21497   FPIRT0  MOVEQ     #0,D7          RETURN ZERO
00011CB0  4E75      21498           RTS                      BACK TO CALLER
                    21499   
                    21500   * INPUT IS A MINUS INTEGER
00011CB2  4207      21501   FPIMI   CLR.B     D7             CLEAR FOR CLEAN SHIFT                 4
00011CB4  0405 00C1 21502           SUB.B     #$80+65,D5     EXPONENT-1 TO BINARY AND STRIP SIGN   8
00011CB8  6BF4      21503           BMI.S     FPIRT0         RETURN ZERO FOR FRACTION              8/10
00011CBA  0405 001F 21504           SUB.B     #31,D5         ? OVERFLOW                            8
00011CBE  6A08      21505           BPL.S     FPICHM         BRANCH POSSIBLE MINUS OVERFLOW        8/10
00011CC0  4405      21506           NEG.B     D5             ADJUST FOR SHIFT COUNT                4
00011CC2  EAAF      21507           LSR.L     D5,D7          SHIFT TO PROPER MAGNITUDE             8-70
00011CC4  4487      21508           NEG.L     D7             TO MINUS NOW                          6
00011CC6  4E75      21509           RTS                      RETURN TO CALLER                      16
                    21510   
                    21511   * CHECK FOR MAXIMUM MINUS NUMBER OR MINUS OVERFLOW
00011CC8  6606      21512   FPICHM  BNE.S     FPIOVM         BRANCH MINUS OVERFLOW
00011CCA  4487      21513           NEG.L     D7             ATTEMPT CONVERT TO NEGATIVE
00011CCC  4A87      21514           TST.L     D7             CLEAR OVERFLOW BIT
00011CCE  6BD2      21515           BMI.S     FPIRTN         RETURN IF MAXIMUM NEGATIVE INTEGER
00011CD0  7E00      21516   FPIOVM  MOVEQ     #0,D7          CLEAR D7
00011CD2  08C7 001F 21517           BSET.L    #31,D7         SET HIGH BIT ON FOR MAXIMUM NEGATIVE
00011CD6  003C 0002 21518           OR.B      #$02,CCR       SET OVERFLOW BIT ON
00011CDA  4E75      21519           RTS                      AND RETURN TO CALLER
