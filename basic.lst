00012122  0000 0800 
00012126  0000 0400 
0001212A  0000 0200 
0001212E  0000 0100 
00012132  0000 0080 22422            DC.L      1<<7,1<<6,1<<5,1<<4,1<<3,1<<2,1<<1,1<<0
00012136  0000 0040 
0001213A  0000 0020 
0001213E  0000 0010 
00012142  0000 0008 
00012146  0000 0004 
0001214A  0000 0002 
0001214E  0000 0001 
00012152  0000 0000 22423            DC.L      0,0
00012156  0000 0000 
