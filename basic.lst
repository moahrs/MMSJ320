                    21521   * (C) COPYRIGHT 1980 MOTORLA INC.  *
                    21522   ************************************
                    21523   
                    21524   ***********************************************************
                    21525   *               INTEGER TO FLOATING POINT                 *
                    21526   *                                                         *
                    21527   *      INPUT: D7 = FIXED POINT INTEGER (2'S COMPLEMENT)   *
                    21528   *      OUTPUT: D7 = FAST FLOATING POINT EQUIVALENT        *
                    21529   *                                                         *
                    21530   *      CONDITION CODES:                                   *
                    21531   *                N - SET IF RESULT IS NEGATIVE            *
                    21532   *                Z - SET IF RESULT IS ZERO                *
                    21533   *                V - CLEARED                              *
                    21534   *                C - UNDEFINED                            *
                    21535   *                X - UNDEFINED                            *
                    21536   *                                                         *
                    21537   *      D5 IS DESTROYED                                    *
                    21538   *                                                         *
                    21539   *      INTEGERS OF GREATER THAN 24 BITS WILL BE ROUNDED   *
                    21540   *      AND IMPRECISE.                                     *
                    21541   *                                                         *
                    21542   *      CODE SIZE: 56 BYTES      STACK WORK AREA: 0 BYTES  *
                    21543   *                                                         *
                    21544   *      TIMINGS: (8MHZ NO WAIT STATES ASSUMED)             *
                    21545   *         COMPOSITE AVERATE 31.75 MICROSECONDS            *
                    21546   *            ARG = 0   4.25          MICROSECONDS         *
                    21547   *            ARG > 0   13.75 - 47.50 MICROSECONDS         *
                    21548   *            ARG < 0   15.50 - 50.25 MICROSECONDS         *
                    21549   *                                                         *
                    21550   ***********************************************************
                    21551   
                    21552   
00011CDC  7A5F      21553   FFPIFP   MOVEQ   #64+31,D5  SETUP HIGH END EXPONENT
00011CDE  4A87      21554            TST.L   D7         ? INTEGER A ZERO
00011CE0  6730      21555            BEQ.S   ITORTN     RETURN SAME RESULT IF SO
00011CE2  6A08      21556            BPL.S   ITOPLS     BRANCH IF POSITIVE INTEGER
00011CE4  7AE0      21557            MOVEQ   #-32,D5    SETUP NEGATIVE HIGH EXPONENT -#80+64+32
00011CE6  4487      21558            NEG.L   D7         FIND POSITIVE VALUE
00011CE8  6926      21559            BVS.S   ITORTI     BRANCH MAXIMUM NEGATIVE NUMBER
00011CEA  5305      21560            SUBQ.B  #1,D5      ADJUST FOR EXTRA ZERO BIT
00011CEC  0C87 0000 21561   ITOPLS   CMP.L   #$00007FFF,D7 ? POSSIBLE 17 BITS ZERO
00011CF0  7FFF      
00011CF2  6206      21562            BHI.S   ITOLP      BRANCH IF NOT
00011CF4  4847      21563            SWAP.W  D7         QUICK SHIFT BY SWAP
00011CF6  0405 0010 21564            SUB.B   #16,D5     DEDUCT 16 SHIFTS FROM EXPONENT
00011CFA  DE87      21565   ITOLP    ADD.L   D7,D7      SHIFT MANTISSA UP
00011CFC  5BCD FFFC 21566            DBMI    D5,ITOLP   LOOP UNTIL NORMALIZED
00011D00  4A07      21567            TST.B   D7         ? TEST FOR ROUND UP
00011D02  6A0C      21568            BPL.S   ITORTI     BRANCH NO ROUNDING NEEDED
00011D04  0687 0000 21569            ADD.L   #$100,D7   ROUND UP
00011D08  0100      
00011D0A  6404      21570            BCC.S   ITORTI     BRANCH NO OVERFLOW
00011D0C  E297      21571            ROXR.L  #1,D7      ADJUST DOWN ONE BIT
00011D0E  5205      21572            ADDQ.B  #1,D5      REFLECT RIGHT SHIFT IN EXPONENT BIAS
00011D10  1E05      21573   ITORTI   MOVE.B  D5,D7      INSERT SIGN/EXPONENT
00011D12  4E75      21574   ITORTN   RTS                RETURN TO CALLER
                    21575   ***************************************
                    21576   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    21577   ***************************************
                    21578   
                    21579   *************************************************
                    21580   *                  FFPLOG                       *
                    21581   *       FAST FLOATING POINT LOGORITHM           *
                    21582   *                                               *
                    21583   *  INPUT:   D7 - INPUT ARGUMENT                 *
                    21584   *                                               *
                    21585   *  OUTPUT:  D7 - LOGORITHMIC RESULT TO BASE E   *
                    21586   *                                               *
                    21587   *     ALL OTHER REGISTERS TOTALLY TRANSPARENT   *
                    21588   *                                               *
                    21589   *  CODE SIZE: 184 BYTES   STACK WORK: 38 BYTES  *
                    21590   *                                               *
                    21591   *  CONDITION CODES:                             *
                    21592   *        Z - SET IF THE RESULT IS ZERO          *
                    21593   *        N - SET IF RESULT IN IS NEGATIVE       *
                    21594   *        V - SET IF INVALID NEGATIVE ARGUMENT   *
                    21595   *            OR ZERO ARGUMENT                   *
                    21596   *        C - UNDEFINED                          *
                    21597   *        X - UNDEFINED                          *
                    21598   *                                               *
                    21599   *                                               *
                    21600   *  NOTES:                                       *
                    21601   *    1) SPOT CHECKS SHOW ERRORS BOUNDED BY      *
                    21602   *       5 X 10**-8.                             *
                    21603   *    2) NEGATIVE ARGUMENTS ARE ILLEGAL AND CAUSE*
                    21604   *       THE "V" BIT TO BE SET AND THE ABSOLUTE  *
                    21605   *       VALUE USED INSTEAD.                     *
                    21606   *    3) A ZERO ARGUMENT RETURNS THE LARGEST     *
                    21607   *       NEGATIVE VALUE POSSIBLE WITH THE "V" BIT*
                    21608   *       SET.                                    *
                    21609   *                                               *
                    21610   *  TIME: (8MHZ NO WAIT STATES ASSUMED)          *
                    21611   *                                               *
                    21612   *        TIMES ARE VERY DATA SENSITIVE WITH     *
                    21613   *        SAMPLES RANGING FROM 170 TO 556        *
                    21614   *        MICROSECONDS                           *
                    21615   *                                               *
                    21616   *************************************************
                    21617   
                    21618   
                    21619   
          8000 0041 21620   FPONELG  EQU       $80000041           FLOATING VALUE FOR ONE
          B172 1840 21621   LOG2     EQU       $B1721840           LOG(2) = .6931471805
                    21622   
                    21623   **************
                    21624   * LOG ENTRY  *
                    21625   **************
                    21626   
                    21627   * INSURE ARGUMENT POSITIVE
00011D14  4A07      21628   FFPLOG   TST.B     D7                  ? TEST SIGN
00011D16  670E      21629            BEQ.S     FPLZRO              BRANCH ARGUMENT ZERO
00011D18  6A14      21630            BPL.S     FPLOK               BRANCH ALRIGHT
                    21631   
                    21632   * ARGUMENT IS NEGATIVE - USE THE ABSOLUTE VALUE AND SET THE "V" BIT
00011D1A  CE3C 007F 21633            AND.B     #$7F,D7             TAKE ABSOLUTE VALUE
00011D1E  610E      21634            BSR.S     FPLOK               FIND LOG(ABS(X))
00011D20  003C 0002 21635   FPSETV   OR.B      #$02,CCR            SET OVERFLOW BIT
00011D24  4E75      21636            RTS                           RETURN TO CALLER
                    21637   
                    21638   * ARGUMENT IS ZERO - RETURN LARGEST NEGATIVE NUMBER WITH "V" BIT
00011D26  2E3C FFFF 21639   FPLZRO   MOVE.L    #-1,D7              RETURN LARGEST NEGATIVE
00011D2A  FFFF      
00011D2C  60F2      21640            BRA.S     FPSETV              RETURN WITH "V" BIT SET
                    21641   
                    21642   * SAVE WORK REGISTERS AND STRIP EXPONENT OFF
00011D2E  48E7 7E80 21643   FPLOK    MOVEM.L   D1-D6/A0,-(SP)      SAVE ALL WORK REGISTERS
00011D32  1F07      21644            MOVE.B    D7,-(SP)            SAVE ORIGINAL EXPONENT
00011D34  1E3C 0041 21645            MOVE.B    #64+1,D7            FORCE BETWEEN 1 AND 2
00011D38  2C3C 8000 21646            MOVE.L    #FPONELG,D6           LOAD UP A ONE
00011D3C  0041      
00011D3E  2407      21647            MOVE.L    D7,D2               COPY ARGUMENT
00011D40  6100 FBA2 21648            BSR       FFPADD              CREATE ARG+1
00011D44  CF42      21649            EXG.L     D7,D2               SWAP RESULT WITH ARGUMENT
00011D46  6100 FB8A 21650            BSR       FFPSUB              CREATE ARG-1
00011D4A  2C02      21651            MOVE.L    D2,D6               PREPARE FOR DIVIDE
00011D4C  6100 FDD4 21652            BSR       FFPDIV              RESULT IS (ARG-1)/(ARG+1)
00011D50  674A      21653            BEQ.S     FPLNOCR             ZERO SO CORDIC NOT NEEDED
                    21654   * CONVERT TO BIN(31,29) PRECISION
00011D52  0407 0043 21655            SUB.B     #64+3,D7            ADJUST EXPONENT
00011D56  4407      21656            NEG.B     D7                  FOR SHIFT NECESSARY
00011D58  0C07 001F 21657            CMP.B     #31,D7              ? INSURE NOT TOO SMALL
00011D5C  6302      21658            BLS.S     FPLSHF              NO, GO SHIFT
00011D5E  7E00      21659            MOVEQ     #0,D7               FORCE TO ZERO
00011D60  EEAF      21660   FPLSHF   LSR.L     D7,D7               SHIFT TO BIN(31,29) PRECISION
                    21661   
                    21662   *****************************************
                    21663   * CORDIC CALCULATION REGISTERS:         *
                    21664   * D1 - LOOP COUNT   A0 - TABLE POINTER  *
                    21665   * D2 - SHIFT COUNT                      *
                    21666   * D3 - Y'   D5 - Y                      *
                    21667   * D4 - X'   D6 - Z                      *
                    21668   * D7 - X                                *
                    21669   *****************************************
                    21670   
00011D62  7C00      21671            MOVEQ     #0,D6               Z=0
00011D64  2A3C 2000 21672            MOVE.L    #1<<29,D5           Y=1
00011D68  0000      
00011D6A  41FA 03EE 21673            LEA       (FFPHTHET,PC),A0    TO INVERSE HYPERBOLIC TANGENT TABLE
00011D6E  7216      21674            MOVEQ     #22,D1              LOOP 23 TIMES
00011D70  7401      21675            MOVEQ     #1,D2               PRIME SHIFT COUNTER
00011D72  6006      21676            BRA.S     CORDICg             ENTER CORDIC LOOP
                    21677   
                    21678   * CORDIC LOOP
00011D74  E4A4      21679   FPLPLSg  ASR.L     D2,D4               SHIFT(X')
00011D76  9A84      21680            SUB.L     D4,D5               Y = Y - X'
00011D78  DC90      21681            ADD.L     (A0),D6             Z = Z + HYPERTAN(I)
00011D7A  2807      21682   CORDICg  MOVE.L    D7,D4               X' = X
00011D7C  2605      21683            MOVE.L    D5,D3               Y' = Y
00011D7E  E4A3      21684            ASR.L     D2,D3               SHIFT(Y')
00011D80  9E83      21685   FPLNLPg  SUB.L     D3,D7               X = X - Y'
00011D82  6AF0      21686            BPL.S     FPLPLSg             BRANCH NEGATIVE
00011D84  2E04      21687            MOVE.L    D4,D7               RESTORE X
00011D86  5888      21688            ADDQ.L    #4,A0               TO NEXT TABLE ENTRY
00011D88  5202      21689            ADDQ.B    #1,D2               INCREMENT SHIFT COUNT
00011D8A  E28B      21690            LSR.L     #1,D3               SHIFT(Y')
00011D8C  51C9 FFF2 21691            DBRA      D1,FPLNLPg          AND LOOP UNTIL DONE
                    21692   
                    21693   * NOW CONVERT TO FLOAT AND ADD EXPONENT*LOG(2) FOR FINAL RESULT
00011D90  7E00      21694            MOVEQ     #0,D7               DEFAULT ZERO IF TOO SMALL
00011D92  6100 0492 21695            BSR       FFPTNORM            FLOAT Z
00011D96  6704      21696            BEQ.S     FPLNOCR             BRANCH IF TOO SMALL
00011D98  5206      21697            ADDQ.B    #1,D6               TIMES TWO
00011D9A  2E06      21698            MOVE.L    D6,D7               SETUP IN D7 IN CASE EXP=0
00011D9C  2407      21699   FPLNOCR  MOVE.L    D7,D2               SAVE RESULT
00011D9E  7C00      21700            MOVEQ     #0,D6               PREPARE ORIGINAL EXPONENT LOAD
00011DA0  1C1F      21701            MOVE.B    (SP)+,D6            LOAD IT BACK
00011DA2  0406 0041 21702            SUB.B     #64+1,D6            CONVERT EXPONENT TO BINARY
00011DA6  6728      21703            BEQ.S     FPLZPR              BRANCH ZERO PARTIAL HERE
00011DA8  1206      21704            MOVE.B    D6,D1               SAVE SIGN BYTE
00011DAA  6A02      21705            BPL.S     FPLPOS              BRANCH POSITIVE VALUE
00011DAC  4406      21706            NEG.B     D6                  FORCE POSITIVE
00011DAE  E09E      21707   FPLPOS   ROR.L     #8,D6               PREPARE TO CONVERT TO INTEGER
00011DB0  7A47      21708            MOVEQ     #$47,D5             SETUP EXPONENT MASK
00011DB2  DC86      21709   FPLNORM  ADD.L     D6,D6               SHIFT TO LEFT
00011DB4  5BCD FFFC 21710            DBMI      D5,FPLNORM          EXP-1 AND BRANCH IF NOT NORMALIZED
00011DB8  1C05      21711            MOVE.B    D5,D6               FIX IN EXPONENT
00011DBA  C23C 0080 21712            AND.B     #$80,D1             EXTRACT SIGN
00011DBE  8C01      21713            OR.B      D1,D6               INSERT SIGN IN
00011DC0  2E3C B172 21714            MOVE.L    #LOG2,D7            MULTIPLY EXPONENT BY LOG(2)
00011DC4  1840      
00011DC6  6100 000E 21715            BSR       FFPMUL2             MULTIPLY D6 AND D7
00011DCA  2C02      21716            MOVE.L    D2,D6               NOW ADD CORDIC RESULT
00011DCC  6100 FB16 21717            BSR       FFPADD              FOR FINAL ANSWER
                    21718   
00011DD0  4CDF 017E 21719   FPLZPR   MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011DD4  4E75      21720            RTS                           RETURN TO CALLER
                    21721   *******************************************
                    21722   * (C)  COPYRIGHT 1980 BY MOTOROLA INC.    *
                    21723   *******************************************
                    21724   
                    21725   ********************************************
                    21726   *          FFPMUL2 SUBROUTINE              *
                    21727   *                                          *
                    21728   *   THIS MODULE IS THE SECOND OF THE       *
                    21729   *   MULTIPLY ROUTINES.  IT IS 18% SLOWER   *
                    21730   *   BUT PROVIDES THE HIGHEST ACCURACY      *
                    21731   *   POSSIBLE.  THE ERROR IS EXACTLY .5     *
                    21732   *   LEAST SIGNIFICANT BIT VERSUS AN ERROR  *
                    21733   *   IN THE HIGH-SPEED DEFAULT ROUTINE OF   *
                    21734   *   .50390625 LEAST SIGNIFICANT BIT DUE    *
                    21735   *   TO TRUNCATION.                         *
                    21736   *                                          *
                    21737   * INPUT:                                   *
                    21738   *          D6 - FLOATING POINT MULTIPLIER  *
                    21739   *          D7 - FLOATING POINT MULTIPLICAN *
                    21740   *                                          *
                    21741   * OUTPUT:                                  *
                    21742   *          D7 - FLOATING POINT RESULT      *
                    21743   *                                          *
                    21744   * REGISTERS D3 THRU D5 ARE VOLATILE        *
                    21745   *                                          *
                    21746   * CONDITION CODES:                         *
                    21747   *          N - SET IF RESULT NEGATIVE      *
                    21748   *          Z - SET IF RESULT IS ZERO       *
                    21749   *          V - SET IF OVERFLOW OCCURRED    *
                    21750   *          C - UNDEFINED                   *
                    21751   *          X - UNDEFINED                   *
                    21752   *                                          *
                    21753   * CODE: 134 BYTES    STACK WORK: 0 BYTES   *
                    21754   *                                          *
                    21755   * NOTES:                                   *
                    21756   *   1) MULTIPIER UNALTERED (D6).           *
                    21757   *   2) UNDERFLOWS RETURN ZERO WITH NO      *
                    21758   *      INDICATOR SET.                      *
                    21759   *   3) OVERFLOWS WILL RETURN THE MAXIMUM   *
                    21760   *      VALUE WITH THE PROPER SIGN AND THE  *
                    21761   *      'V' BIT SET IN THE CCR.             *
                    21762   *                                          *
                    21763   *  TIMES: (8MHZ NO WAIT STATES ASSUMED)    *
                    21764   * ARG1 ZERO            5.750 MICROSECONDS  *
                    21765   * ARG2 ZERO            3.750 MICROSECONDS  *
                    21766   * MINIMUM TIME OTHERS 45.750 MICROSECONDS  *
                    21767   * MAXIMUM TIME OTHERS 61.500 MICROSECONDS  *
                    21768   * AVERAGE OTHERS      52.875 MICROSECONDS  *
                    21769   *                                          *
                    21770   ********************************************
                    21771   
                    21772   
                    21773   * FFPMUL2 SUBROUTINE ENTRY POINT
00011DD6  1A07      21774   FFPMUL2 MOVE.B D7,D5     PREPARE SIGN/EXPONENT WORK       4
00011DD8  6754      21775          BEQ.S  FFMRTN    RETURN IF RESULT ALREADY ZERO    8/10
00011DDA  1806      21776          MOVE.B D6,D4     COPY ARG1 SIGN/EXPONENT          4
00011DDC  676A      21777          BEQ.S  FFMRT0    RETURN ZERO IF ARG1=0            8/10
00011DDE  DA45      21778          ADD.W  D5,D5     SHIFT LEFT BY ONE                4
00011DE0  D844      21779          ADD.W  D4,D4     SHIFT LEFT BY ONE                4
00011DE2  7680      21780          MOVEQ  #-128,D3  PREPARE EXPONENT MODIFIER ($80)  4
00011DE4  B704      21781          EOR.B  D3,D4     ADJUST ARG1 EXPONENT TO BINARY   4
00011DE6  B705      21782          EOR.B  D3,D5     ADJUST ARG2 EXPONENT TO BINARY   4
00011DE8  DA04      21783          ADD.B  D4,D5     ADD EXPONENTS                    4
00011DEA  6960      21784          BVS.S  FFMOUF    BRANCH IF OVERFLOW/UNDERFLOW     8/10
00011DEC  1803      21785          MOVE.B D3,D4     OVERLAY $80 CONSTANT INTO D4     4
00011DEE  B945      21786          EOR.W  D4,D5     D5 NOW HAS SIGN AND EXPONENT     4
00011DF0  E25D      21787          ROR.W  #1,D5     MOVE TO LOW 8 BITS               8
00011DF2  4845      21788          SWAP.W D5        SAVE FINAL S+EXP IN HIGH WORD    4
00011DF4  3A06      21789          MOVE.W D6,D5     COPY ARG1 LOW BYTE               4
00011DF6  4207      21790          CLR.B  D7        CLEAR S+EXP OUT OF ARG2          4
00011DF8  4205      21791          CLR.B  D5        CLEAR S+EXP OUT OF ARG1 LOW BYTE 4
00011DFA  3805      21792          MOVE.W D5,D4     PREPARE ARG1LOWB FOR MULTIPLY    4
00011DFC  C8C7      21793          MULU.W D7,D4     D4 = ARG2LOWB X ARG1LOWB         38-54 (46)
00011DFE  4844      21794          SWAP.W D4        PLACE RESULT IN LOW WORD         4
00011E00  2607      21795          MOVE.L D7,D3     COPY ARG2                        4
00011E02  4843      21796          SWAP.W D3        TO ARG2HIGHW                     4
00011E04  C6C5      21797          MULU.W D5,D3     D3 = ARG1LOWB X ARG2HIGHW        38-54 (46)
00011E06  D883      21798          ADD.L  D3,D4     D4 = PARTIAL PRODUCT (NO CARRY)  8
00011E08  4846      21799          SWAP.W D6        TO ARG1 HIGH TWO BYTES           4
00011E0A  2606      21800          MOVE.L D6,D3     COPY ARG1HIGHW OVER              4
00011E0C  C6C7      21801          MULU.W D7,D3     D3 = ARG2LOWB X ARG1HIGHW        38-54 (46)
00011E0E  D883      21802          ADD.L  D3,D4     D4 = PARTIAL PRODUCT             8
00011E10  4244      21803          CLR.W  D4        CLEAR LOW END RUNOFF             4
00011E12  D904      21804          ADDX.B D4,D4     SHIFT IN CARRY IF ANY            4
00011E14  4844      21805          SWAP.W D4        PUT CARRY INTO HIGH WORD         4
00011E16  4847      21806          SWAP.W D7        NOW TOP OF ARG2                  4
00011E18  CEC6      21807          MULU.W D6,D7     D7 = ARG1HIGHW X ARG2HIGHW       40-70 (54)
00011E1A  4846      21808          SWAP.W D6        RESTORE ARG1                     4
00011E1C  4845      21809          SWAP.W D5        RESTORE S+EXP TO LOW WORD
00011E1E  DE84      21810          ADD.L  D4,D7     ADD PARTIAL PRODUCTS             8
00011E20  6A00 000E 21811          BPL    FFMNOR    BRANCH IF MUST NORMALIZE         8/10
00011E24  0687 0000 21812          ADD.L  #$80,D7   ROUND UP (CANNOT OVERFLOW)       16
00011E28  0080      
00011E2A  1E05      21813          MOVE.B D5,D7     INSERT SIGN AND EXPONENT         4
00011E2C  671A      21814          BEQ.S  FFMRT0    RETURN ZERO IF ZERO EXPONENT     8/10
00011E2E  4E75      21815   FFMRTN RTS              RETURN TO CALLER                 16
                    21816   
                    21817   * MUST NORMALIZE RESULT
00011E30  5305      21818   FFMNOR SUBQ.B #1,D5    BUMP EXPONENT DOWN BY ONE        4
00011E32  6914      21819          BVS.S  FFMRT0   RETURN ZERO IF UNDERFLOW         8/10
00011E34  6512      21820          BCS.S  FFMRT0   RETURN ZERO IF SIGN INVERTED     8/10
00011E36  7840      21821          MOVEQ  #$40,D4  ROUNDING FACTOR                  4
00011E38  DE84      21822          ADD.L  D4,D7    ADD IN ROUNDING FACTOR           8
00011E3A  DE87      21823          ADD.L  D7,D7    SHIFT TO NORMALIZE               8
00011E3C  6404      21824          BCC.S  FFMCLN   RETURN NORMALIZED NUMBER         8/10
00011E3E  E297      21825          ROXR.L #1,D7    ROUNDING FORCED CARRY IN TOP BIT 10
00011E40  5205      21826          ADDQ.B #1,D5    UNDO NORMALIZE ATTEMPT           4
00011E42  1E05      21827   FFMCLN MOVE.B D5,D7    INSERT SIGN AND EXPONENT         4
00011E44  6702      21828          BEQ.S  FFMRT0   RETURN ZERO IF EXPONENT ZERO     8/10
00011E46  4E75      21829          RTS              RETURN TO CALLER                 16
                    21830   
                    21831   * ARG1 ZERO
00011E48  7E00      21832   FFMRT0 MOVEQ  #0,D7     RETURN ZERO                      4
00011E4A  4E75      21833          RTS              RETURN TO CALLER                 16
                    21834   
                    21835   * OVERFLOW OR UNDERFLOW EXPONENT
00011E4C  6AFA      21836   FFMOUF BPL.S  FFMRT0    BRANCH IF UNDERFLOW TO GIVE ZERO 8/10
00011E4E  BD07      21837          EOR.B  D6,D7     CALCULATE PROPER SIGN            4
00011E50  8EBC FFFF 21838          OR.L   #$FFFFFF7F,D7 FORCE HIGHEST VALUE POSSIBLE 16
00011E54  FF7F      
00011E56  4A07      21839          TST.B  D7        SET SIGN IN RETURN CODE
00011E58  003C 0002 21840          ORI.B  #$02,CCR                            SET OVERFLOW BIT
00011E5C  4E75      21841          RTS              RETURN TO CALLER                 16
                    21842   ***************************************
                    21843   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    21844   ***************************************
                    21845   
                    21846   *************************************************
                    21847   *                  FFPPWR                       *
                    21848   *       FAST FLOATING POINT POWER FUNCTION      *
                    21849   *                                               *
                    21850   *  INPUT:   D6 - FLOATING POINT EXPONENT VALUE  *
                    21851   *           D7 - FLOATING POINT ARGUMENT VALUE  *
                    21852   *                                               *
                    21853   *  OUTPUT:  D7 - RESULT OF THE VALUE TAKEN TO   *
                    21854   *                THE POWER SPECIFIED            *
                    21855   *                                               *
                    21856   *     ALL REGISTERS BUT D7 ARE TRANSPARENT      *
                    21857   *                                               *
                    21858   *  CODE SIZE:  36 BYTES   STACK WORK: 42 BYTES  *
                    21859   *                                               *
                    21860   * CALLS SUBROUTINES: FFPLOG, FFPEXP AND FFPMUL  *
                    21861   *                                               *
                    21862   *  CONDITION CODES:                             *
                    21863   *        Z - SET IF THE RESULT IS ZERO          *
                    21864   *        N - CLEARED                            *
                    21865   *        V - SET IF OVERFLOW OCCURRED OR BASE   *
                    21866   *            VALUE ARGUMENT WAS NEGATIVE        *
                    21867   *        C - UNDEFINED                          *
                    21868   *        X - UNDEFINED                          *
                    21869   *                                               *
                    21870   *  NOTES:                                       *
                    21871   *    1) A NEGATIVE BASE VALUE WILL FORCE THE USE*
                    21872   *       IF ITS ABSOLUTE VALUE.  THE "V" BIT WILL*
                    21873   *       BE SET UPON FUNCTION RETURN.            *
                    21874   *    2) IF THE RESULT OVERFLOWS THEN THE        *
                    21875   *       MAXIMUM SIZE VALUE IS RETURNED WITH THE *
                    21876   *       "V" BIT SET IN THE CONDITION CODE.      *
                    21877   *    3) SPOT CHECKS SHOW AT LEAST SIX DIGIT     *
                    21878   *       PRECISION FOR 80 PERCENT OF THE CASES.  *
                    21879   *                                               *
                    21880   *  TIME: (8MHZ NO WAIT STATES ASSUMED)          *
                    21881   *                                               *
                    21882   *        THE TIMING IS VERY DATA SENSITIVE WITH *
                    21883   *        TEST SAMPLES RANGING FROM 720 TO       *
                    21884   *        1206 MICROSECONDS                      *
                    21885   *                                               *
                    21886   *************************************************
                    21887   
                    21888   
                    21889   
                    21890   *****************
                    21891   * POWER  ENTRY  *
                    21892   *****************
                    21893   
                    21894   * TAKE THE LOGORITHM OF THE BASE VALUE
00011E5E  4A07      21895   FFPPWR   TST.B     D7                  ? NEGATIVE BASE VALUE
00011E60  6A0C      21896            BPL.S     FPPPOS              BRANCH POSITIVE
00011E62  CE3C 007F 21897            AND.B     #$7F,D7             TAKE ABSOLUTE VALUE
00011E66  6106      21898            BSR.S     FPPPOS              FIND RESULT USING THAT
00011E68  003C 0002 21899            OR.B      #$02,CCR            FORCE "V" BIT ON FOR NEGATIVE ARGUMENT
00011E6C  4E75      21900            RTS                           RETURN TO CALLER
                    21901   
00011E6E  6100 FEA4 21902   FPPPOS   BSR       FFPLOG              FIND LOG OF THE NUMBER TO BE USED
00011E72  48E7 1C00 21903            MOVEM.L   D3-D5,-(SP)         SAVE MULTIPLY WORK REGISTERS
00011E76  6100 FF5E 21904            BSR       FFPMUL2             MULTIPLY BY THE EXPONENT
00011E7A  4CDF 0038 21905            MOVEM.L   (SP)+,D3-D5         RESTORE MULTIPLY WORK REGISTERS
                    21906   * IF OVERFLOWED, FFPEXP WILL SET "V" BIT AND RETURN DESIRED RESULT ANYWAY
00011E7E  6000 FD3A 21907            BRA       FFPEXP              RESULT IS EXPONENT
                    21908   ***************************************
                    21909   * (C) COPYRIGHT 1981 BY MOTOROLA INC. *
                    21910   ***************************************
                    21911   
                    21912   *************************************************
                    21913   *        FFPSIN FFPCOS FFPTAN FFPSINCS          *
                    21914   *     FAST FLOATING POINT SINE/COSINE/TANGENT   *
                    21915   *                                               *
                    21916   *  INPUT:   D7 - INPUT ARGUMENT (RADIAN)        *
                    21917   *                                               *
                    21918   *  OUTPUT:  D7 - FUNCTION RESULT                *
                    21919   *           (FFPSINCS ALSO RETURNS D6)          *
                    21920   *                                               *
                    21921   *     ALL OTHER REGISTERS TOTALLY TRANSPARENT   *
                    21922   *                                               *
                    21923   *  CODE SIZE: 334 BYTES   STACK WORK: 38 BYTES  *
                    21924   *                                               *
                    21925   *  CONDITION CODES:                             *
                    21926   *        Z - SET IF RESULT IN D7 IS ZERO        *
                    21927   *        N - SET IF RESULT IN D7 IS NEGATIVE    *
                    21928   *        C - UNDEFINED                          *
                    21929   *        V - SET IF RESULT IS MEANINGLESS       *
                    21930   *            (INPUT MAGNITUDE TOO LARGE)        *
                    21931   *        X - UNDEFINED                          *
                    21932   *                                               *
                    21933   *  FUNCTIONS:                                   *
                    21934   *             FFPSIN   -  SINE RESULT           *
                    21935   *             FFPCOS   -  COSINE RESULT         *
                    21936   *             FFPTAN   -  TANGENT RESULT        *
                    21937   *             FFPSINCS -  BOTH SINE AND COSINE  *
                    21938   *                         D6 - SIN, D7 - COSINE *
                    21939   *                                               *
                    21940   *  NOTES:                                       *
                    21941   *    1) INPUT VALUES ARE IN RADIANS.            *
                    21942   *    2) FUNCTION FFPSINCS RETURNS BOTH SINE     *
                    21943   *       AND COSINE TWICE AS FAST AS CALCULATING *
                    21944   *       THE TWO FUNCTIONS INDEPENDENTLY FOR     *
                    21945   *       THE SAME VALUE.  THIS IS HANDY FOR      *
                    21946   *       GRAPHICS PROCESSING.                    *
                    21947   *    2) INPUT ARGUMENTS LARGER THAN TWO PI      *
                    21948   *       SUFFER REDUCED PRECISION.  THE LARGER   *
                    21949   *       THE ARGUMENT, THE SMALLER THE PRECISION.*
                    21950   *       EXCESSIVELY LARGE ARGUMENTS WHICH HAVE  *
                    21951   *       LESS THAN 5 BITS OF PRECISION ARE       *
                    21952   *       RETURNED UNCHANGED WITH THE "V" BIT SET.*
                    21953   *    3) FOR TANGENT ANGLES OF INFINITE VALUE    *
                    21954   *       THE LARGEST POSSIBLE POSITIVE NUMBER    *
                    21955   *       IS RETURNED ($FFFFFF7F). THIS STILL     *
                    21956   *       GIVES RESULTS WELL WITHIN SINGLE        *
                    21957   *       PRECISION CALCULATION.                  *
                    21958   *    4) SPOT CHECKS SHOW ERRORS BOUNDED BY      *
                    21959   *       4 X 10**-7 BUT FOR ARGUMENTS CLOSE TO   *
                    21960   *       PI/2 INTERVALS WHERE 10**-5 IS SEEN.    *
                    21961   *                                               *
                    21962   *  TIME: (8MHZ NO WAIT STATES AND ARGUMENT      *
                    21963   *         ASSUMED WITHIN +-PI)                  *
                    21964   *                                               *
                    21965   *           FFPSIN       413 MICROSECONDS       *
                    21966   *           FFPCOS       409 MICROSECONDS       *
                    21967   *           FFPTAN       501 MICROSECONDS       *
                    21968   *           FFPSINCS     420 MICROSECONDS       *
                    21969   *************************************************
                    21970   
                    21971   
                    21972   
                    21973   
          C90F DB42 21974   PI       EQU       $C90FDB42          FLOATING CONSTANT PI
          C90F DAA2 21975   FIXEDPI  EQU       $C90FDAA2          PI SKELETON TO 32 BITS PRECISION
          A2F9 833E 21976   INV2PI   EQU       $A2F9833E          INVERSE OF TWO-PI
          9B74 EE40 21977   KINV     EQU       $9B74EE40          FLOATING K INVERSE
          EC91 6240 21978   NKFACT   EQU       $EC916240          NEGATIVE K INVERSE
                    21979   
                    21980   ********************************************
                    21981   * ENTRY FOR RETURNING BOTH SINE AND COSINE *
                    21982   ********************************************
00011E82  3F3C FFFE 21983   FFPSINCS MOVE.W    #-2,-(SP)           FLAG BOTH SINE AND COSINE WANTED
00011E86  6024      21984            BRA.S     FPSCOM              ENTER COMMON CODE
                    21985   
                    21986   **********************
                    21987   * TANGENT ENTRY POINT*
                    21988   **********************
00011E88  3F3C FFFF 21989   FFPTAN   MOVE.W    #-1,-(SP)           FLAG TANGENT WITH MINUS VALUE
00011E8C  6014      21990            BRA.S     FPSCHL              CHECK VERY SMALL VALUES
                    21991   
                    21992   **************************
                    21993   * COSINE ONLY ENTRY POINT*
                    21994   **************************
00011E8E  3F3C 0001 21995   FFPCOS   MOVE.W    #1,-(SP)            FLAG COSINE WITH POSITIVE VALUE
00011E92  6018      21996            BRA.S     FPSCOM              ENTER COMMON CODE
                    21997   
                    21998   * NEGATIVE SINE/TANGENT SMALL VALUE CHECK
00011E94  0C07 00B8 21999   FPSCHM   CMP.B     #$80+$40-8,D7       ? LESS OR SAME AS -2**-9
00011E98  6212      22000            BHI.S     FPSCOM              CONTINUE IF NOT TOO SMALL
                    22001   * RETURN ARGUMENT
00011E9A  548F      22002   FPSRTI   ADDQ.L    #2,SP               RID INTERNAL PARAMETER
00011E9C  4A07      22003            TST.B     D7                  SET CONDITION CODES
00011E9E  4E75      22004            RTS                           RETURN TO CALLER
                    22005   
                    22006   ************************
                    22007   * SINE ONLY ENTRY POINT*
                    22008   ************************
00011EA0  4267      22009   FFPSIN   CLR.W     -(SP)               FLAG SINE WITH ZERO
                    22010   * SINE AND TANGENT VALUES < 2**-9 RETURN IDENTITIES
00011EA2  4A07      22011   FPSCHL   TST.B     D7                  TEST SIGN
00011EA4  6BEE      22012            BMI.S     FPSCHM              BRANCH MINUS
00011EA6  0C07 0038 22013            CMP.B     #$40-8,D7           ? LESS OR SAME THAN 2**-9
00011EAA  63EE      22014            BLS.S     FPSRTI              RETURN IDENTITY
                    22015   
                    22016   * SAVE REGISTERS AND INSURE INPUT WITHIN + OR - PI RANGE
00011EAC  48E7 7E80 22017   FPSCOM   MOVEM.L   D1-D6/A0,-(SP)      SAVE ALL WORK REGISTERS
00011EB0  2407      22018            MOVE.L    D7,D2               COPY INPUT OVER
00011EB2  DE07      22019            ADD.B     D7,D7               RID SIGN BIT
00011EB4  0C07 008A 22020            CMP.B     #(64+5)<<1,D7       ? ABS(ARG) < 2**6 (32)
00011EB8  634A      22021            BLS.S     FPSNLR              BRANCH YES, NOT TOO LARGE
                    22022   * ARGUMENT IS TOO LARGE TO SUBTRACT TO WITHIN RANGE
00011EBA  0C07 00A8 22023            CMP.B     #(64+20)<<1,D7      ? TEST EXCESSIVE SIZE (>2**20)
00011EBE  630C      22024            BLS.S     FPSGPR              NO, GO AHEAD AND USE
                    22025   * ERROR - ARGUMENT SO LARGE RESULT HAS NO PRECISION
00011EC0  003C 0002 22026            OR.B      #$02,CCR            FORCE V BIT ON
00011EC4  4CDF 017E 22027            MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011EC8  548F      22028            ADDQ.L    #2,SP               CLEAN INTERNAL ARGUMENT OFF STACK
00011ECA  4E75      22029            RTS                           RETURN TO CALLER
                    22030   
                    22031   * WE MUST FIND MOD(ARG,TWOPI) SINCE ARGUMENT IS TOO LARGE FOR
                    22032   SUBTRACTIONS
00011ECC  2C3C A2F9 22033   FPSGPR   MOVE.L    #INV2PI,D6          LOAD UP 2*PI INVERSE CONSTANT
00011ED0  833E      
00011ED2  2E02      22034            MOVE.L    D2,D7               COPY OVER INPUT ARGUMENT
00011ED4  6100 FF00 22035            BSR       FFPMUL2             DIVIDE BY TWOPI (VIA MULTIPLY INVERSE)
                    22036   * CONVERT QUOTIENT TO FLOAT INTEGER
00011ED8  1A07      22037            MOVE.B    D7,D5               COPY EXPONENT OVER
00011EDA  CA3C 007F 22038            AND.B     #$7F,D5             RID SIGN FROM EXPONENT
00011EDE  0405 0058 22039            SUB.B     #64+24,D5           FIND FRACTIONAL PRECISION
00011EE2  4405      22040            NEG.B     D5                  MAKE POSITIVE
00011EE4  78FF      22041            MOVEQ     #-1,D4              SETUP MASK OF ALL ONES
00011EE6  4204      22042            CLR.B     D4                  START ZEROES AT LOW BYTE
00011EE8  EBAC      22043            LSL.L     D5,D4               SHIFT ZEROES INTO FRACTIONAL PART
00011EEA  883C 00FF 22044            OR.B      #$FF,D4             DO NOT REMOVE SIGN AND EXPONENT
00011EEE  CE84      22045            AND.L     D4,D7               STRIP FRACTIONAL BITS ENTIRELY
00011EF0  2C3C C90F 22046            MOVE.L    #PI+1,D6            LOAD UP 2*PI CONSTANT
00011EF4  DB43      
00011EF6  6100 FEDE 22047            BSR       FFPMUL2             MULTIPLY BACK OUT
00011EFA  2C07      22048            MOVE.L    D7,D6               SETUP TO SUBTRACT MULTIPLE OF TWOPI
00011EFC  2E02      22049            MOVE.L    D2,D7               MOVE ARGUMENT IN
00011EFE  6100 F9D2 22050            BSR       FFPSUB              FIND REMAINDER OF TWOPI DIVIDE
00011F02  2407      22051            MOVE.L    D7,D2               USE IT AS NEW INPUT ARGUMENT
                    22052   
                    22053   * CONVERT ARGUMENT TO BINARY(31,26) PRECISION FOR REDUCTION WITHIN +-PI
00011F04  283C 0C90 22054   FPSNLR   MOVE.L    #FIXEDPI>>4,D4      LOAD PI
00011F08  FDAA      
00011F0A  2E02      22055            MOVE.L    D2,D7               COPY FLOAT ARGUMENT
00011F0C  4207      22056            CLR.B     D7                  CLEAR SIGN AND EXPONENT
00011F0E  4A02      22057            TST.B     D2                  TEST SIGN
00011F10  6B1A      22058            BMI.S     FPSNMI              BRANCH NEGATIVE
00011F12  0402 0046 22059            SUB.B     #64+6,D2            OBTAIN SHIFT VALUE
00011F16  4402      22060            NEG.B     D2                  FOR 5 BIT NON-FRACTION BITS
00011F18  0C02 001F 22061            CMP.B     #31,D2              ? VERY SMALL NUMBER
00011F1C  6302      22062            BLS.S     FPSSH1              NO, GO AHEAD AND SHIFT
00011F1E  7E00      22063            MOVEQ     #0,D7               FORCE TO ZERO
00011F20  E4AF      22064   FPSSH1   LSR.L     D2,D7               CONVERT TO FIXED POINT
                    22065   * FORCE TO +PI OR BELOW
00011F22  BE84      22066   FPSPCK   CMP.L     D4,D7               ? GREATER THAN PI
00011F24  6F24      22067            BLE.S     FPSCKM              BRANCH NOT
00011F26  9E84      22068            SUB.L     D4,D7               SUBTRACT
00011F28  9E84      22069            SUB.L     D4,D7               .  TWOPI
00011F2A  60F6      22070            BRA.S     FPSPCK              AND CHECK AGAIN
                    22071   
00011F2C  0402 00C6 22072   FPSNMI   SUB.B     #$80+64+6,D2        RID SIGN AND GET SHIFT VALUE
00011F30  4402      22073            NEG.B     D2                  FOR 5 NON-FRACTIONAL BITS
00011F32  0C02 001F 22074            CMP.B     #31,D2              ? VERY SMALL NUMBER
00011F36  6302      22075            BLS.S     FPSSH2              NO, GO AHEAD AND SHIFT
00011F38  7E00      22076            MOVEQ     #0,D7               FORCE TO ZERO
00011F3A  E4AF      22077   FPSSH2   LSR.L     D2,D7               CONVERT TO FIXED POINT
00011F3C  4487      22078            NEG.L     D7                  MAKE NEGATIVE
00011F3E  4484      22079            NEG.L     D4                  MAKE -PI
                    22080   * FORCE TO -PI OR ABOVE
00011F40  BE84      22081   FPSNCK   CMP.L     D4,D7               ? LESS THAN -PI
00011F42  6C06      22082            BGE.S     FPSCKM              BRANCH NOT
00011F44  9E84      22083            SUB.L     D4,D7               ADD
00011F46  9E84      22084            SUB.L     D4,D7               .  TWOPI
00011F48  60F6      22085            BRA.S     FPSNCK              AND CHECK AGAIN
                    22086   
                    22087   *****************************************
                    22088   * CORDIC CALCULATION REGISTERS:         *
                    22089   * D1 - LOOP COUNT   A0 - TABLE POINTER  *
                    22090   * D2 - SHIFT COUNT                      *
                    22091   * D3 - X'   D5 - X                      *
                    22092   * D4 - Y'   D6 - Y                      *
                    22093   * D7 - TEST ARGUMENT                    *
                    22094   *****************************************
                    22095   
                    22096   * INPUT WITHIN RANGE, NOW START CORDIC SETUP
00011F4A  2A3C 0000 22097   FPSCKM   MOVE.L    #0,D5               X=0
00011F4E  0000      
00011F50  2C3C EC91 22098            MOVE.L    #NKFACT,D6          Y=NEGATIVE INVERSE K FACTOR SEED
00011F54  6240      
00011F56  283C 3243 22099            MOVE.L    #FIXEDPI>>2,D4      SETUP FIXED PI/2 CONSTANT
00011F5A  F6A8      
00011F5C  E787      22100            ASL.L     #3,D7               NOW TO BINARY(31,29) PRECISION
00011F5E  6B04      22101            BMI.S     FPSAP2              BRANCH IF MINUS TO ADD PI/2
00011F60  4486      22102            NEG.L     D6                  Y=POSITIVE INVERSE K FACTOR SEED
00011F62  4484      22103            NEG.L     D4                  SUBTRACT PI/2 FOR POSITIVE ARGUMENT
00011F64  DE84      22104   FPSAP2   ADD.L     D4,D7               ADD CONSTANT
00011F66  41FA 0252 22105            LEA       (FFPTHETA,PC),A0    LOAD ARCTANGENT TABLE
00011F6A  7217      22106            MOVEQ     #23,D1              LOOP 24 TIMES
00011F6C  74FF      22107            MOVEQ     #-1,D2              PRIME SHIFT COUNTER
                    22108   * CORDIC LOOP
00011F6E  5242      22109   FSINLP   ADDQ.W    #1,D2               INCREMENT SHIFT COUNT
00011F70  2605      22110            MOVE.L    D5,D3               COPY X
00011F72  2806      22111            MOVE.L    D6,D4               COPY Y
00011F74  E4A3      22112            ASR.L     D2,D3               SHIFT FOR X'
00011F76  E4A4      22113            ASR.L     D2,D4               SHIFT FOR Y'
00011F78  4A87      22114            TST.L     D7                  TEST ARG VALUE
00011F7A  6B0C      22115            BMI.S     FSBMI               BRANCH MINUS TEST
00011F7C  9A84      22116            SUB.L     D4,D5               X=X-Y'
00011F7E  DC83      22117            ADD.L     D3,D6               Y=Y+X'
00011F80  9E98      22118            SUB.L     (A0)+,D7            ARG=ARG-TABLE(N)
00011F82  51C9 FFEA 22119            DBRA      D1,FSINLP           LOOP UNTIL DONE
00011F86  600A      22120            BRA.S     FSCOM               ENTER COMMON CODE
00011F88  DA84      22121   FSBMI    ADD.L     D4,D5               X=X+Y'
00011F8A  9C83      22122            SUB.L     D3,D6               Y=Y-X'
00011F8C  DE98      22123            ADD.L     (A0)+,D7            ARG=ARG+TABLE(N)
00011F8E  51C9 FFDE 22124            DBRA      D1,FSINLP           LOOP UNTIL DONE
                    22125   
                    22126   * NOW SPLIT UP TANGENT AND FFPSINCS FROM SINE AND COSINE
00011F92  322F 001C 22127   FSCOM    MOVE.W    7*4(SP),D1          RELOAD INTERNAL PARAMETER
00011F96  6A22      22128            BPL.S     FSSINCOS            BRANCH FOR SINE OR COSINE
                    22129   
00011F98  5201      22130            ADDQ.B    #1,D1               SEE IF WAS -1 FOR TANGENT
00011F9A  6630      22131            BNE.S     FSDUAL              NO, MUST BE BOTH SIN AND COSINE
                    22132   * TANGENT FINISH
00011F9C  613A      22133            BSR.S     FSFLOAT             FLOAT Y (SIN)
00011F9E  2E06      22134            MOVE.L    D6,D7               SETUP FOR DIVIDE INTO
00011FA0  2C05      22135            MOVE.L    D5,D6               PREPARE X
00011FA2  6134      22136            BSR.S     FSFLOAT             FLOAT X (COS)
00011FA4  670C      22137            BEQ.S     FSTINF              BRANCH INFINITE RESULT
00011FA6  6100 FB7A 22138            BSR       FFPDIV              TANGENT = SIN/COS
00011FAA  4CDF 017E 22139   FSINFRT  MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011FAE  548F      22140            ADDQ.L    #2,SP               DELETE INTERNAL PARAMETER
00011FB0  4E75      22141            RTS                           RETURN TO CALLER
                    22142   * TANGENT IS INFINITE. RETURN MAXIMUM POSITIVE NUMBER.
00011FB2  2E3C FFFF 22143   FSTINF   MOVE.L    #$FFFFFF7F,D7       LARGEST FFP NUMBER
00011FB6  FF7F      
00011FB8  60F0      22144            BRA.S     FSINFRT             AND CLEAN UP
                    22145   
                    22146   * SINE AND COSINE
00011FBA  6702      22147   FSSINCOS BEQ.S     FSSINE              BRANCH IF SINE
00011FBC  2C05      22148            MOVE.L    D5,D6               USE X FOR COSINE
00011FBE  6118      22149   FSSINE   BSR.S     FSFLOAT             CONVERT TO FLOAT
00011FC0  2E06      22150            MOVE.L    D6,D7               RETURN RESULT
00011FC2  4A07      22151            TST.B     D7                  AND CONDITION CODE TEST
00011FC4  4CDF 017E 22152            MOVEM.L   (SP)+,D1-D6/A0      RESTORE REGISTERS
00011FC8  548F      22153            ADDQ.L    #2,SP               DELETE INTERNAL PARAMETER
00011FCA  4E75      22154            RTS                           RETURN TO CALLER
                    22155   
                    22156   * BOTH SINE AND COSINE
00011FCC  2F05      22157   FSDUAL   MOVE.L    D5,-(SP)            SAVE COSINE DERIVITIVE
00011FCE  6108      22158            BSR.S     FSFLOAT             CONVERT SINE DERIVITIVE TO FLOAT
00011FD0  2F46 0018 22159            MOVE.L    D6,6*4(SP)          PLACE SINE INTO SAVED D6
00011FD4  2C1F      22160            MOVE.L    (SP)+,D6            RESTORE COSINE DERIVITIVE
00011FD6  60E6      22161            BRA.S     FSSINE              AND CONTINUE RESTORING SINE ON THE SLY
                    22162   
                    22163   * FSFLOAT - FLOAT INTERNAL PRECISION BUT TRUNCATE TO ZERO IF < 2**-21
00011FD8  2806      22164   FSFLOAT  MOVE.L    D6,D4               COPY INTERNAL PRECISION VALUE
00011FDA  6B0E      22165            BMI.S     FSFNEG              BRANCH NEGATIVE
00011FDC  0C86 0000 22166            CMP.L     #$000000FF,D6       ? TEST MAGNITUDE
00011FE0  00FF      
00011FE2  6200 0242 22167            BHI       FFPTNORM            NORMALIZE IF NOT TOO SMALL
00011FE6  7C00      22168   FSFZRO   MOVEQ     #0,D6               RETURN A ZERO
00011FE8  4E75      22169            RTS                           RETURN TO CALLER
00011FEA  E084      22170   FSFNEG   ASR.L     #8,D4               SEE IF ALL ONES BITS 8-31
00011FEC  5284      22171            ADDQ.L    #1,D4               ? GOES TO ZERO
00011FEE  6600 0236 22172            BNE       FFPTNORM            NORMALIZE IF NOT TOO SMALL
00011FF2  60F2      22173            BRA.S     FSFZRO              RETURN ZERO
                    22174   ***************************************
